<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NetOps - 项目管理</title>
<link rel="stylesheet" href="/fontawesome.min.css">

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f0f2f5; min-height: 100vh; }

  .header {
    background: #1e40af;
    color: #fff;
    padding: 20px 32px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .header i { font-size: 24px; }
  .header h1 { font-size: 20px; font-weight: 600; }
  .header small { opacity: 0.7; font-size: 13px; }

  .container { max-width: 960px; margin: 32px auto; padding: 0 16px; }

  .actions { display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap; }
  .btn {
    padding: 10px 20px;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: all 0.15s;
  }
  .btn-primary { background: #1e40af; color: #fff; }
  .btn-primary:hover { background: #1d3a9f; }
  .btn-outline { background: #fff; color: #374151; border: 1px solid #e5e7eb; }
  .btn-outline:hover { background: #f9fafb; }

  .project-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }

  .project-card {
    background: #fff;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    border: 2px solid transparent;
    transition: all 0.15s;
    position: relative;
  }
  .project-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.12); border-color: #dbeafe; }
  .project-card.active { border-color: #1e40af; background: #eff6ff; }

  .project-icon {
    width: 44px; height: 44px;
    background: #dbeafe;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    margin-bottom: 12px;
  }
  .project-name { font-size: 16px; font-weight: 600; color: #111827; margin-bottom: 4px; }
  .project-meta { font-size: 12px; color: #6b7280; margin-bottom: 8px; }
  .project-stats { font-size: 12px; color: #9ca3af; display: flex; gap: 12px; }

  .project-actions { display: flex; gap: 8px; margin-top: 14px; }
  .project-actions .btn { padding: 6px 12px; font-size: 12px; flex: 1; justify-content: center; }
  .btn-enter { background: #1e40af; color: #fff; }
  .btn-enter:hover { background: #1d3a9f; }
  .btn-delete { background: #fff; color: #dc2626; border: 1px solid #fecaca; }
  .btn-delete:hover { background: #fef2f2; }

  .empty { text-align: center; padding: 60px 20px; color: #9ca3af; }
  .empty i { font-size: 48px; margin-bottom: 12px; opacity: 0.4; }
  .empty p { font-size: 15px; }

  /* Modal */
  .modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 100;
    align-items: center; justify-content: center;
  }
  .modal-overlay.show { display: flex; }
  .modal {
    background: #fff;
    border-radius: 16px;
    padding: 28px;
    width: 420px;
    max-width: 90vw;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  }
  .modal h2 { font-size: 18px; margin-bottom: 16px; color: #111827; }
  .modal input {
    width: 100%; padding: 10px 14px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 14px;
    outline: none;
    margin-bottom: 16px;
  }
  .modal input:focus { border-color: #1e40af; box-shadow: 0 0 0 3px rgba(30,64,175,0.1); }
  .modal-btns { display: flex; gap: 10px; justify-content: flex-end; }
  .modal-btns .btn { padding: 8px 18px; }

  .toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
    background: #111827; color: #fff;
    padding: 10px 20px; border-radius: 8px;
    font-size: 14px;
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
    z-index: 200;
  }
  .toast.show { opacity: 1; }
  .toast.error { background: #dc2626; }
  .toast.success { background: #16a34a; }

  .back-link {
    display: inline-flex; align-items: center; gap: 6px;
    color: #1e40af; text-decoration: none; font-size: 14px;
    padding: 16px 32px; display: block;
  }
  .back-link:hover { text-decoration: underline; }

  .loading { display: flex; align-items: center; justify-content: center; padding: 60px; color: #9ca3af; }
  .spinner {
    width: 32px; height: 32px;
    border: 3px solid #e5e7eb;
    border-top-color: #1e40af;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    margin-right: 12px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .card-enter-btn { position: absolute; top: 16px; right: 16px; }

  /* AI Settings Modal */
  #aiSettingsModal {
    display: none; position: fixed; inset: 0; z-index: 350;
    background: rgba(0,0,0,0.7); align-items: center; justify-content: center;
  }
  #aiSettingsModal.show { display: flex; }
  .ai-modal {
    background: #1e2433; border-radius: 14px; width: 480px; max-height: 85vh;
    display: flex; flex-direction: column; box-shadow: 0 20px 60px rgba(0,0,0,.4); overflow: hidden;
  }
  .ai-modal-header {
    padding: 16px 20px; background: #2563eb; display: flex; align-items: center; gap: 10px;
  }
  .ai-modal-header span { font-size: 15px; font-weight: 600; color: #fff; }
  .ai-modal-header .close-btn {
    margin-left: auto; background: none; border: none; color: rgba(255,255,255,.7);
    cursor: pointer; font-size: 20px; padding: 2px 6px; border-radius: 4px;
  }
  .ai-modal-body { padding: 20px; overflow-y: auto; flex: 1; }
  .ai-tabs { display: flex; gap: 8px; margin-bottom: 16px; }
  .ai-tab {
    flex: 1; padding: 8px; border-radius: 8px; border: 1px solid #4a5568;
    background: #2d3748; color: #e2e8f0; cursor: pointer; font-size: 13px; font-weight: 600;
  }
  .ai-tab.active { background: #2563eb; border-color: #2563eb; }
  .ai-tab:hover:not(.active) { background: #374151; }
  .ai-field { margin-bottom: 14px; }
  .ai-field label {
    display: block; font-size: 12px; color: #9ca3af; margin-bottom: 6px;
    text-transform: uppercase; letter-spacing: .5px;
  }
  .ai-field input {
    width: 100%; background: #2d3748; border: 1px solid #4a5568; color: #e2e8f0;
    border-radius: 8px; padding: 9px 12px; font-size: 13px; outline: none; box-sizing: border-box;
  }
  .ai-field input:focus { border-color: #2563eb; }
  .ai-hint { font-size: 11px; color: #6b7280; margin-top: 4px; }
  .ai-info { font-size: 11px; color: #6b7280; background: #2d3748; border-radius: 6px; padding: 8px 10px; line-height: 1.6; }
  .ai-test-result { margin-top: 12px; font-size: 13px; border-radius: 8px; padding: 10px 14px; display: none; white-space: pre-wrap; line-height: 1.5; }
  .ai-test-result.ok { display: block; background: #1a2a1a; border: 1px solid #2d4a2d; color: #86efac; }
  .ai-test-result.err { display: block; background: #2a1a1a; border: 1px solid #4a2a2a; color: #fca5a5; }
  .ai-modal-footer { padding: 14px 20px; border-top: 1px solid #2d3748; display: flex; gap: 10px; justify-content: flex-end; }
  .ai-btn { border: none; padding: 9px 18px; border-radius: 8px; cursor: pointer; font-size: 13px; font-weight: 600; }
  .ai-btn-test { background: #059669; color: #fff; }
  .ai-btn-test:hover { background: #047857; }
  .ai-btn-save { background: #2563eb; color: #fff; }
  .ai-btn-save:hover { background: #1d4ed8; }
  .ai-btn-cancel { background: #374151; color: #9ca3af; }
  .ai-btn-cancel:hover { background: #4b5563; }

  .header-actions { margin-left: auto; display: flex; gap: 8px; align-items: center; }
  .header-btn {
    background: rgba(255,255,255,0.15); color: #fff; border: 1px solid rgba(255,255,255,0.25);
    border-radius: 8px; padding: 8px 16px; font-size: 13px; cursor: pointer;
    display: flex; align-items: center; gap: 6px; transition: all 0.15s;
  }
  .header-btn:hover { background: rgba(255,255,255,0.25); }
</style>
</head>
<body>

<div class="header">
  <i class="fa-solid fa-diagram-project"></i>
  <div>
    <h1>NetOps 项目管理</h1>
    <small>选择或新建项目，开始拓扑设计</small>
  </div>
  <div class="header-actions">
    <button class="header-btn" onclick="openAISettings()">
      <i class="fa-solid fa-robot"></i> AI 配置
    </button>
  </div>
</div>

<a href="/" class="back-link"><i class="fa-solid fa-arrow-left"></i> 返回拓扑编辑器</a>

<div class="container">
  <div class="actions">
    <button class="btn btn-primary" onclick="showNewModal()">
      ＋ 新建项目
    </button>
    <button class="btn btn-outline" onclick="loadProjects()">
      <i class="fa-solid fa-refresh"></i> 刷新
    </button>
  </div>

  <div id="projectGrid" class="project-grid">
    <div class="loading"><div class="spinner"></div>加载中...</div>
  </div>
</div>

<!-- New Project Modal -->
<div class="modal-overlay" id="newModal">
  <div class="modal">
    <h2>新建项目</h2>
    <input id="newProjName" placeholder="输入项目名称..." onkeydown="if(event.key==='Enter')createProject()" autofocus>
    <div class="modal-btns">
      <button class="btn btn-outline" onclick="hideNewModal()">取消</button>
      <button class="btn btn-primary" onclick="createProject()">创建</button>
    </div>
  </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal-overlay" id="delModal">
  <div class="modal">
    <h2>删除项目</h2>
    <p id="delProjName" style="font-size:14px;color:#374151;margin-bottom:16px;"></p>
    <p style="font-size:13px;color:#dc2626;margin-bottom:16px;">删除后无法恢复，确定要删除吗？</p>
    <div class="modal-btns">
      <button class="btn btn-outline" id="btn-del-cancel" onclick="closeDelModal()">取消</button>
      <button class="btn btn-delete" id="btn-del-confirm" onclick="confirmDel()">确认删除</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<!-- AI Settings Modal -->
<div id="aiSettingsModal">
  <div class="ai-modal" style="width:560px;">
    <div class="ai-modal-header">
      <i class="fa-solid fa-robot" style="color:#fff;font-size:18px"></i>
      <span>🤖 AI 配置</span>
      <button class="close-btn" onclick="closeAISettings()">&times;</button>
    </div>
    <div class="ai-modal-body">

      <!-- Provider Tabs -->
      <div class="ai-tabs" id="aiProviderTabs">
        <button class="ai-tab active" data-provider="minimax" onclick="selectProvider('minimax')">MiniMax</button>
        <button class="ai-tab" data-provider="siliconflow" onclick="selectProvider('siliconflow')">硅基流动</button>
        <button class="ai-tab" data-provider="openai" onclick="selectProvider('openai')">OpenAI</button>
        <button class="ai-tab" data-provider="custom" onclick="selectProvider('custom')">自定义</button>
      </div>

      <!-- Auth Type Toggle -->
      <div style="display:flex;gap:8px;margin-bottom:16px;">
        <button class="ai-tab active" id="tab-apikey" onclick="switchAITab('apikey')" style="flex:1;">🔑 API Key</button>
        <button class="ai-tab" id="tab-oauth" onclick="switchAITab('oauth')" style="flex:1;">🌐 Access Token</button>
      </div>

      <!-- API Key Panel -->
      <div id="panel-apikey">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div class="ai-field">
            <label>API 地址</label>
            <input id="ai-api-url" placeholder="https://api.minimaxi.com/anthropic">
          </div>
          <div class="ai-field">
            <label>模型</label>
            <input id="ai-model" placeholder="如 MiniMax-M2.5-highspeed" style="width:100%;background:#2d3748;border:1px solid #4a5568;color:#e2e8f0;border-radius:8px;padding:9px 12px;font-size:13px;outline:none;box-sizing:border-box;">
          </div>
        </div>
        <div class="ai-field">
          <label>API Key</label>
          <input id="ai-api-key" type="password" placeholder="sk-..." style="width:100%;">
        </div>
      </div>

      <!-- OAuth Panel -->
      <div id="panel-oauth" style="display:none;">
        <div class="ai-field">
          <div style="background:#1a2a1a;border:1px solid #2d4a2d;border-radius:10px;padding:12px;margin-bottom:14px;font-size:12px;color:#86efac;">
            🌐 通过 <b>MiniMax 开放平台</b> 获取 Access Token（以 eyJ 开头）<br>
            <a href="https://platform.minimaxi.com/" target="_blank" style="color:#4ade80;">→ 前往 platform.minimaxi.com</a>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div class="ai-field">
            <label>Access Token</label>
            <input id="ai-oauth-token" type="password" placeholder="eyJhbGc...">
          </div>
          <div class="ai-field">
            <label>模型</label>
            <input id="ai-oauth-model" placeholder="如 MiniMax-M2.5-highspeed" style="width:100%;background:#2d3748;border:1px solid #4a5568;color:#e2e8f0;border-radius:8px;padding:9px 12px;font-size:13px;outline:none;box-sizing:border-box;">
          </div>
        </div>
      </div>

      <!-- Advanced Section -->
      <div style="border-top:1px solid #2d3748;margin-top:16px;padding-top:14px;">
        <div onclick="toggleAdvanced()" style="cursor:pointer;display:flex;align-items:center;gap:6px;color:#9ca3af;font-size:13px;user-select:none;">
          <i class="fa-solid fa-chevron-down" id="advArrow" style="transition:transform 0.2s;"></i>
          高级配置
        </div>
        <div id="advPanel" style="display:none;margin-top:12px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="ai-field">
              <label>Temperature <span style="color:#6b7280;font-size:11px;">(创造性)</span></label>
              <div style="display:flex;align-items:center;gap:8px;">
                <input id="ai-temperature" type="range" min="0" max="1" step="0.05" value="0.7" oninput="updateTempDisplay(this.value)" style="flex:1;">
                <span id="tempDisplay" style="color:#e2e8f0;font-size:13px;min-width:32px;text-align:right;">0.7</span>
              </div>
            </div>
            <div class="ai-field">
              <label>Max Tokens <span style="color:#6b7280;font-size:11px;">(最大输出)</span></label>
              <input id="ai-max-tokens" type="number" placeholder="8192" value="8192" style="width:100%;">
            </div>
          </div>
          <div class="ai-field">
            <label>系统提示词 <span style="color:#6b7280;font-size:11px;">(System Prompt)</span></label>
            <textarea id="ai-system-prompt" rows="4" placeholder="定义 AI 的角色和行为..." style="width:100%;background:#2d3748;border:1px solid #4a5568;color:#e2e8f0;border-radius:8px;padding:9px 12px;font-size:13px;resize:vertical;box-sizing:border-box;font-family:inherit;line-height:1.5;"></textarea>
            <div class="ai-hint">定义 AI 助手的角色、能力范围和回复规则。留空使用默认提示词。</div>
          </div>
        </div>
      </div>

      <div id="ai-test-result" class="ai-test-result"></div>
    </div>
    <div class="ai-modal-footer">
      <button class="ai-btn ai-btn-test" onclick="testAI()">
        <i class="fa-solid fa-plug"></i> 测试连接
      </button>
      <button class="ai-btn ai-btn-save" onclick="saveAISettings()">保存配置</button>
      <button class="ai-btn ai-btn-cancel" onclick="closeAISettings()">取消</button>
    </div>
  </div>
</div>


<script>
// ──────────────────────────────────────────
// State
// ──────────────────────────────────────────
var projects = [];
var currentProjId = null;
var deleteTargetId = null;

// ──────────────────────────────────────────
// Init
// ──────────────────────────────────────────
document.addEventListener('DOMContentLoaded', loadProjects);

// ──────────────────────────────────────────
// Load projects
// ──────────────────────────────────────────
function loadProjects() {
  var grid = document.getElementById('projectGrid');
  grid.innerHTML = '<div class="loading"><div class="spinner"></div>加载中...</div>';
  fetch('/api/projects/')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      projects = data || [];
      renderProjects();
    })
    .catch(function(err) {
      grid.innerHTML = '<div class="empty"><i class="fa-solid fa-folder-open"></i><p>加载失败: ' + err.message + '</p></div>';
    });
}

// ──────────────────────────────────────────
// Render
// ──────────────────────────────────────────
function renderProjects() {
  var grid = document.getElementById('projectGrid');
  if (projects.length === 0) {
    grid.innerHTML = '<div class="empty"><i class="fa-solid fa-folder-open"></i><p>还没有项目，点击「新建项目」创建第一个</p></div>';
    return;
  }
  var html = '';
  for (var i = 0; i < projects.length; i++) {
    var p = projects[i];
    html += '<div class="project-card">';
    html += '  <div class="project-icon" style="color:#eab308;"><i class="fa-solid fa-folder"></i></div>';
    html += '  <div class="project-name">' + escHtml(p.name || p.id) + '</div>';
    html += '  <div class="project-meta">创建于 ' + (p.created || '未知') + '</div>';
    html += '  <div class="project-stats">';
    html += '    <span><i class="fa-solid fa-server"></i> ' + (p.nodeCount || 0) + ' 个设备</span>';
    html += '    <span><i class="fa-solid fa-link"></i> ' + (p.edgeCount || 0) + ' 条连线</span>';
    html += '  </div>';
    html += '  <div class="project-actions">';
    html += '    <button class="btn btn-enter" data-proj-id="' + escAttr(p.id) + '"><i class="fa-solid fa-play"></i> 进入</button>';
    html += '    <button class="btn btn-delete" data-proj-id="' + escAttr(p.id) + '" data-proj-name="' + escAttr(p.name || p.id) + '" title="删除项目"><i class="fa-solid fa-trash"></i></button>';
    html += '  </div>';
    html += '</div>';
  }
  grid.innerHTML = html;
}

// ──────────────────────────────────────────
// Enter project
// ──────────────────────────────────────────
function enterProject(projId) {
  // Redirect to main page with this project
  window.location.href = '/' + encodeURIComponent(projId);
}

// ──────────────────────────────────────────
// New project modal
// ──────────────────────────────────────────
function showNewModal() {
  document.getElementById('newModal').classList.add('show');
  document.getElementById('newProjName').value = '';
  document.getElementById('newProjName').focus();
}
function hideNewModal() {
  document.getElementById('newModal').classList.remove('show');
}

function createProject() {
  var name = document.getElementById('newProjName').value.trim();
  if (!name) { toast('请输入项目名称', 'error'); return; }
  hideNewModal();
  var projId = document.getElementById('newProjName').value.trim();
  fetch('/api/projects/', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name: name })
  }).then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.error) { toast(data.error, 'error'); loadProjects(); return; }
      toast('✓ 项目已创建：' + name, 'success');
      // Redirect to new project
      window.location.href = data.redirect || ('/' + encodeURIComponent(name));
    })
    .catch(function(err) {
      toast('创建失败: ' + err.message, 'error');
    });
}

// ──────────────────────────────────────────
// Project delete
// ──────────────────────────────────────────


// ──────────────────────────────────────────
// Toast
// ──────────────────────────────────────────
// Bind modal buttons via addEventListener (more reliable than onclick)
document.addEventListener('click', function(e) {
  if (e.target.closest('#btn-del-cancel')) {
    closeDelModal();
    return;
  }
  if (e.target.closest('#btn-del-confirm')) {
    confirmDel();
    return;
  }
}, true); // Use capture phase to catch events early

// Global click listener for project card buttons
document.addEventListener('click', function(e) {
  var enterBtn = e.target.closest('.btn-enter');
  if (enterBtn) {
    var id = enterBtn.dataset.projId;
    if (id) enterProject(id);
    return;
  }
  var delBtn = e.target.closest('.btn-delete');
  if (delBtn) {
    var id = delBtn.dataset.projId;
    var name = delBtn.dataset.projName;
    if (id) showDelModal(id, name);
    return;
  }
});

// ── Project Delete ─────────────────────────────────────────
var _delTargetId = null;

function showDelModal(id, name) {
  _delTargetId = id;
  document.getElementById('delProjName').textContent = name || id;
  var modal = document.getElementById('delModal');
  if (modal) modal.style.display = 'flex';
}

function closeDelModal() {
  _delTargetId = null;
  var modal = document.getElementById('delModal');
  if (modal) modal.style.display = 'none';
}

function confirmDel() {
  var id = _delTargetId;
  if (!id) { toast('没有选择要删除的项目', 'error'); return; }
  fetch('/api/projects/' + encodeURIComponent(id), {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ _method: 'delete' })
  }).then(function(r) { return r.json(); })
    .then(function(data) {
      closeDelModal();
      toast('✓ 项目已删除', 'success');
      loadProjects();
    })
    .catch(function(err) {
      closeDelModal();
      toast('删除失败: ' + (err.message || '未知错误'), 'error');
    });
}

function toast(msg, type) {
  var el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast' + (type ? ' ' + type : '');
  el.classList.add('show');
  setTimeout(function() { el.classList.remove('show'); }, 2500);
}

// ──────────────────────────────────────────
// Utilities
// ──────────────────────────────────────────
function escHtml(s) {
  s = String(s || '');
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function escAttr(s) {
  return String(s || '').replace(/'/g, '%27').replace(/"/g, '%22');
}

// ──────────────────────────────────────────
// AI Settings (global, not per-project)
// ──────────────────────────────────────────
var _providers = {
  minimax: {
    name: 'MiniMax',
    api_url: 'https://api.minimaxi.com/anthropic',
    models: ['MiniMax-M2.5-highspeed', 'MiniMax-M2.5', 'MiniMax-M2.1-highspeed', 'MiniMax-M2.1', 'MiniMax-M2.7-highspeed', 'MiniMax-M2.7']
  },
  siliconflow: {
    name: '硅基流动',
    api_url: 'https://api.siliconflow.cn/v1',
    models: ['Qwen/Qwen2.5-72B-Instruct', 'deepseek-ai/DeepSeek-V3', 'THUDM/GLM-4-Plus', 'Qwen/Qwen2.5-7B-Instruct', 'deepseek-ai/DeepSeek-R1']
  },
  openai: {
    name: 'OpenAI',
    api_url: 'https://api.openai.com/v1',
    models: ['gpt-4o', 'gpt-4o-mini', 'gpt-4-turbo', 'gpt-3.5-turbo']
  },
  custom: {
    name: '自定义',
    api_url: '',
    models: []
  }
};
var _currentProvider = 'minimax';
var _settingsData = {};

function selectProvider(p) {
  _currentProvider = p;
  // Update tab active states
  document.querySelectorAll('#aiProviderTabs .ai-tab').forEach(function(t) {
    t.classList.toggle('active', t.dataset.provider === p);
  });
  // Auto-fill API URL
  var urlField = document.getElementById('ai-api-url');
  if (p !== 'custom') {
    urlField.value = _providers[p].api_url;
    urlField.placeholder = _providers[p].api_url;
    urlField.readOnly = true;
    urlField.style.opacity = '0.7';
  } else {
    urlField.placeholder = 'https://your-api-endpoint.com/v1';
    urlField.readOnly = false;
    urlField.style.opacity = '1';
  }

}


function switchAITab(tab) {
  document.getElementById('tab-apikey').classList.toggle('active', tab === 'apikey');
  document.getElementById('tab-oauth').classList.toggle('active', tab === 'oauth');
  document.getElementById('panel-apikey').style.display = tab === 'apikey' ? 'block' : 'none';
  document.getElementById('panel-oauth').style.display = tab === 'oauth' ? 'block' : 'none';
}

function toggleAdvanced() {
  var panel = document.getElementById('advPanel');
  var arrow = document.getElementById('advArrow');
  var isHidden = panel.style.display === 'none';
  panel.style.display = isHidden ? 'block' : 'none';
  arrow.style.transform = isHidden ? 'rotate(180deg)' : '';
}

function updateTempDisplay(val) {
  document.getElementById('tempDisplay').textContent = parseFloat(val).toFixed(2);
}

function openAISettings() {
  document.getElementById('aiSettingsModal').classList.add('show');
  document.getElementById('ai-test-result').className = 'ai-test-result';
  document.getElementById('ai-test-result').style.display = 'none';
  document.getElementById('advPanel').style.display = 'none';
  document.getElementById('advArrow').style.transform = '';

  fetch('/api/llm/settings')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      _settingsData = data;
      var provider = data.provider || 'minimax';
      var isOAuth = !!(data.oauth_token);

      _currentProvider = provider;
      selectProvider(provider);
      switchAITab(isOAuth ? 'oauth' : 'apikey');

      // Load values
      document.getElementById('ai-api-url').value = data.api_url || _providers[provider].api_url || '';
      document.getElementById('ai-api-key').value = data.api_key && !data.api_key.includes('****') ? data.api_key : '';
      document.getElementById('ai-api-key').placeholder = data.api_key && data.api_key.includes('****') ? '(已保存 Key)' : 'sk-...';
      document.getElementById('ai-oauth-token').value = data.oauth_token || '';
      document.getElementById('ai-oauth-model').value = data.model || '';
      document.getElementById('ai-oauth-model').value = data.model || '';
      document.getElementById('ai-temperature').value = data.temperature || 0.7;
      document.getElementById('tempDisplay').textContent = parseFloat(data.temperature || 0.7).toFixed(2);
      document.getElementById('ai-max-tokens').value = data.max_tokens || 8192;
      document.getElementById('ai-system-prompt').value = data.system_prompt || '';

      // Set current model value
      var modelSel = isOAuth ? 'ai-oauth-model' : 'ai-model';
      document.getElementById(modelSel).value = data.model || '';
    })
    .catch(function() {});
}

function closeAISettings() {
  document.getElementById('aiSettingsModal').classList.remove('show');
}

function saveAISettings() {
  var tab = document.getElementById('tab-apikey').classList.contains('active') ? 'apikey' : 'oauth';
  var payload = {
    provider: _currentProvider,
    temperature: parseFloat(document.getElementById('ai-temperature').value) || 0.7,
    max_tokens: parseInt(document.getElementById('ai-max-tokens').value) || 8192,
    system_prompt: document.getElementById('ai-system-prompt').value.trim()
  };

  if (tab === 'apikey') {
    payload.api_url = document.getElementById('ai-api-url').value.trim();
    payload.model = document.getElementById('ai-model').value.trim();
    var key = document.getElementById('ai-api-key').value.trim();
    if (key) payload.api_key = key;
    // Only clear oauth if user switched away
    payload.oauth_token = '';
  } else {
    payload.api_url = _providers[_currentProvider] ? _providers[_currentProvider].api_url : document.getElementById('ai-api-url').value.trim();
    payload.model = document.getElementById('ai-oauth-model').value.trim();
    payload.oauth_token = document.getElementById('ai-oauth-token').value.trim();
    payload.api_key = '';
  }

  fetch('/api/llm/settings', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  }).then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.error) { toast('保存失败: ' + data.error, 'error'); return; }
      toast('✓ AI 配置已保存', 'success');
      closeAISettings();
    })
    .catch(function(err) { toast('保存失败: ' + err.message, 'error'); });
}

function testAI() {
  var tab = document.getElementById('tab-apikey').classList.contains('active') ? 'apikey' : 'oauth';
  var payload = {};
  if (tab === 'apikey') {
    payload.api_url = document.getElementById('ai-api-url').value.trim();
    payload.api_key = document.getElementById('ai-api-key').value.trim();
    payload.model = document.getElementById('ai-model').value.trim() || 'MiniMax-M2.5-highspeed';
  } else {
    payload.oauth_token = document.getElementById('ai-oauth-token').value.trim();
    payload.model = document.getElementById('ai-oauth-model').value.trim() || 'MiniMax-M2.5-highspeed';
  }
  var result = document.getElementById('ai-test-result');
  result.className = 'ai-test-result';
  result.textContent = '⏳ 测试中，请稍候...';
  result.style.display = 'block';
  fetch('/api/llm/test', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  }).then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.ok) {
        result.className = 'ai-test-result ok';
        result.textContent = '✅ 连接成功！AI 响应: ' + (data.reply || '').slice(0, 150);
      } else {
        result.className = 'ai-test-result err';
        result.textContent = '❌ 连接失败: ' + (data.error || '未知错误');
      }
    })
    .catch(function(err) {
      result.className = 'ai-test-result err';
      result.textContent = '❌ 请求失败: ' + err.message;
    });
}



</script>
