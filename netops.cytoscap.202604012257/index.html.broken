<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NetOps - 网络拓扑编辑器</title>
<link rel="stylesheet" href="fontawesome.min.css">
<script src="cytoscape.min.js"></script>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #1e2433;
    color: #1f2937;
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    user-select: none;
  }

  /* === Header === */
  header {
    background: #ffffff;
    border-bottom: 1px solid #e5e7eb;
    padding: 8px 16px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
    z-index: 10;
  }

  .logo {
    font-size: 16px;
    font-weight: 700;
    color: #2563eb;
    letter-spacing: 2px;
    white-space: nowrap;
  }

  .toolbar {
    display: flex;
    gap: 4px;
    flex: 1;
    flex-wrap: wrap;
  }

  .toolbar button {
    background: #f3f4f6;
    border: 1px solid #374151;
    color: #6b7280;
    padding: 5px 12px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 12px;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .toolbar button:hover { background: #374151; color: #fff; }
  .toolbar button.active { background: #3b82f6; border-color: #2563eb; color: #fff; }
  .toolbar button.danger:hover { background: #dc2626; border-color: #dc2626; color: #fff; }
  .toolbar button.lock-locked { background: #fef3c7; color: #92400e; border-color: #f59e0b; }
  .toolbar button.lock-unlocked { background: #d1fae5; color: #065f46; border-color: #10b981; }

  /* === Main layout === */
  .main {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  /* === Device Palette === */
  .palette {
    width: 100px;
    background: #ffffff;
    border-right: 1px solid #e5e7eb;
    padding: 10px 6px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow-y: auto;
    flex-shrink: 0;
  }

  .palette-title {
    font-size: 10px;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 2px;
    padding-left: 2px;
  }

  .palette-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 7px 4px;
    border-radius: 8px;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.15s;
    font-size: 10px;
    color: #6b7280;
  }

  .palette-item:hover {
    background: #dbeafe;
    cursor: pointer;
  }
  .palette-item.selected {
    background: #dbeafe;
    border-color: #2563eb;
    color: #60a5fa;
  }
  .palette-group { font-weight: 600; }
  .palette-group .group-chevron { font-size: 10px; opacity: 0.5; }
  .palette-group-label { display: flex; align-items: center; gap: 4px; font-size: 12px; }
  .palette-sub { padding-left: 20px !important; background: #f8fafc; }
  .palette-sub:hover { background: #dbeafe; }
  .palette-draggable { cursor: grab; }
  .palette-draggable:active { cursor: grabbing; }
  .palette-dragging { opacity: 0.5; }
  #cy.drag-over { outline: 2px dashed #2563eb; outline-offset: -4px; background: rgba(37,99,235,0.03); }

  .palette-icon {
    font-size: 22px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* === Canvas === */
  .canvas-wrap {
    flex: 1;
    min-height: 0;
    position: relative;
    overflow: hidden;
    background: #f1f5f9;
    background-image:
      radial-gradient(circle, #cbd5e1 1px, transparent 1px);
    background-size: 24px 24px;
    background-position: 0 0;
  }
  .canvas-wrap.grid-on {
    background: #f1f5f9;
    background-image:
      linear-gradient(#cbd5e1 1px, transparent 1px),
      linear-gradient(90deg, #cbd5e1 1px, transparent 1px);
    background-size: 48px 48px;
  }

  #cy {
    width: 100%;
    height: 100%;
  }

  /* === Mode badge === */
  .mode-badge {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    background: #3b82f6;
    color: #fff;
    padding: 5px 16px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
    z-index: 5;
    display: none;
    pointer-events: none;
    box-shadow: 0 2px 8px rgba(59,130,246,0.4);
  }

  .mode-badge.visible { display: block; }

  /* === Properties Panel === */
  .props-panel {
    width: 230px;
    background: #ffffff;
    border-left: 1px solid #e5e7eb;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    overflow: hidden;
  }
  .props-section { display: flex; flex-direction: column; overflow: hidden; }
  .props-main { flex: 1; overflow-y: auto; overflow-x: hidden; }
  .props-log { border-top: 2px solid #e5e7eb; height: 220px; flex-shrink: 0; }
  .props-log-header {
    padding: 8px 12px 6px;
    font-size: 10px;
    font-weight: 600;
    color: #2563eb;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid #e5e7eb;
    flex-shrink: 0;
  }
  .props-log-filters { display: flex; gap: 4px; }
  .props-log-filter {
    padding: 2px 8px; border-radius: 10px; font-size: 10px; cursor: pointer;
    border: 1px solid #d1d5db; color: #6b7280; background: #fff; transition: all 0.15s;
  }
  .props-log-filter.active { background: #2563eb; color: #fff; border-color: #2563eb; }
  .props-log-filter:hover:not(.active) { background: #f1f5f9; }
  .props-log-list { flex: 1; overflow-y: auto; padding: 6px 0; }
  .props-log-item {
    padding: 4px 12px; font-size: 11px; color: #374151;
    display: flex; align-items: flex-start; gap: 6px;
    border-bottom: 1px solid #f9fafb;
  }
  .props-log-item:last-child { border-bottom: none; }
  .props-log-item .log-icon { flex-shrink: 0; margin-top: 1px; font-size: 12px; }
  .props-log-item .log-text { flex: 1; line-height: 1.4; }
  .props-log-item .log-time { flex-shrink: 0; font-size: 10px; color: #9ca3af; margin-top: 1px; }
  .props-log-item.ai .log-icon { color: #a78bfa; }
  .props-log-item.human .log-icon { color: #10b981; }
  .props-log-empty { padding: 20px 12px; text-align: center; color: #9ca3af; font-size: 12px; }
  .props-log-clear { padding: 3px 10px; font-size: 10px; background: #fee2e2; color: #ef4444; border: none; border-radius: 6px; cursor: pointer; flex-shrink: 0; }
  .props-log-clear:hover { background: #fecaca; }

  .props-header {
    padding: 12px 14px 10px;
    font-size: 11px;
    font-weight: 600;
    color: #2563eb;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    border-bottom: 1px solid #e5e7eb;
  }

  .props-empty {
    padding: 24px 14px;
    color: #9ca3af;
    font-size: 12px;
    text-align: center;
    line-height: 1.8;
  }

  .prop-group {
    padding: 9px 14px;
    border-bottom: 1px solid #e5e7eb;
  }

  .prop-label {
    font-size: 10px;
    color: #6b7280;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .prop-input {
    width: 100%;
    background: #f3f4f6;
    border: 1px solid #374151;
    color: #1f2937;
    border-radius: 5px;
    padding: 5px 8px;
    font-size: 12px;
    outline: none;
    transition: border-color 0.15s;
  }

  .prop-input:focus { border-color: #2563eb; }

  /* === Context menu === */
  .ctx-menu {
    position: fixed;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 4px 0;
    z-index: 100;
    display: none;
    min-width: 160px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.12);
  }

  .ctx-menu.visible { display: block; }

  .ctx-item {
    padding: 8px 16px;
    font-size: 13px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    color: #374151;
  }

  .ctx-item:hover { background: #f3f4f6; }
  .ctx-item.danger { color: #ef4444; }
  .ctx-item.danger:hover { background: #fef2f2; }

  /* === Toast === */
  .toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(60px);
    background: #3b82f6;
    color: #ffffff;
    padding: 9px 22px;
    border-radius: 8px;
    font-size: 13px;
    z-index: 200;
    transition: transform 0.3s ease, opacity 0.3s ease;
    pointer-events: none;
    opacity: 0;
  }

  .toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  /* === Hint bar === */
  .hint-bar { color: #9ca3af; 
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 11px;
    color: #374151;
    z-index: 5;
    pointer-events: none;
    white-space: nowrap;
  }

  /* === Form Generation Modal === */
  #formGenModal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 400;
    background: rgba(0,0,0,0.7);
    align-items: center;
    justify-content: center;
  }
  #formGenModal.open { display: flex; }
  .form-gen-wrap {
    background: #fff;
    border-radius: 14px;
    width: min(900px, 95vw);
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    overflow: hidden;
  }
  .form-gen-header {
    padding: 16px 20px;
    background: #2563eb;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .form-gen-header h3 { margin: 0; font-size: 16px; font-weight: 600; flex: 1; }
  .form-gen-header .close-btn {
    background: rgba(255,255,255,0.2);
    border: none;
    color: #fff;
    font-size: 20px;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    cursor: pointer;
    line-height: 1;
  }
  .form-gen-header .close-btn:hover { background: rgba(255,255,255,0.3); }
  .form-gen-tabs {
    display: flex;
    background: #f1f5f9;
    border-bottom: 1px solid #e5e7eb;
    flex-shrink: 0;
  }
  .form-gen-tab {
    padding: 10px 20px;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 13px;
    color: #6b7280;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
  }
  .form-gen-tab.active { color: #2563eb; border-bottom-color: #2563eb; font-weight: 600; }
  .form-gen-body { flex: 1; overflow-y: auto; padding: 16px 20px; }
  .form-gen-tab-content { display: none; }
  .form-gen-tab-content.active { display: block; }
  .form-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .form-table th { background: #f8fafc; padding: 8px 10px; text-align: left; font-weight: 600; color: #374151; border-bottom: 2px solid #e5e7eb; white-space: nowrap; }
  .form-table td { padding: 6px 8px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
  .form-table tr:hover td { background: #f8fafc; }
  .form-table input, .form-table select {
    width: 100%; padding: 6px 8px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 13px; background: #fff; color: #1f2937; box-sizing: border-box;
  }
  .form-table input:focus, .form-table select:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 2px rgba(37,99,235,0.15); }
  .form-table .del-btn { background: #fee2e2; color: #ef4444; border: none; border-radius: 6px; padding: 4px 10px; cursor: pointer; font-size: 13px; width: 100%; }
  .form-table .del-btn:hover { background: #fecaca; }
  .add-row-btn { margin-top: 10px; background: #eff6ff; color: #2563eb; border: 1px dashed #2563eb; border-radius: 8px; padding: 8px 16px; cursor: pointer; font-size: 13px; width: 100%; }
  .add-row-btn:hover { background: #dbeafe; }
  .align-menu-item {
    padding: 8px 14px;
    font-size: 13px;
    color: #374151;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background 0.15s;
  }
  .align-menu-item:hover { background: #eff6ff; color: #2563eb; }
  .form-gen-footer { padding: 14px 20px; background: #f8fafc; border-top: 1px solid #e5e7eb; display: flex; align-items: flex-start; gap: 14px; flex-shrink: 0; }
  .form-gen-footer .ai-toggle { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #374151; flex-shrink: 0; margin-top: 20px; }
  .form-gen-footer .ai-toggle input[type="checkbox"] { width: 16px; height: 16px; cursor: pointer; }
  .form-gen-remarks { flex: 1; }
  .form-gen-remarks label { font-size: 13px; color: #374151; display: block; margin-bottom: 4px; font-weight: 500; }
  .form-gen-remarks textarea { width: 100%; padding: 8px 10px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 13px; resize: vertical; min-height: 60px; box-sizing: border-box; font-family: inherit; }
  .form-gen-remarks textarea:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 2px rgba(37,99,235,0.15); }
  .form-gen-actions { display: flex; flex-direction: column; gap: 6px; flex-shrink: 0; }
  .form-gen-actions button { padding: 8px 18px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; transition: background 0.2s; }
  .form-gen-actions .btn-gen { background: #2563eb; color: #fff; }
  .form-gen-actions .btn-gen:hover { background: #1d4ed8; }
  .form-gen-actions .btn-gen:disabled { background: #9ca3af; cursor: not-allowed; }
  .form-gen-actions .btn-close { background: #fff; color: #6b7280; border: 1px solid #d1d5db; }
  .form-gen-actions .btn-close:hover { background: #f3f4f6; }

  /* === Scrollbar === */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: #ffffff; }
  ::-webkit-scrollbar-thumb { background: #f3f4f6; border-radius: 3px; }

  /* === Terminal Modal === */
  #termModal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0,0,0,0.85);
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0;
  }
  #termModal.open { display: flex; }

  .term-header {
    width: min(900px, 96vw);
    background: #0d1117;
    border: 1px solid #30363d;
    border-bottom: none;
    border-radius: 10px 10px 0 0;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .term-dots { display: flex; gap: 6px; }
  .term-dot { width:12px;height:12px;border-radius:50%; }
    border-bottom: 1px solid #f3f4f6;
    transition: background 0.15s;
    border-radius: 6px;
    margin: 2px 6px;
  }
  .proj-item:hover { background: #f0f7ff; }
  .proj-item:active { background: #dbeafe; transform: scale(0.99); }
  .proj-item.active { background: #eff6ff; border: 1px solid #bfdbfe; }
  .proj-item-info { flex: 1; }
  .proj-item-name { font-size: 14px; font-weight: 600; color: #1f2937; }
  .proj-item-meta { font-size: 11px; color: #9ca3af; margin-top: 2px; }
  .proj-item-del { background: none; border: none; color: #ef4444; font-size: 13px; cursor: pointer; padding: 4px 8px; border-radius: 4px; opacity: 0; transition: opacity 0.12s; }
  .proj-item:hover .proj-item-del { opacity: 1; }
  .proj-item-del:hover { background: #fee2e2; }
  .proj-empty { text-align: center; padding: 32px 20px; color: #9ca3af; font-size: 13px; }
  #projectModal { animation: fadeIn 0.18s ease; }
  #projectList .proj-item { animation: slideIn 0.15s ease; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes slideIn { from { opacity: 0; transform: translateX(-8px); } to { opacity: 1; transform: translateX(0); } }


  .login-box {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    width: 380px;
    padding: 24px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  }
  .login-title {
    font-size: 16px;
    font-weight: 600;
    color: #1f2937;
    margin-bottom: 6px;
  }
  .login-sub {
    font-size: 12px;
    color: #6b7280;
    margin-bottom: 20px;
  }
  .login-row {
    margin-bottom: 14px;
  }
  .login-label {
    display: block;
    font-size: 11px;
    color: #6b7280;
    margin-bottom: 5px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .login-input {
    width: 100%;
    background: #f3f4f6;
    border: 1px solid #374151;
    color: #1f2937;
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 13px;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.15s;
  }
  .login-input:focus { border-color: #2563eb; }
  .login-row-flex { display: flex; gap: 10px; }
  .login-row-flex .login-row { flex: 1; }
  .login-btns { display: flex; gap: 10px; margin-top: 20px; }
  .btn-connect {
    flex: 1;
    background: #3b82f6;
    border: none;
    color: #fff;
    padding: 9px;
    border-radius: 8px;
    font-size: 13px;
    cursor: pointer;
    font-weight: 500;
  }
  .btn-connect:hover { background: #2563eb; }
  #btn-save { background: #10b981; color: #fff; border: none; border-radius: 6px; padding: 7px 14px; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 4px; }
  #btn-save:hover { background: #059669; }
  #btn-save:active { transform: scale(0.97); }
  .btn-cancel {
    background: #f3f4f6;
    border: 1px solid #374151;
    color: #6b7280;
    padding: 9px 16px;
    border-radius: 8px;
    font-size: 13px;
    cursor: pointer;
  }
  .btn-cancel:hover { background: #374151; color: #fff; }
  .login-error { color: #ef4444; font-size: 12px; margin-top: 8px; display: none; }
  .login-note { font-size: 11px; color: #9ca3af; margin-top: 12px; line-height: 1.6; }

  /* === Chat Panel === */
  #chatToggle {
    position: fixed;
    bottom: 20px;
    left: 20px;
    right: auto;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #2563eb;
    border: none;
    color: #fff;
    font-size: 22px;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(37,99,235,0.4);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s;
  }
  #chatToggle:hover { transform: scale(1.1); }
  #chatToggle .badge {
    position: absolute;
    top: -4px;
    right: -4px;
    background: #ef4444;
    color: #fff;
    font-size: 11px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: none;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }

  #chatPanel {
    position: fixed;
    top: 0;
    left: -400px;
    width: 380px;
    height: 100vh;
    background: #fff;
    border-right: 1px solid #e5e7eb;
    display: flex;
    flex-direction: column;
    z-index: 200;
    transition: left 0.3s ease;
    box-shadow: 4px 0 24px rgba(0,0,0,0.1);
  }
  #chatPanel.open { left: 0; }
  #chatResizeV {
    position: absolute;
    top: 0;
    right: -4px;
    width: 8px;
    height: 100%;
    cursor: ew-resize;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #chatResizeV::after {
    content: '';
    width: 4px;
    height: 40px;
    border-radius: 2px;
    background: #d1d5db;
    transition: background 0.2s;
  }
  #chatResizeV:hover::after { background: #9ca3af; }
  #chatResizeH {
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 8px;
    cursor: ns-resize;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #chatResizeH::after {
    content: '';
    width: 40px;
    height: 4px;
    border-radius: 2px;
    background: #d1d5db;
    transition: background 0.2s;
  }
  #chatResizeH:hover::after { background: #9ca3af; }

  .chat-header {
    padding: 8px 16px 10px;
    background: #2563eb;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    border-radius: 16px 0 0 0;
    cursor: move;
    user-select: none;
    position: relative;
  }
  .chat-header::before {
    content: '⋮⋮';
    font-size: 10px;
    letter-spacing: 1px;
    opacity: 0.6;
    flex-shrink: 0;
  }
  .chat-header .title { flex: 1; font-weight: 600; font-size: 15px; }
  .chat-close {
    background: rgba(255,255,255,0.2);
    border: none;
    color: #fff;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .chat-close:hover { background: rgba(255,255,255,0.3); }
  .chat-btn-sm {
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff;
    padding: 3px 8px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 11px;
    white-space: nowrap;
  }
  .chat-btn-sm:hover { background: rgba(255,255,255,0.25); }
  .chat-memories {
    flex: 1;
    overflow-y: auto;
    padding: 12px;
  }
  .chat-memories .mem-item {
    padding: 8px 10px;
    border-radius: 6px;
    margin-bottom: 6px;
    cursor: pointer;
    font-size: 12px;
    border: 1px solid #e5e7eb;
    background: #f9fafb;
  }
  .chat-memories .mem-item:hover { background: #eff6ff; border-color: #3b82f6; }
  .chat-memories .mem-item .mem-date { font-size: 11px; color: #6b7280; margin-top: 2px; }
  .chat-memories .mem-item .mem-del {
    float: right;
    color: #ef4444;
    font-size: 14px;
    cursor: pointer;
    padding: 0 4px;
  }
  .chat-confirm-modal {
    display: none;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: #fff;
    border-radius: 12px;
    padding: 20px 24px;
    width: 240px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    z-index: 300;
    text-align: center;
  }
  .chat-confirm-modal.show { display: block; }
  .chat-confirm-modal .msg { font-size: 13px; color: #374151; margin-bottom: 16px; line-height: 1.5; }
  .chat-confirm-modal .btns { display: flex; gap: 10px; justify-content: center; }
  .chat-confirm-modal .btn-cancel {
    padding: 6px 16px;
    border-radius: 6px;
    border: 1px solid #d1d5db;
    background: #fff;
    color: #374151;
    cursor: pointer;
    font-size: 12px;
  }
  .chat-confirm-modal .btn-cancel:hover { background: #f3f4f6; }
  .chat-confirm-modal .btn-ok {
    padding: 6px 16px;
    border-radius: 6px;
    border: none;
    background: #ef4444;
    color: #fff;
    cursor: pointer;
    font-size: 12px;
  }
  .chat-confirm-modal .btn-ok:hover { background: #dc2626; }
  #chatConfirmOverlay {
    display: none;
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.3);
    z-index: 299;
    border-radius: 0 12px 0 0;
  }
  #chatConfirmOverlay.show { display: block; }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    padding-bottom: 40px;  /* space for scroll-to-bottom button */
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
  }
  .chat-msg {
    max-width: 85%;
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 13px;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
    color: #111827;
  }
  .chat-msg.user {
    align-self: flex-end;
    background: #2563eb;
    color: #ffffff;
    border-bottom-right-radius: 4px;
  }
  .chat-msg.ai {
    align-self: flex-start;
    background: #f3f4f6;
    color: #111827;
    border-bottom-left-radius: 4px;
  }
  .chat-msg .ts { font-size: 10px; opacity: 0.6; margin-top: 4px; display: block; text-align: right; color: #9ca3af; }
  .chat-msg.ai .ts { text-align: left; color: #9ca3af; }
  .chat-msg-label {
    font-size: 11px;
    font-weight: 700;
    margin-bottom: 3px;
    opacity: 0.7;
  }
  .chat-msg.user .chat-msg-label { text-align: right; color: #bfdbfe; }
  .chat-msg.ai .chat-msg-label { color: #6b7280; }
  .chat-typing {
    display: inline-flex;
    gap: 4px;
    align-items: center;
    padding: 2px 0;
  }
  .chat-typing span {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #9ca3af;
    animation: chat-typing-bounce 1.2s infinite ease-in-out;
  }
  .chat-typing span:nth-child(2) { animation-delay: 0.2s; }
  .chat-typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes chat-typing-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
    30% { transform: translateY(-6px); opacity: 1; }
  }

  .chat-session-list {
    width: 56px !important;
    flex: 0 0 56px !important;
    min-width: 56px !important;
    max-width: 56px !important;
    flex-shrink: 0;
    border-right: 1px solid #e5e7eb;
    overflow: hidden;
    background: #f9fafb;
    transition: width 0.2s ease;
  }
  .chat-session-list .session-item-wrap {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    padding: 4px 3px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .chat-session-item {
    padding: 5px 3px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    color: #374151;
    position: relative;
    text-align: center;
    line-height: 1.25;
  }
  .chat-session-item:hover { background: #e5e7eb; }
  .chat-session-item.active { background: #dbeafe; color: #1d4ed8; }
  .chat-session-item .sname { width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block; text-align: center; font-size: 10px; }
  .chat-session-item .sdel { display: none; color: #ef4444; font-size: 13px; cursor: pointer; padding: 0 2px; flex-shrink: 0; position: absolute; top: 1px; right: 1px; background: #fff; border-radius: 3px; }
  .chat-session-item:hover .sdel { display: block; }
  .chat-session-new {
    width: 100%;
    padding: 5px 3px;
    border-radius: 6px;
    border: 1px dashed #d1d5db;
    background: transparent;
    color: #6b7280;
    font-size: 10px;
    cursor: pointer;
    text-align: center;
    margin-bottom: 4px;
  }
  .chat-session-new:hover { border-color: #3b82f6; color: #3b82f6; background: #eff6ff; }
  .chat-session-date { font-size: 9px; color: #9ca3af; display: block; text-align: center; line-height: 1.1; width: 100%; }

  .chat-empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #6b7280;
    font-size: 13px;
    gap: 8px;
    padding: 20px;
    text-align: center;
  }
  .chat-empty .big { font-size: 36px; }

  .chat-input-area {
    padding: 12px;
    border-top: 1px solid #e5e7eb;
    display: flex;
    gap: 8px;
    flex-shrink: 0;
    background: #fff;
  }
  .chat-input {
    flex: 1;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 20px;
    padding: 10px 14px;
    font-size: 13px;
    resize: none;
    outline: none;
    font-family: inherit;
    max-height: 100px;
    overflow-y: auto;
    color: #111827;
  }
  .chat-input:focus { border-color: #2563eb; }
  .chat-send {
    width: 40px;
    height: 40px;
    background: #2563eb;
    border: none;
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
    align-self: flex-end;
  }
  .chat-send:hover { background: #1d4ed8; }
  .chat-send:disabled { background: #9ca3af; cursor: not-allowed; }
  .chat-ops-card {
    background: #f0f9ff;
    border: 1px solid #bfdbfe;
    border-radius: 8px;
    padding: 10px 14px;
    margin-top: 6px;
    font-size: 13px;
  }
  .chat-ops-card .ops-title {
    font-weight: 600;
    color: #1e40af;
    margin-bottom: 6px;
  }
  .chat-ops-card .op-item {
    background: #fff;
    border: 1px solid #dbeafe;
    border-radius: 6px;
    padding: 6px 10px;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 6px;
    color: #374151;
    font-size: 12px;
  }
  .chat-ops-card .op-item .op-icon { font-size: 14px; }
  .chat-ops-execute {
    width: 100%;
    margin-top: 8px;
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .chat-ops-execute:hover { background: #1d4ed8; }
  .chat-ops-execute:disabled { background: #9ca3af; cursor: not-allowed; }
  .chat-ops-dismiss {
    width: 100%;
    margin-top: 4px;
    background: none;
    border: 1px solid #dbeafe;
    color: #6b7280;
    border-radius: 6px;
    padding: 5px;
    font-size: 12px;
    cursor: pointer;
  }
  .chat-ops-dismiss:hover { background: #f3f4f6; }
  .chat-with-topo {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: #374151;
    padding: 4px 12px 0;
  }
  .chat-with-topo input { accent-color: #2563eb; }

  /* === Edge Port Popup === */
  #edgePortPopup {
    display: none;
    position: fixed;
    z-index: 150;
    background: #ffffff;
    border: 1px solid #d1d5db;
    border-radius: 10px;
    padding: 14px;
    width: 280px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.1);
    font-size: 13px;
  }
  #edgePortPopup.show { display: block; }
  .edge-popup-title {
    color: #1f2937;
    font-weight: 600;
    margin-bottom: 12px;
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .edge-popup-row {
    margin-bottom: 10px;
  }
  .edge-popup-label {
    font-size: 11px;
    color: #374151;
    margin-bottom: 4px;
  }
  .edge-popup-input {
    width: 100%;
    background: #ffffff;
    border: 1px solid #374151;
    color: #111827;
    border-radius: 5px;
    padding: 6px 10px;
    font-size: 12px;
    outline: none;
    box-sizing: border-box;
  }
  .edge-popup-input:focus { border-color: #2563eb; }
  .edge-popup-btns {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  .edge-popup-btns button {
    flex: 1;
    padding: 7px;
    border-radius: 6px;
    font-size: 12px;
    cursor: pointer;
    border: none;
    font-weight: 500;
  }
  .btn-confirm {
    background: #3b82f6;
    color: #fff;
  }
  .btn-confirm:hover { background: #2563eb; }
  .btn-cancel-popup {
    background: #374151;
    color: #6b7280;
  }
  .btn-cancel-popup:hover { background: #4b5563; color: #fff; }

  /* === Edit Dropdown === */
  .edit-menu-item {
    padding: 8px 14px;
    font-size: 13px;
    color: #374151;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background 0.15s;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
  }
  .edit-menu-item:hover { background: #eff6ff; color: #2563eb; }
  .edit-menu-divider { height: 1px; background: #e5e7eb; margin: 4px 0; }
  .edit-submenu {
    display: none;
    position: absolute;
    left: 100%;
    top: 0;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 6px 0;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    min-width: 140px;
    z-index: 61;
  }
  .edit-menu-item:hover .edit-submenu { display: block; }
  .edit-submenu-item {
    padding: 7px 14px;
    font-size: 13px;
    color: #374151;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background 0.15s;
  }
  .edit-submenu-item:hover { background: #eff6ff; color: #2563eb; }

  /* === Resize Handles Overlay === */
  #resizeOverlay {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 30;
    overflow: hidden;
  }
  .resize-handle {
    pointer-events: auto !important;
    position: absolute;
    width: 10px;
    height: 10px;
    background: #fff;
    border: 2px solid #2563eb;
    border-radius: 2px;
    cursor: nwse-resize;
    box-sizing: border-box;
    z-index: 31;
  }

    .resize-handle.tl { cursor: nwse-resize; }
  .resize-handle.tr { cursor: nesw-resize; }
  .resize-handle.bl { cursor: nesw-resize; }
  .resize-handle.br { cursor: nwse-resize; }
  .resize-handle.tm { cursor: ns-resize; top: -5px; left: 50%; margin-left: -5px; }
  .resize-handle.bm { cursor: ns-resize; bottom: -5px; left: 50%; margin-left: -5px; }
  .resize-handle.lm { cursor: ew-resize; left: -5px; top: 50%; margin-top: -5px; }
  .resize-handle.rm { cursor: ew-resize; right: -5px; top: 50%; margin-top: -5px; }
  .resize-handle:hover { background: #2563eb; }


  /* === Shape color swatches === */
  .shape-color-swatch {
    display: inline-block;
    width: 18px; height: 18px;
    border-radius: 50%;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.15s;
  }
  .shape-color-swatch.selected { border-color: #2563eb; }
</style>
</head>
<body>


<!-- Header -->
<header>
  <div class="logo"><i class="fa-solid fa-diagram-project"></i> NetOps</div>
  <div class="toolbar">
    <button id="btn-projects" onclick="window.open('/projects.html', '_blank')"><i class="fa-solid fa-folder-tree"></i> 选择项目</button>
    <button id="btn-current-proj" disabled style="background:#f3f4f6;color:#9ca3af;border:1px solid #e5e7eb;cursor:default;"><i class="fa-solid fa-folder-open"></i> 未选择项目</button>
    <button id="btn-save" onclick="saveProject()"><i class="fa-solid fa-cloud-arrow-up"></i> 保存</button>
    <button id="btn-select" class="active" onclick="setMode('select')"><i class="fa-solid fa-mouse-pointer"></i> 选择</button>
    <button id="btn-connect" onclick="setMode('connect')"><i class="fa-solid fa-link"></i> 连线</button>
    <button id="btn-grid" onclick="toggleGrid()"><i class="fa-solid fa-th"></i> 网格</button>
    <div style="position:relative;">
      <button id="btn-align" onclick="toggleAlignMenu()"><i class="fa-solid fa-th-large"></i> 对齐 ▾</button>
      <div id="alignMenu" style="display:none; position:absolute; top:calc(100% + 4px); left:0; background:#fff; border:1px solid #e5e7eb; border-radius:8px; padding:6px 0; box-shadow:0 4px 16px rgba(0,0,0,0.12); z-index:60; min-width:160px;">
        <div class="align-menu-item" onclick="doAlign('left')"><i class="fa-solid fa-align-left"></i> 左对齐</div>
        <div class="align-menu-item" onclick="doAlign('hcenter')"><i class="fa-solid fa-grip-lines"></i> 水平居中</div>
        <div class="align-menu-item" onclick="doAlign('right')"><i class="fa-solid fa-align-right"></i> 右对齐</div>
        <div style="height:1px;background:#e5e7eb;margin:4px 0;"></div>
        <div class="align-menu-item" onclick="doAlign('top')"><i class="fa-solid fa-align-start"></i> 顶对齐</div>
        <div class="align-menu-item" onclick="doAlign('vcenter')"><i class="fa-solid fa-grip-lines-vertical"></i> 垂直居中</div>
        <div class="align-menu-item" onclick="doAlign('bottom')"><i class="fa-solid fa-align-end"></i> 底对齐</div>
        <div style="height:1px;background:#e5e7eb;margin:4px 0;"></div>
        <div class="align-menu-item" onclick="doAlign('grid')"><i class="fa-solid fa-table-cells"></i> 网格对齐</div>
      </div>
    </div>
    <div style="position:relative;">
      <button id="btn-edit" onclick="toggleEditMenu()"><i class="fa-solid fa-pen"></i> 编辑 ▾</button>
      <div id="editMenu" style="display:none; position:absolute; top:calc(100% + 4px); left:0; background:#fff; border:1px solid #e5e7eb; border-radius:8px; padding:6px 0; box-shadow:0 4px 16px rgba(0,0,0,0.12); z-index:60; min-width:160px;">
        <div style="position:relative;">
          <button class="edit-menu-item" onclick="startPlaceShape('ellipse')">
            <i class="fa-regular fa-circle" style="font-size:14px"></i> 椭圆
            <span style="margin-left:auto;color:#9ca3af;font-size:11px;">▸</span>
            <div class="edit-submenu">
              <div class="edit-submenu-item" onclick="event.stopPropagation(); startPlaceShape('ellipse','#ef4444')">🔴 红色</div>
              <div class="edit-submenu-item" onclick="event.stopPropagation(); startPlaceShape('ellipse','#f59e0b')">🟡 黄色</div>
              <div class="edit-submenu-item" onclick="event.stopPropagation(); startPlaceShape('ellipse','#10b981')">🟢 绿色</div>
            </div>
          </button>
        </div>
        <div style="position:relative;">
          <button class="edit-menu-item" onclick="startPlaceShape('rectangle')">
            <i class="fa-regular fa-square" style="font-size:14px"></i> 方形
            <span style="margin-left:auto;color:#9ca3af;font-size:11px;">▸</span>
            <div class="edit-submenu">
              <div class="edit-submenu-item" onclick="event.stopPropagation(); startPlaceShape('rectangle','#ef4444')">🔴 红色</div>
              <div class="edit-submenu-item" onclick="event.stopPropagation(); startPlaceShape('rectangle','#f59e0b')">🟡 黄色</div>
              <div class="edit-submenu-item" onclick="event.stopPropagation(); startPlaceShape('rectangle','#10b981')">🟢 绿色</div>
            </div>
          </button>
        </div>
        <div class="edit-menu-divider"></div>
        <button class="edit-menu-item" onclick="openTextBoxDialog()">
          <i class="fa-regular fa-square" style="font-size:14px"></i> 文本框
        </button>
      </div>
    </div>
    <button class="danger" onclick="clearAll()"><i class="fa-solid fa-trash-alt"></i> 清空</button>
    <button onclick="syncToAI()"><i class="fa-solid fa-robot"></i> AI连接同步</button>
    <button onclick="undoTopo && undoTopo()" title="Ctrl+Z 撤销"><i class="fa-solid fa-rotate-left"></i> 撤销</button>
    <button onclick="refreshCanvas()" title="刷新画布视图"><i class="fa-solid fa-arrows-rotate"></i> 刷新</button>

    <button id="btn-canvas-lock" onclick="toggleCanvasLock()" title="锁定画布" style="background:#fef3c7;color:#92400e;border:1px solid #f59e0b;"><i class="fa-solid fa-lock"></i> 已锁定</button>
  </div>
</header>

  <div class="main-row" style="display:flex;flex:1;overflow:hidden;min-height:0;">


<!-- Main -->
<div class="main">

  <!-- Device Palette -->
  <div class="palette" id="devicePalette">
    <div class="palette-title">设备</div>

    <div class="palette-item palette-group" data-action="toggle-group">
      <div class="palette-icon" id="icon-router"></div>
      <div class="palette-group-label">
        路由器 <span class="group-chevron">▾</span>
      </div>
    </div>
    <div class="palette-subitems" style="display:none">
      <div class="palette-item palette-sub" data-type="router" data-action="add-device" data-device="router">
        <div class="palette-icon" id="icon-router0"></div>
        <div>路由器</div>
      </div>
      <div class="palette-item palette-sub" data-type="router_advanced" data-action="add-device" data-device="router_advanced">
        <div class="palette-icon" id="icon-router_advanced"></div>
        <div>高级路由器</div>
      </div>
      <div class="palette-item palette-sub" data-type="router_core" data-action="add-device" data-device="router_core">
        <div class="palette-icon" id="icon-router_core"></div>
        <div>核心路由器</div>
      </div>
    </div>

    <div class="palette-item palette-group" data-action="toggle-group">
      <div class="palette-icon" id="icon-switch"></div>
      <div class="palette-group-label">
        交换机 <span class="group-chevron">▾</span>
      </div>
    </div>
    <div class="palette-subitems" style="display:none">
      <div class="palette-item palette-sub" data-type="switch" data-action="add-device" data-device="switch">
        <div class="palette-icon" id="icon-switch0"></div>
        <div>交换机</div>
      </div>
      <div class="palette-item palette-sub" data-type="switch_core" data-action="add-device" data-device="switch_core">
        <div class="palette-icon" id="icon-switch_core"></div>
        <div>核心交换机</div>
      </div>
      <div class="palette-item palette-sub" data-type="switch_access" data-action="add-device" data-device="switch_access">
        <div class="palette-icon" id="icon-switch_access"></div>
        <div>接入交换机</div>
      </div>
    </div>

    <div class="palette-item palette-draggable" data-type="firewall" data-action="add-device" data-device="firewall">
      <div class="palette-icon" id="icon-firewall"></div>
      <div>防火墙</div>
    </div>

    <div class="palette-item palette-draggable" data-type="server" data-action="add-device" data-device="server">
      <div class="palette-icon" id="icon-server"></div>
      <div>服务器</div>
    </div>

    <div class="palette-item palette-draggable" data-type="pc" data-action="add-device" data-device="pc">
      <div class="palette-icon" id="icon-pc"></div>
      <div>PC</div>
    </div>

    <div class="palette-item palette-draggable" data-type="cloud" data-action="add-device" data-device="cloud">
      <div class="palette-icon" id="icon-cloud"></div>
      <div>云</div>
    </div>
  </div>

  <!-- Canvas -->
  <div class="canvas-wrap" id="canvasWrap">
    <div id="cyCanvas" tabindex="0" style="outline:none;"></div>
    <div id="selBox" style="position:absolute;border:1.5px solid #2563eb;background:rgba(37,99,235,0.1);border-radius:3px;pointer-events:none;display:none;z-index:10;"></div>
    <div class="mode-badge" id="modeBadge"><span class="mode-dot" style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#fff;margin-right:6px;vertical-align:middle;"></span><span class="mode-text">选择模式</span></div>
    <div class="hint-bar">
      <i class="fa-solid fa-circle-info" style="color:#374151;margin-right:4px"></i>
      双击画布放置设备 · 拖拽移动设备 · 双击设备编辑名称
    </div>
    <div id="resizeOverlay">
      <div class="resize-handle tl" id="rh-tl" data-handle="tl"></div>
      <div class="resize-handle tr" id="rh-tr" data-handle="tr"></div>
      <div class="resize-handle bl" id="rh-bl" data-handle="bl"></div>
      <div class="resize-handle br" id="rh-br" data-handle="br"></div>
      <div class="resize-handle tm" id="rh-tm" data-handle="tm"></div>
      <div class="resize-handle bm" id="rh-bm" data-handle="bm"></div>
      <div class="resize-handle lm" id="rh-lm" data-handle="lm"></div>
      <div class="resize-handle rm" id="rh-rm" data-handle="rm"></div>
    </div>

</div>

  <!-- TextBox Dialog -->
  <div id="textBoxDialog" style="display:none;position:fixed;inset:0;z-index:500;background:rgba(0,0,0,0.6);align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:12px;padding:24px;width:min(420px,90vw);box-shadow:0 20px 60px rgba(0,0,0,0.3);">
      <div style="font-size:16px;font-weight:600;margin-bottom:16px;">📝 添加文本框</div>
      <div style="margin-bottom:12px;">
        <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">文字内容</div>
        <textarea id="tbContent" rows="3" placeholder="输入文字..." style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;resize:vertical;box-sizing:border-box;font-family:inherit;"></textarea>
      </div>
      <div style="display:flex;gap:12px;margin-bottom:16px;">
        <div style="flex:1;">
          <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">背景色</div>
          <div style="display:flex;gap:6px;align-items:center;">
            <input type="color" id="tbBgColor" value="#ffffff" style="width:36px;height:28px;border:1px solid #d1d5db;border-radius:6px;cursor:pointer;padding:0;">
            <span id="tbBgLabel" style="font-size:11px;color:#9ca3af;">#ffffff</span>
            <span style="font-size:11px;color:#9ca3af;cursor:pointer;" onclick="document.getElementById('tbBgColor').value='#000000';document.getElementById('tbBgLabel').textContent='透明';">透明</span>
          </div>
        </div>
        <div style="flex:1;">
          <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">字体颜色</div>
          <div style="display:flex;gap:6px;align-items:center;">
            <input type="color" id="tbFgColor" value="#1f2937" style="width:36px;height:28px;border:1px solid #d1d5db;border-radius:6px;cursor:pointer;padding:0;">
            <span id="tbFgLabel" style="font-size:11px;color:#9ca3af;">#1f2937</span>
          </div>
        </div>
      </div>
      <div style="display:flex;gap:8px;justify-content:flex-end;">
        <button onclick="document.getElementById('textBoxDialog').style.display='none'" style="padding:8px 16px;border-radius:8px;border:1px solid #d1d5db;background:#fff;color:#6b7280;cursor:pointer;font-size:13px;">取消</button>
        <button onclick="confirmTextBox()" style="padding:8px 16px;border-radius:8px;border:none;background:#2563eb;color:#fff;cursor:pointer;font-size:13px;font-weight:600;">确认放置</button>
      </div>
    </div>
  </div>

  <!-- Properties Panel -->
  <div id="propsPanel" class="props-panel">
    <div class="props-section props-main">
      <div class="props-header">属性</div>
      <div class="props-empty" id="propsEmpty">选中节点或连线<br>查看/编辑属性</div>
      <div id="propsContent" style="display:none"></div>
    </div>
    <div class="props-section props-log">
      <div class="props-log-header">
        <span>📋 变更记录</span>
        <div class="props-log-filters">
          <button class="props-log-filter active" data-filter="all" onclick="setLogFilter('all')">全部</button>
          <button class="props-log-filter" data-filter="ai" onclick="setLogFilter('ai')">🤖</button>
          <button class="props-log-filter" data-filter="human" onclick="setLogFilter('human')">👤</button>
          <button class="props-log-clear" onclick="clearOpLog()">清除</button>
        </div>
      </div>
      <div class="props-log-list" id="opLogList">
        <div class="props-log-empty">暂无变更记录</div>
      </div>
    </div>
  </div>

  </div><!-- end main-row -->


</div>

<!-- Context Menu -->
<div class="ctx-menu" id="ctxMenu">
  <div class="ctx-item" onclick="ctxEdit()"><i class="fa-solid fa-pen" style="width:16px"></i> 编辑属性</div>
  <div class="ctx-item" onclick="ctxDuplicate()"><i class="fa-solid fa-copy" style="width:16px"></i> 复制设备</div>
  <div class="ctx-item danger" id="ctxDeleteItem" onclick="ctxDelete()"><i class="fa-solid fa-trash-alt" style="width:16px"></i> 删除</div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<!-- Hidden file input -->
<input type="file" id="fileImport" accept=".json" style="display:none" onchange="handleFileImport(event)">

<!-- Project Manager Modal -->
<div id="projectModal" style="display:none; position:fixed; inset:0; z-index:300; background:rgba(0,0,0,0.7); align-items:center; justify-content:center;">
  <div style="background:#ffffff; border:1px solid #e5e7eb; border-radius:14px; width:min(500px,90vw); max-height:80vh; display:flex; flex-direction:column; box-shadow:0 4px 24px rgba(0,0,0,0.15);">
    <div style="padding:16px 20px; border-bottom:1px solid #e5e7eb; display:flex; align-items:center; justify-content:space-between;">
      <div style="font-size:16px; font-weight:700; color:#1f2937;">🗂️ 项目管理</div>
      <button onclick="closeProjectModal()" style="background:none; border:none; font-size:20px; cursor:pointer; color:#9ca3af; padding:4px; line-height:1;">&times;</button>
    </div>
    <div style="padding:16px 20px; border-bottom:1px solid #e5e7eb;">
      <div style="display:flex; gap:8px;">
        <input id="projNameInput" type="text" placeholder="输入新项目名称..." style="flex:1; border:1px solid #d1d5db; border-radius:6px; padding:8px 12px; font-size:13px; outline:none; box-sizing:border-box;" onkeydown="if(event.key==='Enter')createProject()">
        <button onclick="createProject()" style="background:#3b82f6; color:#fff; border:none; border-radius:6px; padding:8px 16px; font-size:13px; cursor:pointer; white-space:nowrap;">+ 新建</button>
      </div>
    </div>
    <div id="projectList" style="flex:1; overflow-y:auto; padding:8px 0;">
    </div>
  </div>
</div>

<!-- AI Analysis Modal -->
<div id="aiModal" style="
  display:none; position:fixed; inset:0; z-index:300;
  background:rgba(0,0,0,0.7); align-items:center; justify-content:center;
">
  <div style="
    background:#111827; border:1px solid #1f2937; border-radius:14px;
    width:min(680px,90vw); max-height:80vh; display:flex; flex-direction:column;
    box-shadow: 0 1px 6px rgba(0,0,0,0.08);
  ">
    <div style="padding:16px 20px; border-bottom:1px solid #1f2937; display:flex; align-items:center; gap:10px">
      <i class="fa-solid fa-brain" style="color:#6ee7b7;font-size:18px"></i>
      <span style="font-size:15px;font-weight:600;color:#e0e6f0">AI 拓扑分析</span>
      <div id="aiStatus" style="margin-left:auto;font-size:12px;color:#6b7280"></div>
      <button onclick="closeAIModal()" style="
        background:none;border:none;color:#6b7280;cursor:pointer;font-size:18px;padding:2px 6px;border-radius:4px
      " onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='#6b7280'">&times;</button>
    </div>
    <div id="aiResult" style="padding:20px; overflow-y:auto; font-size:13px; line-height:1.9; color:#d1d5db; white-space:pre-wrap; flex:1"></div>
  </div>
</div>

<!-- LLM 设置弹窗 -->
</div>

<!-- Chat Toggle Button -->
<button id="chatToggle" onclick="toggleChat()" title="AI 对话">
  <i class="fa-solid fa-comment-dots"></i>
  <span class="badge" id="chatBadge"></span>
</button>

<!-- Chat Panel -->
<div id="chatPanel">
  <div id="chatResizeV" onmousedown="startChatResizeV(event)"></div>
  <div id="chatResizeH" onmousedown="startChatResizeH(event)"></div>
  <div class="chat-header" onmousedown="startChatDrag(event)" ondblclick="resetChatPanelPos()" title="拖动移动面板 · 双击恢复默认位置">
    <i class="fa-solid fa-robot" style="font-size:18px"></i>
    <div class="title">AI 拓扑助手</div>
    <button class="chat-btn-sm" onclick="openFormGen()" title="表单生成拓扑" style="background:#1d4ed8;color:#fff;border-radius:6px;">📋 表单</button>
    <button class="chat-close" onclick="toggleChat()">×</button>
  </div>
  <div id="chatConfirmOverlay" onclick="hideChatConfirm()"></div>
  <div class="chat-confirm-modal" id="chatConfirmModal">
    <div class="msg" id="chatConfirmMsg"></div>
    <div class="btns">
      <button class="btn-cancel" onclick="hideChatConfirm()">取消</button>
      <button class="btn-ok" id="chatConfirmOk">确定</button>
    </div>
  </div>
  <div style="display:flex;flex:1;overflow:hidden;">
    <div class="chat-session-list" id="chatSessionList" style="width:56px;min-width:56px;max-width:56px;flex:0 0 56px;"><div class="session-item-wrap" id="chatSessionListWrap"></div></div>
    <div style="flex:1;display:flex;flex-direction:column;min-width:0;overflow:hidden;">
      <div class="chat-messages" id="chatMessages" style="position:relative;"><div id="scrollToBottomBtn" onclick="scrollChatToBottom()" style="display:none;position:absolute;bottom:10px;right:14px;background:#374151;color:#fff;padding:6px 12px;border-radius:16px;font-size:12px;cursor:pointer;z-index:5;box-shadow:0 2px 8px rgba(0,0,0,0.2);">↓ 最新消息</div>
        <div class="chat-empty" id="chatEmpty">
          <div class="big">🤖</div>
          <div>AI 助手已就绪</div>
          <div style="font-size:12px">发送拓扑+问题，我会分析并回复</div>
        </div>
      </div>
      <div style="padding:8px 10px;border-top:1px solid #e5e7eb;background:#fff;flex-shrink:0;">
        <div class="chat-with-topo">
          <input type="checkbox" id="chatWithTopo" checked>
          <label for="chatWithTopo">附带拓扑</label>
        </div>
        <div style="display:flex;gap:6px;margin-top:6px;">
          <textarea class="chat-input" id="chatInput" rows="2" placeholder="输入问题，或上传文档让AI读取..." style="flex:1;resize:none;" onkeydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault();sendChat()}"></textarea>
          <div style="display:flex;flex-direction:column;gap:4px;">
            <label class="chat-file-btn" title="上传文档（.txt/.md/.json）" style="cursor:pointer;padding:4px 8px;border-radius:6px;background:#f3f4f6;border:1px solid #d1d5db;font-size:12px;color:#6b7280;white-space:nowrap;text-align:center;">
              📎<input type="file" id="chatFileInput" accept=".txt,.md,.json,.log,.conf,.cfg,.yaml,.yml,.xml,.csv" style="display:none;" onchange="handleChatFileUpload(this)">
            </label>
            <button class="chat-send" id="chatSendBtn" onclick="sendChat()" style="padding:4px 12px;border:none;border-radius:6px;background:#2563eb;color:#fff;cursor:pointer;font-size:13px;white-space:nowrap;">发送</button>
          </div>
        </div>
        <div id="chatAttachmentInfo" style="display:none;margin-top:4px;font-size:11px;color:#6b7280;"></div>
      </div>
    </div>
  </div>
</div>

<!-- Edge Port Input Popup -->
<div id="edgePortPopup">
  <div class="edge-popup-title">
    <i class="fa-solid fa-plug" style="color:#3b82f6"></i>
    设置端口信息
  </div>
  <div class="edge-popup-row">
    <div class="edge-popup-label" id="edgeSrcLabel">源端口</div>
    <input class="edge-popup-input" id="edgeSrcPort" placeholder="如 GE0/0/1">
  </div>
  <div class="edge-popup-row">
    <div class="edge-popup-label" id="edgeTgtLabel">目标端口</div>
    <input class="edge-popup-input" id="edgeTgtPort" placeholder="如 GE0/0/1">
  </div>
  <div class="edge-popup-row" style="display:flex; gap:8px; align-items:center; margin-bottom:8px;">
    <span style="font-size:11px;color:#6b7280;">线型：</span>
    <button id="popup-style-solid" onclick="setEdgeStyle('solid'); updatePopupStyleUI()" style="flex:1;padding:4px;border-radius:4px;border:1px solid #3b82f6;background:#eff6ff;color:#3b82f6;font-size:13px;cursor:pointer;font-family:monospace;">━━━</button>
    <button id="popup-style-dashed" onclick="setEdgeStyle('dashed'); updatePopupStyleUI()" style="flex:1;padding:4px;border-radius:4px;border:1px solid #d1d5db;background:#fff;color:#6b7280;font-size:13px;cursor:pointer;font-family:monospace;">- - -</button>
  </div>
  <div class="edge-popup-row" style="display:flex; gap:8px; align-items:center; margin-bottom:10px;">
    <span style="font-size:11px;color:#6b7280;">颜色：</span>
    <button id="popup-color-gray" onclick="setEdgeColor('#374151'); updatePopupColorUI()" style="width:22px;height:22px;border-radius:50%;background:#374151;border:2px solid #fff;cursor:pointer;" title="灰"></button>
    <button id="popup-color-red" onclick="setEdgeColor('#ef4444'); updatePopupColorUI()" style="width:22px;height:22px;border-radius:50%;background:#ef4444;border:2px solid #fff;cursor:pointer;" title="红"></button>
    <button id="popup-color-green" onclick="setEdgeColor('#10b981'); updatePopupColorUI()" style="width:22px;height:22px;border-radius:50%;background:#10b981;border:2px solid #fff;cursor:pointer;" title="绿"></button>
    <button id="popup-color-blue" onclick="setEdgeColor('#3b82f6'); updatePopupColorUI()" style="width:22px;height:22px;border-radius:50%;background:#3b82f6;border:2px solid #fff;cursor:pointer;" title="蓝"></button>
  </div>
  <div class="edge-popup-btns">
    <button class="btn-confirm" onclick="confirmEdgePorts()">✓ 确认</button>
    <button class="btn-cancel-popup" onclick="cancelEdgePorts()">取消</button>
  </div>
</div>

<!-- Form Generation Modal -->
<div id="formGenModal">
  <div class="form-gen-wrap">
    <div class="form-gen-header">
      <i class="fa-solid fa-table-list" style="font-size:18px"></i>
      <h3>批量生成拓扑</h3>
      <button class="close-btn" onclick="closeFormGen()">×</button>
    </div>
    <div class="form-gen-tabs">
      <button class="form-gen-tab active" onclick="switchFormTab('devices')">📦 设备列表</button>
      <button class="form-gen-tab" onclick="switchFormTab('edges')">🔗 连线列表</button>
    </div>
    <div class="form-gen-body">
      <div id="tab-devices" class="form-gen-tab-content active">
        <div style="overflow-x:auto;">
          <table class="form-table" id="formDevTable">
            <thead>
              <tr>
                <th style="width:40px">#</th>
                <th>名称 *</th>
                <th>类型</th>
                <th>IP地址</th>
                <th>描述</th>
                <th style="width:60px">操作</th>
              </tr>
            </thead>
            <tbody id="formDevTbody"></tbody>
          </table>
        </div>
        <button class="add-row-btn" onclick="addFormDevRow()">+ 添加设备</button>
      </div>
      <div id="tab-edges" class="form-gen-tab-content">
        <div style="overflow-x:auto;">
          <table class="form-table" id="formEdgeTable">
            <thead>
              <tr>
                <th style="width:40px">#</th>
                <th>源设备</th>
                <th>目标设备</th>
                <th>源端口</th>
                <th>目标端口</th>
                <th style="width:60px">操作</th>
              </tr>
            </thead>
            <tbody id="formEdgeTbody"></tbody>
          </table>
        </div>
        <button class="add-row-btn" onclick="addFormEdgeRow()">+ 添加连线</button>
      </div>
    </div>
    <div class="form-gen-footer">
      <div class="form-gen-remarks">
        <label for="formRemarks">📝 AI 辅助说明（可选）</label>
        <textarea id="formRemarks" placeholder="补充描述网络结构、端口约定、VLAN 规划等，AI 会据此检查并优化拓扑..."></textarea>
      </div>
      <div class="ai-toggle">
        <input type="checkbox" id="formAiEnabled">
        <label for="formAiEnabled" style="cursor:pointer;">🤖 AI 辅助</label>
      </div>
      <div class="form-gen-actions">
        <button class="btn-gen" id="formGenBtn" onclick="doFormGen()">⚡ 生成拓扑</button>
        <button class="btn-close" onclick="clearFormDraft()" title="清除草稿">清空草稿</button>
        <button class="btn-close" onclick="closeFormGen()">取消</button>
      </div>
    </div>
  </div>
</div>

<script>
// Global error handler
window.addEventListener('error', function(e) {
    console.error('JS ERROR:', e.message, 'at', e.filename, 'line', e.lineno);
});

// ============================================================
// SVG Icon definitions (Huawei flat design style)
// ============================================================
const SVG = {
  router: `<img src="/icons/router.png" style="width:32px;height:32px;object-fit:contain;">`,
  switch: `<img src="/icons/switch.png" style="width:32px;height:32px;object-fit:contain;">`,
  firewall: `<img src="/icons/icon_firewall_custom.png" style="width:32px;height:32px;object-fit:contain;">`,
  server: `<img src="/icons/server.png" style="width:32px;height:32px;object-fit:contain;">`,
  pc: `<img src="/icons/pc.png" style="width:32px;height:32px;object-fit:contain;">`,
  cloud: `<img src="/icons/cloud.png" style="width:32px;height:32px;object-fit:contain;">`,
  wifi: `<img src="/icons/icon202.png" style="width:32px;height:32px;object-fit:contain;">`,
  phone: `<img src="/icons/icon204.png" style="width:32px;height:32px;object-fit:contain;">`,
  internet: `<img src="/icons/icon205.png" style="width:32px;height:32px;object-fit:contain;">`,
  database: `<img src="/icons/icon157.png" style="width:32px;height:32px;object-fit:contain;">`,
  printer: `<img src="/icons/icon159.png" style="width:32px;height:32px;object-fit:contain;">`,
  camera: `<img src="/icons/icon161.png" style="width:32px;height:32px;object-fit:contain;">`,
  switch_core: `<img src="/icons/switch_core.png" style="width:32px;height:32px;object-fit:contain;">`,
  switch_access: `<img src="/icons/switch_access.png" style="width:32px;height:32px;object-fit:contain;">`,
  router_advanced: `<img src="/icons/router_advanced.png" style="width:32px;height:32px;object-fit:contain;">`,
  router_core: `<img src="/icons/router_core.png" style="width:32px;height:32px;object-fit:contain;">`,
};



// ============================================================
// Cytoscape initialization
// ============================================================
var cy;
var _placing = false;  // guard against rapid duplicate placement
var isUndoRedo = false;  // undo/redo guard (declared global for access from addNode)

// One-click device placement: direct addNode call at viewport center
function quickAdd(type) {
  if (typeof cy === 'undefined' || !cy) {
    toast('画布加载中，请稍候');
    return;
  }
  try {
    var cw = cy.width();
    var ch = cy.height();
    var pan = cy.pan();
    var z = cy.zoom();
    if (!cw || !ch || !isFinite(cw) || !isFinite(ch)) {
      toast('画布尺寸异常');
      return;
    }
    var x = (cw / 2 - pan.x) / z + (Math.random() - 0.5) * 60;
    var y = (ch / 2 - pan.y) / z + (Math.random() - 0.5) * 60;
    toast('正在添加...');
    addNode(type, x, y);
  } catch(e) {
    toast('添加失败: ' + e.message);
  }
}

(function initCy() {
try {
cy = cytoscape({
  container: document.getElementById('canvasWrap'),
  style: [
    {
      selector: 'node',
      style: {
        'label': 'data(label)',
        'text-valign': 'bottom',
        'text-halign': 'center',
        'text-margin-y': '1px',
        'font-size': 13,
        'font-weight': '600',
        'color': '#1f2937',
        'text-wrap': 'none',
        'width': 80,
        'height': 80,
        'shape': 'roundrectangle',
        'border-width': 3,
        'border-color': 'data(color)',
        'background-color': '#ffffff',
        'background-opacity': 1,
        'background-image': 'data(icon)',
        'background-fit': 'cover',
        'background-clip': 'node',
        'background-position-x': '50%',
        'background-position-y': '50%',
      }
    },
    {
      selector: 'node[type="internet"]',
      style: { 'shape': 'round-rectangle' }
    },
    {
      selector: 'node:active',
      style: {
        'overlay-opacity': 0.1,
        'overlay-color': 'data(color)',
      }
    },
    {
      selector: 'edge',
      style: {
        'width': 2,
        'line-color': 'data(edgeColor)',
        'line-style': 'data(edgeStyle)',
        'curve-style': 'bezier',
        'label': 'data(label)',
        'font-size': 10,
        'color': '#374151',
        'text-background-color': '#f3f4f6',
        'text-background-opacity': 1,
        'text-background-padding': '2px',
        'edge-distances': 'intersection',
        'source-text-margin-y': 5,
        'target-text-margin-y': 5,
        'source-text-offset': 20,
        'target-text-offset': 20,
        'source-text-rotation': 'autorotate',
        'target-text-rotation': 'autorotate',
        'source-label': 'data(srcPort)',
        'target-label': 'data(tgtPort)',
        'source-font-size': 10,
        'target-font-size': 10,
        'source-color': '#1f2937',
        'target-color': '#1f2937',
        'source-font-weight': '600',
        'target-font-weight': '600',
        'source-text-background-color': '#f3f4f6',
        'target-text-background-color': '#f3f4f6',
        'source-text-background-opacity': 1,
        'target-text-background-opacity': 1,
      }
    },
    {
      selector: 'node:selected',
      style: {
        'border-width': 3,
        'border-color': '#60a5fa',
        'color': '#f3f4f6',
        
        
        
      }
    },
    {
      selector: '.node-connecting',
      style: {
        'border-width': 3,
        'border-color': '#3b82f6',
        'color': '#60a5fa',
      }
    },
    {
      selector: '.node-hover',
      style: {
        'border-width': 2.5,
      }
    },
  ],
  layout: { name: 'preset' },
  wheelSensitivity: 0.3,
  userPanningEnabled: true,
  userWheelEnabled: false,
  minZoom: 0.15,
  maxZoom: 4,
  boxSelectionEnabled: true,
  ready: function() {
    var _cy = this;
    _cy.zoom(1);
    _cy.pan({ x: 0, y: 0 });
    window.__cy__ = _cy;
    window.dispatchEvent(new CustomEvent('cyReady'));

    var _resizeTimer = null;
    window.addEventListener('resize', function() {
      clearTimeout(_resizeTimer);
      _resizeTimer = setTimeout(function() {
        _cy.resize();
        _cy.zoom(1);
        _cy.pan({ x: 0, y: 0 });
        // terminal removed
      }, 200);
    });

    // Guard: prevent double-fire when user double-clicks (but allow immediate placement when device type is selected)
  var _lastTapTime = 0;
  _cy.on('tap', function(e) {
    var now = Date.now();

    // If a device type is selected for placement, always process immediately (skip debounce)
    if (selectedDeviceType) {
      var pos = e.position || e.modelPosition;
      if (!pos) return;
      var isNode = !!(e.target && e.target.isNode && e.target.isNode());
      var isEdge = !!(e.target && e.target.isEdge && e.target.isEdge());
      if (isNode || isEdge) {
        // Clicked on a node/edge - treat as normal tap, ignore device placement
        if (isNode && currentMode === 'connect') { handleConnectTap(e.target); }
        else if (isNode) { selectElement(e.target); }
        return;
      }
      // Clicked on empty canvas - place device
      if (_placing) return;
      _placing = true;
      if (gridEnabled) {
        pos.x = Math.round(pos.x / GRID_SIZE) * GRID_SIZE;
        pos.y = Math.round(pos.y / GRID_SIZE) * GRID_SIZE;
      }
      addNode(selectedDeviceType, pos.x, pos.y);
      selectedDeviceType = null;
      document.querySelectorAll('.palette-item').forEach(function(el) { el.classList.remove('selected'); });
      var _mb = getModeBadge();
      if (_mb) { _mb.classList.remove('visible'); var _t2 = _mb.querySelector('.mode-text'); if(_t2) _t2.textContent = '选择模式'; }
      setMode('select');
      setTimeout(function() { _placing = false; }, 100);
      return;
    }

    // Normal debounce for non-placement taps
    if (now - _lastTapTime < 350) return;
    _lastTapTime = now;

    var pos = e.position || e.modelPosition;
    if (!pos) return;

    var isNode = !!(e.target && e.target.isNode && e.target.isNode());
    var isEdge = !!(e.target && e.target.isEdge && e.target.isEdge());

    if (isNode) {
      var node = e.target;
      if (currentMode === 'connect') {
        if (!connectSource) {
          connectSource = node;
          node.addClass('node-connecting');
          var _mb_nc = getModeBadge();
          if (_mb_nc) { var _t = _mb_nc.querySelector('.mode-text'); if(_t) _t.textContent = '已选源设备，再点目标设备'; _mb_nc.classList.add('visible'); }
        } else {
          if (connectSource.id() !== node.id()) {
            addEdge(connectSource.id(), node.id());
          }
          connectSource.removeClass('node-connecting');
          connectSource = null;
        }
      } else {
        selectElement(node);
      }
      return;
    }

    if (isEdge) {
      if (currentMode === 'select') selectElement(e.target);
      return;
    }

    if (selectedDeviceType) {
      if (_placing) { console.log('[TAP] blocked by _placing guard'); return; }
      _placing = true;
      if (gridEnabled) {
        pos.x = Math.round(pos.x / GRID_SIZE) * GRID_SIZE;
        pos.y = Math.round(pos.y / GRID_SIZE) * GRID_SIZE;
      }
      addNode(selectedDeviceType, pos.x, pos.y);
      selectedDeviceType = null;
      document.querySelectorAll('.palette-item').forEach(function(el) { el.classList.remove('selected'); });
      var _mb = getModeBadge();
      if (_mb) { _mb.classList.remove('visible'); var _t2 = _mb.querySelector('.mode-text'); if(_t2) _t2.textContent = '选择模式'; }
      setMode('select');
      // Clear placement lock after a short delay to allow next placement
      setTimeout(function() { _placing = false; }, 100);
      return;
    }
    if (currentMode === 'connect' && connectSource) {
      connectSource.removeClass('node-connecting');
      connectSource = null;
      return;
    }
    _cy.elements().unselect();
    hideProps();
  });

    _cy.on('dbltap', function(e) {
      if (e.target && e.target.isNode && e.target.isNode()) return;
      if (!selectedDeviceType) return;
      if (_placing) { console.log('[DBLTAP] blocked by _placing'); return; }
      _placing = true;
      var pos = e.position || e.modelPosition;
      if (!pos) { _placing = false; return; }
      addNode(selectedDeviceType, pos.x, pos.y);
      selectedDeviceType = null;
      document.querySelectorAll('.palette-item').forEach(function(el) { el.classList.remove('selected'); });
      var _mb3 = getModeBadge();
      if (_mb3) { _mb3.classList.remove('visible'); var _t3 = _mb3.querySelector('.mode-text'); if(_t3) _t3.textContent = '选择模式'; }
      setMode('select');
      setTimeout(function() { _placing = false; }, 100);
    });
  }  // closes ready: function()
  });  // closes cytoscape({...})
  } catch(e) {
    console.error('Cytoscape init FAILED:', e.message, e.stack);
    // Fallback: retry with minimal config
    try {
      cy = cytoscape({
        container: document.getElementById('canvasWrap'),
        elements: [],
        style: [{
          selector: 'node', style: {'label': 'data(label)', 'shape': 'roundrectangle', 'width': 80, 'height': 80, 'background-color': '#fff', 'border-width': 3, 'border-color': '#374151'}
        }, {
          selector: 'edge', style: {'width': 2, 'line-color': '#374151'}
        }],
        minZoom: 0.1, maxZoom: 4, boxSelectionEnabled: true, userPanningEnabled: true, userWheelEnabled: false
      });
      window.__cy__ = cy;
      cy.zoom(1);
      window.dispatchEvent(new CustomEvent('cyReady'));
    } catch(e2) {
      console.error('Fallback init also FAILED:', e2.message);
    }
  }
}());






// Direct canvas click: most reliable way to place devices (bypasses Cytoscape event system)
document.getElementById('canvasWrap').addEventListener('click', function(e) {
  if (!selectedDeviceType) return;
  // Ignore clicks on resize handles or other overlay elements
  var t = e.target;
  if (t.id && (t.id.startsWith('rh-') || t.id === 'selBox' || t.id === 'modeBadge' || t.id === 'resizeOverlay')) return;
  // Get Cytoscape coordinates
  var wrapRect = this.getBoundingClientRect();
  var zoom = cy.zoom();
  var pan = cy.pan();
  var x = (e.clientX - wrapRect.left - pan.x) / zoom;
  var y = (e.clientY - wrapRect.top - pan.y) / zoom;
  if (gridEnabled) { x = Math.round(x / GRID_SIZE) * GRID_SIZE; y = Math.round(y / GRID_SIZE) * GRID_SIZE; }
  console.log('[canvasWrap click] placing', selectedDeviceType, 'at', Math.round(x), Math.round(y));
  addNode(selectedDeviceType, x, y);
  selectedDeviceType = null;
  document.querySelectorAll('.palette-item').forEach(function(el) { el.classList.remove('selected'); });
  var _mb = getModeBadge();
  if (_mb) { _mb.classList.remove('visible'); var _t = _mb.querySelector('.mode-text'); if(_t) _t.textContent = '选择模式'; }
  setMode('select');
}, true);  // capture phase - fires before bubble


// Global click guard: cancel pending placement on any click that isn't on palette/canvas
document.addEventListener('click', function(e) {
  if (!selectedDeviceType) return;
  // Walk up the DOM to see if the click is in our app
  var el = e.target;
  while (el && el !== document.body) {
    if (el.id === 'canvasWrap' || el.id === 'cyCanvas') return;  // click on canvas - let tap handler deal with it
    if (el.classList && (el.classList.contains('palette-item') || el.classList.contains('palette-group'))) return;  // click on palette
    el = el.parentElement;
  }
  // Click is outside canvas and palette - cancel placement
  selectedDeviceType = null;
  document.querySelectorAll('.palette-item').forEach(function(p) { p.classList.remove('selected'); });
  var _mb_g = getModeBadge();
  if (_mb_g) { _mb_g.classList.remove('visible'); var _tg = _mb_g.querySelector('.mode-text'); if(_tg) _tg.textContent = '选择模式'; }
  setMode('select');
  console.log('[click guard] cancelled placement (click outside canvas)');
}, true);


// Device configuration
// ============================================================
const DEFAULTS = {
  router:   { ip: '', desc: '路由器' },
  router_advanced: { ip: '', desc: '高级路由器' },
  router_core: { ip: '', desc: '核心路由器' },
  switch:   { ip: '', desc: '交换机' },
  switch_core:   { ip: '', desc: '核心交换机' },
  switch_access: { ip: '', desc: '接入交换机' },
  firewall: { ip: '', desc: '防火墙' },
  server:   { ip: '', desc: '服务器' },
  pc:       { ip: '', desc: 'PC' },
  cloud:    { ip: '', desc: '云' },
};

const DEVICES = {
  router:   { label: '路由器',   icon: 'router.png', color: '#3b82f6', w: 72, h: 72 },
  router_advanced: { label: '高级路由器', icon: 'router_advanced.png', color: '#8b5cf6', w: 72, h: 72 },
  router_core: { label: '核心路由器', icon: 'router_core.png', color: '#6366f1', w: 72, h: 72 },
  switch:   { label: '交换机',   icon: 'switch.png', color: '#10b981', w: 80, h: 62 },
  switch_core:   { label: '核心交换机', icon: 'switch_core.png', color: '#6366f1', w: 80, h: 62 },
  switch_access: { label: '接入交换机', icon: 'switch_access.png', color: '#10b981', w: 80, h: 62 },
  firewall: { label: '防火墙',   icon: 'icon_firewall_custom.png', color: '#ef4444', w: 68, h: 68 },
  server:   { label: '服务器',   icon: 'server.png', color: '#8b5cf6', w: 68, h: 72 },
  pc:       { label: 'PC',       icon: 'pc.png', color: '#f59e0b', w: 68, h: 68 },
  cloud:    { label: '云',        icon: 'cloud.png', color: '#06b6d4', w: 72, h: 58 },
};


// ============================================================
// Node management
// ============================================================
function getNextLabel(type) {
  nodeCounter[type] = (nodeCounter[type] || 0) + 1;
  return DEVICES[type].label + '-' + nodeCounter[type];
}

function addNode(type, x, y, extra = {}) {
  const def = DEFAULTS[type];
  const d = DEVICES[type];
  const id = 'n' + Date.now() + Math.random().toString(36).substr(2, 5);
  nodeCounter[type] = (nodeCounter[type] || 0) + 1;

  // Capture undo state BEFORE adding (so undo restores empty canvas)
  if (!isUndoRedo) saveUndoState();

  try {
    var nodeData = {
      id, type,
      label: extra.label || (def.desc + '-' + nodeCounter[type]),
      icon: '/icons/' + d.icon,
      color: d.color,
      w: d.w, h: d.h,
      ip: def.ip, desc: def.desc,
      mac: '', port: '', bandwidth: '',
      ...extra,
    };
    var pos = {
      x: gridEnabled ? snapToGrid(x || Math.random() * 500 + 150) : (x || Math.random() * 500 + 150),
      y: gridEnabled ? snapToGrid(y || Math.random() * 300 + 150) : (y || Math.random() * 300 + 150)
    };
cy.add({ group: 'nodes', data: nodeData, position: pos });
  } catch(addErr) {
    toast('添加失败: ' + addErr.message);
    addOpLog('human', '添加设备失败：' + (extra.label || def.desc) + ' - ' + addErr.message);
    return id;
  }

  // Select and show properties
  var newNode = cy.nodes('[id="' + id + '"]')[0];
  if (newNode) { newNode.select(); }
  editingId = id;
  showProps(newNode);

  toast('✓ 已添加 ' + d.label);
  addOpLog('human', '添加设备：' + (extra.label || def.desc + '-' + nodeCounter[type]));
  return id;
}

function addEdge(srcId, tgtId) {
  // Allow multiple edges between two devices (different ports)

  const src = cy.getElementById(srcId);
  const tgt = cy.getElementById(tgtId);

  // Show port popup
  const srcLabel = document.getElementById('edgeSrcLabel');
  const tgtLabel = document.getElementById('edgeTgtLabel');
  const srcInput = document.getElementById('edgeSrcPort');
  const tgtInput = document.getElementById('edgeTgtPort');
  const popup = document.getElementById('edgePortPopup');

  srcLabel.textContent = '源端口 (' + src.data('label') + ')';
  tgtLabel.textContent = '目标端口 (' + tgt.data('label') + ')';
  srcInput.value = '';
  tgtInput.value = '';

  pendingEdge = { srcId, tgtId };

  // Position popup near center of canvas
  const wrap = document.querySelector('.canvas-wrap');
  const rect = wrap.getBoundingClientRect();
  popup.style.left = (rect.left + rect.width / 2 - 140) + 'px';
  popup.style.top = (rect.top + rect.height / 2 - 100) + 'px';
  popup.classList.add('show');
  document.getElementById('edgeSrcPort').focus();
  updatePopupColorUI();
}

function confirmEdgePorts() {
  if (!pendingEdge) return;
  const srcPort = document.getElementById('edgeSrcPort').value.trim();
  const tgtPort = document.getElementById('edgeTgtPort').value.trim();

  const src = cy.getElementById(pendingEdge.srcId);
  const tgt = cy.getElementById(pendingEdge.tgtId);

  let label = '';
  if (srcPort && tgtPort) {
    label = '';  // shown at ends via source-label/target-label
  } else if (srcPort) {
    label = srcPort + ' → ' + tgt.data('label');
  } else if (tgtPort) {
    label = src.data('label') + ' → ' + tgtPort;
  }

  const id = 'e' + Date.now();

  cy.add({
    group: 'edges',
    data: {
      id,
      label,
      source: pendingEdge.srcId,
      target: pendingEdge.tgtId,
      srcPort,
      tgtPort,
      bandwidth: '',
      edgeColor: pendingEdgeColor,
      edgeStyle: pendingEdgeStyle,
    },
    css: {
      'line-color': pendingEdgeColor,
      'line-style': pendingEdgeStyle,
    }
  });

  document.getElementById('edgePortPopup').classList.remove('show');
  // Save edge info BEFORE nulling pendingEdge (bug fix: was using pendingEdge after=null)
  var savedSrcId = pendingEdge ? pendingEdge.srcId : '';
  var savedTgtId = pendingEdge ? pendingEdge.tgtId : '';
  pendingEdge = null;
  setMode('select');
  toast('✓ 已建立连线');
  var sp = document.getElementById('edgeSrcPort').value.trim();
  var tp = document.getElementById('edgeTgtPort').value.trim();
  var srcLabel = savedSrcId && cy.getElementById(savedSrcId) ? cy.getElementById(savedSrcId).data('label') : (savedSrcId || '?');
  var tgtLabel = savedTgtId && cy.getElementById(savedTgtId) ? cy.getElementById(savedTgtId).data('label') : (savedTgtId || '?');
  var portInfo = sp || tp ? '（' + (sp || '?') + ' → ' + (tp || '?') + '）' : '';
  addOpLog('human', '添加连线：' + srcLabel + ' → ' + tgtLabel + ' ' + portInfo);
}

function cancelEdgePorts() {
  document.getElementById('edgePortPopup').classList.remove('show');
  pendingEdge = null;
  setMode('select');
}

// ============================================================
// Grid & Alignment
// ============================================================
function snapToGrid(val) {
  return Math.round(val / GRID_SIZE) * GRID_SIZE;
}

function refreshCanvas() {
  cy && cy.resize && cy.resize();
  cy && cy.zoom && cy.zoom(1);
  cy && cy.pan && cy.pan({ x: 0, y: 0 });
  cy && cy.center && cy.center();
}

function toggleGrid() {
  gridEnabled = !gridEnabled;
  const btn = document.getElementById('btn-grid');
  const wrap = document.getElementById('canvasWrap');
  if (gridEnabled) {
    btn.classList.add('active');
    wrap.classList.add('grid-on');
    toast('✓ 网格吸附已开启');
  } else {
    btn.classList.remove('active');
    wrap.classList.remove('grid-on');
    toast('ℹ 网格吸附已关闭');
  }
}

function alignToGrid() {
  const sel = cy.nodes(':selected');
  const nodes = sel.length > 0 ? sel : cy.nodes();
  if (nodes.length === 0) {
    toast('⚠ 没有设备需要对齐');
    return;
  }
  const cols = Math.ceil(Math.sqrt(nodes.length));
  const padding = 80;
  const availW = cy.container().offsetWidth - padding * 2;
  const availH = cy.container().offsetHeight - padding * 2;
  const cellW = availW / cols;
  const cellH = GRID_SIZE * 2;
  nodes.forEach(function(n, i) {
    const col = i % cols;
    const row = Math.floor(i / cols);
    const x = snapToGrid(padding + col * cellW + cellW / 2);
    const y = snapToGrid(padding + row * cellH + cellH / 2);
    n.position({ x: x, y: y });
  });
  toast('✓ 已对齐整理，共 ' + nodes.length + ' 台设备');
}

function toggleAlignMenu() {
  var menu = document.getElementById('alignMenu');
  menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
  // Close on outside click
  document.onclick = function(e) {
    if (!document.getElementById('alignMenu').contains(e.target) && e.target.id !== 'btn-align') {
      document.getElementById('alignMenu').style.display = 'none';
      document.onclick = null;
    }
  };
}

function doAlign(type) {
  document.getElementById('alignMenu').style.display = 'none';
  document.onclick = null;
  const sel = cy.nodes(':selected');
  const nodes = sel.length > 0 ? sel : cy.nodes();
  if (nodes.length < 2) {
    toast('⚠ 至少需要2个设备才能对齐');
    return;
  }
  var minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
  nodes.forEach(function(n) {
    var p = n.position();
    var w = n.data('w') || 72;
    var h = n.data('h') || 72;
    minX = Math.min(minX, p.x - w/2);
    maxX = Math.max(maxX, p.x + w/2);
    minY = Math.min(minY, p.y - h/2);
    maxY = Math.max(maxY, p.y + h/2);
  });
  var midX = (minX + maxX) / 2;
  var midY = (minY + maxY) / 2;
  if (type === 'left') {
    nodes.forEach(function(n) {
      var w = n.data('w') || 72;
      n.position({ x: minX + w/2, y: n.position().y });
    });
    toast('✓ 左对齐（' + nodes.length + '个）', 1500);
  } else if (type === 'right') {
    nodes.forEach(function(n) {
      var w = n.data('w') || 72;
      n.position({ x: maxX - w/2, y: n.position().y });
    });
    toast('✓ 右对齐（' + nodes.length + '个）', 1500);
  } else if (type === 'hcenter') {
    nodes.forEach(function(n) { n.position({ x: midX, y: n.position().y }); });
    toast('✓ 水平居中（' + nodes.length + '个）', 1500);
  } else if (type === 'top') {
    nodes.forEach(function(n) {
      var h = n.data('h') || 72;
      n.position({ x: n.position().x, y: minY + h/2 });
    });
    toast('✓ 顶对齐（' + nodes.length + '个）', 1500);
  } else if (type === 'bottom') {
    nodes.forEach(function(n) {
      var h = n.data('h') || 72;
      n.position({ x: n.position().x, y: maxY - h/2 });
    });
    toast('✓ 底对齐（' + nodes.length + '个）', 1500);
  } else if (type === 'vcenter') {
    nodes.forEach(function(n) { n.position({ x: n.position().x, y: midY }); });
    toast('✓ 垂直居中（' + nodes.length + '个）', 1500);
  } else if (type === 'grid') {
    alignToGrid();
  }
  saveUndoState && saveUndoState();
  autoSaveProject && autoSaveProject();
  refreshCanvas && refreshCanvas();
}

// ============================================================
// Mode management
// ============================================================
// ===== SECTION: UI Actions =====
function getModeBadge() { return document.getElementById('modeBadge'); }

function setMode(mode) {
  if (pendingEdge) {
    document.getElementById('edgePortPopup').classList.remove('show');
    pendingEdge = null;
  }
  if (currentMode !== mode) {
    hideResizeHandles();
  }
  if (connectSource) {
    connectSource.removeClass('node-connecting');
    connectSource = null;
  }
  currentMode = mode;
  document.querySelectorAll('.toolbar button').forEach(function(el) { el.classList.remove('active'); });
  if (mode === 'select') {
    document.getElementById('btn-select') && (document.getElementById('btn-select').classList.add('active'));
  } else if (mode === 'connect') {
    document.getElementById('btn-connect') && (document.getElementById('btn-connect').classList.add('active'));
    var badge = getModeBadge();
    badge.querySelector('.mode-text').textContent = '点第一个设备（源）';
    badge.classList.add('visible');
  }
  if (mode !== 'connect') {
    var _mb = getModeBadge(); if (_mb) _mb.classList.remove('visible');
  }
}

// ============================================================
// Edge Style & Color
// ============================================================
function setEdgeColor(color) {
  pendingEdgeColor = color;
  ['#374151','#ef4444','#f59e0b','#10b981','#3b82f6'].forEach(function(c) {
    var btn = document.getElementById('color-' + c.replace('#',''));
    if (btn) btn.style.border = (c === color ? '3px solid #1f2937' : '2px solid #fff');
  });
}

function updatePopupColorUI() {
  ['gray','red','green','blue'].forEach(function(c) {
    var btn = document.getElementById('popup-color-' + c);
    if (btn) {
      var colorMap = {gray:'#374151',red:'#ef4444',green:'#10b981',blue:'#3b82f6'};
      btn.style.border = (pendingEdgeColor === colorMap[c] ? '3px solid #1f2937' : '2px solid #fff');
    }
  });
}

// ============================================================
// Palette drag-and-drop
// ============================================================
function onPaletteDragStart(e) {
  var type = e.currentTarget.dataset.deviceType;
  if (!type) return;
  e.dataTransfer.setData('deviceType', type);
  e.dataTransfer.effectAllowed = 'copy';
  e.currentTarget.classList.add('palette-dragging');
  document.getElementById('cyCanvas').classList.add('drag-over');
  // Also activate click-to-place mode
  selectedDeviceType = type;
  var _mb_ds = getModeBadge();
  if (_mb_ds) {
    var _t2 = _mb_ds.querySelector('.mode-text');
    if (_t2) _t2.textContent = '已选' + (DEVICES[type] && DEVICES[type].label || type) + '，点击画布放置';
    _mb_ds.classList.add('visible');
  }
}

function onPaletteDragEnd(e) {
  e.currentTarget.classList.remove('palette-dragging');
  document.getElementById('cyCanvas').classList.remove('drag-over');
}

function setupCanvasDropZone() {
  var cyEl = document.getElementById('cyCanvas');

  document.addEventListener('dragover', function(e) {
    var rect = cyEl.getBoundingClientRect();
    if (e.clientX >= rect.left && e.clientX <= rect.right &&
        e.clientY >= rect.top && e.clientY <= rect.bottom) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'copy';
      cyEl.classList.add('drag-over');
    }
  });

  document.addEventListener('dragleave', function(e) {
    var rect = cyEl.getBoundingClientRect();
    if (e.clientX < rect.left || e.clientX > rect.right ||
        e.clientY < rect.top || e.clientY > rect.bottom) {
      cyEl.classList.remove('drag-over');
    }
  });

  document.addEventListener('drop', function(e) {
    e.preventDefault();
    cyEl.classList.remove('drag-over');
    var type = e.dataTransfer.getData('deviceType');
    if (!type) return;
    var rect = cyEl.getBoundingClientRect();
    if (e.clientX < rect.left || e.clientX > rect.right ||
        e.clientY < rect.top || e.clientY > rect.bottom) return;
    // Convert client coords to Cytoscape model coords
    var rect = cyEl.getBoundingClientRect();
    var posX = e.clientX - rect.left;
    var posY = e.clientY - rect.top;
    if (gridEnabled) {
      posX = Math.round(posX / GRID_SIZE) * GRID_SIZE;
      posY = Math.round(posY / GRID_SIZE) * GRID_SIZE;
    }

    addNode(type, posX, posY);
    document.querySelectorAll('.palette-item').forEach(function(el) { el.classList.remove('selected'); });
    var _mb4 = getModeBadge(); if (_mb4) _mb4.classList.remove('visible');
    selectedDeviceType = null;
  });
}

function setEdgeStyle(style) {
  pendingEdgeStyle = style;
  updatePopupStyleUI();
}
function updatePopupStyleUI() {
  var sb = document.getElementById('popup-style-solid');
  var db = document.getElementById('popup-style-dashed');
  if (sb) sb.style.cssText = 'flex:1;padding:4px;border-radius:4px;border:1px solid ' + (pendingEdgeStyle==='solid'?'#3b82f6;background:#eff6ff;color:#3b82f6':'#d1d5db;background:#fff;color:#6b7280') + ';font-size:13px;cursor:pointer;font-family:monospace;';
  if (db) db.style.cssText = 'flex:1;padding:4px;border-radius:4px;border:1px solid ' + (pendingEdgeStyle==='dashed'?'#3b82f6;background:#eff6ff;color:#3b82f6':'#d1d5db;background:#fff;color:#6b7280') + ';font-size:13px;cursor:pointer;font-family:monospace;';
}
// ===== SECTION: Constants =====
const GRID_SIZE = 48;

// ===== SECTION: Global State =====
let currentMode = 'select';
let selectedDeviceType = null;
let boxSelecting = false, boxStartX = 0, boxStartY = 0;
let connectSource = null;
let pendingEdge = null;
let pendingEdgeStyle = 'solid';
let pendingEdgeColor = '#374151';
let nodeCounter = {};
let editingId = null;
let gridEnabled = false;
let lastDblTapTime = 0;
let lastDblTapTarget = null;
let canvasLocked = true;

// ============================================================
// Palette
// ============================================================
function toggleGroup(item) {
  const sub = item.nextElementSibling;
  if (!sub || !sub.classList.contains('palette-subitems')) return;
  const isOpen = sub.style.display !== 'none';
  sub.style.display = isOpen ? 'none' : 'block';
  item.querySelector('.group-chevron').textContent = isOpen ? '▸' : '▾';
}

function pickDevice(type) {
  // Two-step: select type → click canvas to place (same as shapes)
  if (editingId) {
    editingId = null;
    cy.elements().unselect();
    hideProps();
  }
  selectedDeviceType = type;
  document.querySelectorAll('.palette-item').forEach(function(el) { el.classList.remove('selected'); });
  if (event.currentTarget) event.currentTarget.classList.add('selected');
  var _mb = getModeBadge();
  if (_mb) {
    _mb.classList.add('visible');
    var _t = _mb.querySelector('.mode-text');
    if (_t) _t.textContent = '已选' + (DEVICES[type] && DEVICES[type].label || type) + '，点击画布放置';
    var _d = _mb.querySelector('.mode-dot');
    if (_d) _d.style.background = DEVICES[type] ? DEVICES[type].color : '#2563eb';
  }
  // Auto-cancel after 30s
  if (window._placementTimer) clearTimeout(window._placementTimer);
  window._placementTimer = setTimeout(function() {
    if (selectedDeviceType) {
      selectedDeviceType = null;
      document.querySelectorAll('.palette-item').forEach(function(el) { el.classList.remove('selected'); });
      var _mb2 = getModeBadge();
      if (_mb2) { _mb2.classList.remove('visible'); var _t2 = _mb2.querySelector('.mode-text'); if(_t2) _t2.textContent = '选择模式'; }
    }
  }, 30000);
}

// ============================================================
// Element selection & properties
// ============================================================
function selectElement(ele) {
  cy.elements().unselect();
  ele.select();
  editingId = ele.id();

  showProps(ele);
}

function hideProps() {
  document.getElementById('propsEmpty').style.display = 'block';
  document.getElementById('propsContent').style.display = 'none';
  editingId = null;
}

function showProps(ele) {
  const empty = document.getElementById('propsEmpty');
  const content = document.getElementById('propsContent');
  empty.style.display = 'none';
  content.style.display = 'block';
  const d = ele.data();

  if (ele.group() === 'nodes' && d.isShape) {
    // === Shape properties ===
    const bgVal = d.shapeBg || 'transparent';
    const fgVal = d.shapeFg || '#1f2937';
    content.innerHTML = `
      <div class="prop-group">
        <div class="prop-label">类型</div>
        <div style="font-size:13px;color:#d1d5db">
          <i class="fa-solid fa-shapes" style="color:${d.shapeColor||'#ef4444'}"></i>
          ${d.type === 'ellipse' ? '椭圆' : '方形'}
        </div>
      </div>
      <div class="prop-group">
        <div class="prop-label">文字</div>
        <input class="prop-input" id="p-label" value="${d.label||''}" placeholder="形状内的文字" oninput="upd('label',this.value)">
      </div>
      <div class="prop-group">
        <div class="prop-label">边框颜色</div>
        <input type="color" value="${d.shapeColor||'#ef4444'}" id="p-shapeColor"
          style="width:36px;height:28px;border:1px solid #374151;border-radius:6px;cursor:pointer;padding:0;"
          oninput="updShapeStyle('shapeColor',this.value)">
        <span style="font-size:11px;color:#9ca3af;margin-left:6px">${d.shapeColor||'#ef4444'}</span>
      </div>
      <div class="prop-group">
        <div class="prop-label">背景颜色</div>
        <input type="color" value="${bgVal === 'transparent' ? '#000000' : bgVal}" id="p-shapeBg"
          style="width:36px;height:28px;border:1px solid #374151;border-radius:6px;cursor:pointer;padding:0;"
          oninput="updShapeStyle('shapeBg',this.value)">
        <span style="font-size:11px;color:#9ca3af;margin-left:6px">${bgVal === 'transparent' ? '透明' : bgVal}</span>
        <span style="font-size:10px;color:#6b7280;cursor:pointer;margin-left:4px" onclick="updShapeStyle('shapeBg','transparent')">透明</span>
      </div>
      <div class="prop-group">
        <div class="prop-label">文字颜色</div>
        <input type="color" value="${fgVal}" id="p-shapeFg"
          style="width:36px;height:28px;border:1px solid #374151;border-radius:6px;cursor:pointer;padding:0;"
          oninput="updShapeStyle('shapeFg',this.value)">
        <span style="font-size:11px;color:#9ca3af;margin-left:6px">${fgVal}</span>
      </div>
      <div class="prop-group">
        <button onclick="saveNodeProps()" style="width:100%;background:#3b82f6;color:#fff;border:none;border-radius:7px;padding:10px;font-size:13px;font-weight:600;cursor:pointer">
          <i class="fa-solid fa-check"></i> 保存修改
        </button>
      </div>
    `;
  } else if (ele.group() === 'nodes' && d.isTextBox) {
    // === TextBox properties ===
    const bgVal = d.tbBg || 'transparent';
    const fgVal = d.tbFg || '#1f2937';
    content.innerHTML = `
      <div class="prop-group">
        <div class="prop-label">类型</div>
        <div style="font-size:13px;color:#d1d5db">
          <i class="fa-solid fa-font"></i> 文本框
        </div>
      </div>
      <div class="prop-group">
        <div class="prop-label">文字</div>
        <input class="prop-input" id="p-label" value="${d.label||''}" placeholder="文本内容" oninput="upd('label',this.value)">
      </div>
      <div class="prop-group">
        <div class="prop-label">背景颜色</div>
        <input type="color" value="${bgVal === 'transparent' ? '#000000' : bgVal}" id="p-tbBg"
          style="width:36px;height:28px;border:1px solid #374151;border-radius:6px;cursor:pointer;padding:0;"
          oninput="updShapeStyle('tbBg',this.value)">
        <span style="font-size:11px;color:#9ca3af;margin-left:6px">${bgVal === 'transparent' ? '透明' : bgVal}</span>
        <span style="font-size:10px;color:#6b7280;cursor:pointer;margin-left:4px" onclick="updShapeStyle('tbBg','transparent')">透明</span>
      </div>
      <div class="prop-group">
        <div class="prop-label">文字颜色</div>
        <input type="color" value="${fgVal}" id="p-tbFg"
          style="width:36px;height:28px;border:1px solid #374151;border-radius:6px;cursor:pointer;padding:0;"
          oninput="updShapeStyle('tbFg',this.value)">
        <span style="font-size:11px;color:#9ca3af;margin-left:6px">${fgVal}</span>
      </div>
      <div class="prop-group">
        <button onclick="saveNodeProps()" style="width:100%;background:#3b82f6;color:#fff;border:none;border-radius:7px;padding:10px;font-size:13px;font-weight:600;cursor:pointer">
          <i class="fa-solid fa-check"></i> 保存修改
        </button>
      </div>
    `;
  } else if (ele.group() === 'nodes') {
    // === Device properties ===
    content.innerHTML = `
      <div class="prop-group">
        <div class="prop-label">设备类型</div>
        <div style="font-size:13px;color:#d1d5db">
          <i class="fa-solid ${d.color ? DEVICES[d.type]?.icon : ''}" style="color:${d.color}"></i>
          ${DEVICES[d.type]?.label || d.type}
        </div>
      </div>
      <div class="prop-group">
        <div class="prop-label">名称</div>
        <input class="prop-input" id="p-label" value="${d.label}" oninput="upd('label',this.value)">
      </div>
      <div class="prop-group">
        <div class="prop-label">IP地址</div>
        <input class="prop-input" id="p-ip" value="${d.ip||''}" placeholder="如 192.168.1.1" oninput="upd('ip',this.value)">
      </div>
      <div class="prop-group">
        <div class="prop-label">描述</div>
        <input class="prop-input" id="p-desc" value="${d.desc||''}" placeholder="设备描述" oninput="upd('desc',this.value)">
      </div>
      <div class="prop-group">
        <button onclick="saveNodeProps()" style="width:100%;background:#3b82f6;color:#fff;border:none;border-radius:7px;padding:10px;font-size:13px;font-weight:600;cursor:pointer">
          <i class="fa-solid fa-check"></i> 保存修改
        </button>
      </div>
    `;
  } else {
    // === Edge properties ===
    content.innerHTML = `
      <div class="prop-group">
        <div style="font-size:12px;color:#6b7280">
          <i class="fa-solid fa-link" style="color:#374151"></i>
          ${cy.getElementById(d.src)?.data('label') || '?'} → ${cy.getElementById(d.tgt)?.data('label') || '?'}
        </div>
      </div>
      <div class="prop-group">
        <div class="prop-label">源端口</div>
        <input class="prop-input" id="p-srcPort" value="${d.srcPort||''}" placeholder="如 GE0/0/1" oninput="upd('srcPort',this.value)">
      </div>
      <div class="prop-group">
        <div class="prop-label">目标端口</div>
        <input class="prop-input" id="p-tgtPort" value="${d.tgtPort||''}" placeholder="如 GE0/0/1" oninput="upd('tgtPort',this.value)">
      </div>
      <div class="prop-group">
        <div class="prop-label">带宽</div>
        <input class="prop-input" id="p-bandwidth" value="${d.bandwidth||''}" placeholder="如 1Gbps / 10Gbps" oninput="upd('bandwidth',this.value)">
      </div>
      <div class="prop-group">
        <div class="prop-label">备注</div>
        <input class="prop-input" id="p-label" value="${d.label||''}" placeholder="如 光纤 / 铜缆" oninput="upd('label',this.value)">
      </div>
      <div class="prop-group">
        <button onclick="saveNodeProps()" style="width:100%;background:#3b82f6;color:#fff;border:none;border-radius:7px;padding:10px;font-size:13px;font-weight:600;cursor:pointer">
          <i class="fa-solid fa-check"></i> 保存修改
        </button>
      </div>
    `;
  }
}

function saveNodeProps() {
  // Regenerate SVG for shapes if needed
  var ele = cy.getElementById(editingId);
  if (ele && ele.data('isShape')) {
    var d = ele.data();
    var w = d.w || 80, h = d.h || 60;
    var svgUri = makeShapeSVG(d.type, d.shapeColor || '#ef4444', w, h, d.label || '', d.shapeBg || 'transparent', d.shapeFg || '#1f2937');
    ele.css({'background-image': svgUri});
  }
  autoSaveProject && autoSaveProject();
  updateProjectMeta && updateProjectMeta();
  var t = document.getElementById('toast');
  t.textContent = '✓ 保存成功';
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(function() { t.classList.remove('show'); }, 2500);
}

function upd(key, val) {
  const ele = cy.getElementById(editingId);
  if (!ele) return;
  ele.data(key, val);
  // For shapes: regenerate SVG when label changes
  if (key === 'label' && ele.data('isShape')) {
    var d = ele.data();
    var w = d.w || 80, h = d.h || 60;
    var svgUri = makeShapeSVG(d.type, d.shapeColor || '#ef4444', w, h, val || '', d.shapeBg || 'transparent', d.shapeFg || '#1f2937');
    ele.css({'background-image': svgUri});
  }
  // Update edge label if label changed and it's an edge
  if (key === 'label' && ele.group() === 'edges') {
    // custom label
  }
}

function updShapeStyle(key, val) {
  const ele = cy.getElementById(editingId);
  if (!ele) return;
  const d = ele.data();
  if (!d.isShape) return;
  ele.data(key, val);
  // Regenerate SVG with new style
  var w = d.w || 80, h = d.h || 60;
  var color = d.shapeColor || '#ef4444';
  var label = d.label || '';
  var bg = d.shapeBg || 'transparent';
  var fg = d.shapeFg || '#1f2937';
  var svgUri = makeShapeSVG(d.type, color, w, h, label, bg, fg);
  ele.css({'background-image': svgUri});
}

// ============================================================
// Auto layout
// ============================================================
function autoLayout() {
  if (cy.nodes().length === 0) { toast('拓扑为空'); return; }
  const nodes = cy.nodes();
  // Breadth-first-ish hierarchical layout
  cy.layout({
    name: 'cose',
    animate: true,
    animationDuration: 500,
    nodeRepulsion: 12000,
    idealEdgeLength: 140,
    gravity: 0.3,
    padding: 60,
    randomize: false,
    nodeDimensionsIncludeLabels: true,
  }).run();
  toast('✨ 正在自动布局...');
}

// ============================================================
// Context menu
// ============================================================
const ctxMenu = document.getElementById('ctxMenu');

cy.on('cxttap', 'node, edge', function(e) {
  e.preventDefault();
  editingId = e.target.id();
  const ev = e.originalEvent;
  ctxMenu.style.left = Math.min(ev.clientX, window.innerWidth - 180) + 'px';
  ctxMenu.style.top = Math.min(ev.clientY, window.innerHeight - 160) + 'px';
  var delItem = document.getElementById('ctxDeleteItem');
  if (delItem) {
    var sel = cy.$(':selected');
    if (sel.length > 1) {
      delItem.innerHTML = '<i class="fa-solid fa-trash-alt" style="width:16px"></i> 删除所选(' + sel.length + ')';
    } else {
      delItem.innerHTML = '<i class="fa-solid fa-trash-alt" style="width:16px"></i> 删除';
    }
  }
  ctxMenu.classList.add('visible');
});

cy.on('cxttap', function(e) {
  if (e.target === cy) ctxMenu.classList.remove('visible');
});

document.addEventListener('click', () => ctxMenu.classList.remove('visible'));

function ctxEdit() {
  const ele = cy.getElementById(editingId);
  if (ele) selectElement(ele);
  ctxMenu.classList.remove('visible');
}

function ctxDelete() {
  var sel = cy.$(':selected');
  if (sel.length === 0) {
    var ele = cy.getElementById(editingId);
    if (ele) sel = sel.add(ele);
  }
  if (sel.length === 0) {
    ctxMenu.classList.remove('visible');
    return;
  }
  saveUndoState();
  var nodes = sel.nodes();
  var edges = sel.edges();
  var devCount = nodes.filter(function(n) { var d = n.data(); return d && !d.isShape && !d.isTextBox; }).length;
  var shapeCount = nodes.filter(function(n) { var d = n.data(); return d && d.isShape; }).length;
  var textCount = nodes.filter(function(n) { var d = n.data(); return d && d.isTextBox; }).length;
  sel.remove();
  hideResizeHandles();
  hideProps();
  toast('已删除（可 Ctrl+Z 撤销）');
  var desc = [];
  if (devCount > 0) desc.push(devCount + '个设备');
  if (shapeCount > 0) desc.push(shapeCount + '个形状');
  if (textCount > 0) desc.push(textCount + '个文本框');
  if (edges.length > 0) desc.push(edges.length + '条连线');
  if (desc.length > 0) addOpLog('human', '删除' + desc.join('、'));
  ctxMenu.classList.remove('visible');
}

function ctxDuplicate() {
  const ele = cy.getElementById(editingId);
  if (ele && ele.group() === 'nodes') {
    const d = ele.data();
    const p = ele.position();
    addNode(d.type, p.x + 60, p.y + 60, {
      label: d.label + '-副本',
      ip: '', desc: d.desc,
    });
  }
  ctxMenu.classList.remove('visible');
}

}

// ============================================================
// Box Selection & Multi-Drag
// Custom box select via canvas-wrap mousedown/mousemove/mouseup
// After box-selection, drag any selected node to drag them all.
// ============================================================

// ============================================================
// Zoom & Pan controls + Canvas lock
// ============================================================
// canvasLocked already declared above (let)

function toggleCanvasLock() {
  canvasLocked = !canvasLocked;
  var btn = document.getElementById('btn-canvas-lock');
  if (canvasLocked) {
    cy.userPanningEnabled(false);
    btn.innerHTML = '<i class="fa-solid fa-lock"></i> 已锁定';
    btn.style.cssText = 'background:#fef3c7;color:#92400e;border:1px solid #f59e0b;';
  } else {
    cy.userPanningEnabled(true);
    btn.innerHTML = '<i class="fa-solid fa-lock-open"></i> 已解锁';
    btn.style.cssText = 'background:#d1fae5;color:#065f46;border:1px solid #10b981;';
  }
}

function cyZoomIn() { var z = Math.min(4, cy.zoom() * 1.25); cy.zoom(z); cy.center(); }
function cyZoomOut() { var z = Math.max(0.15, cy.zoom() / 1.25); cy.zoom(z); cy.center(); }
function cyPan(dx, dy) { var p = cy.pan(); cy.pan({ x: p.x + dx, y: p.y + dy }); }

// Lock canvas panning by default (user can unlock via toggle button)
cy.userPanningEnabled(false);

// ============================================================
// Multi-node drag (Cytoscape handles single-node drag natively)
// ============================================================
var _dragSelStartPos = {};
var _multiDragNodes = [];

cy.on('grab', 'node', function(e) {
  var node = e.target;
  _dragSelStartPos = {};
  _multiDragNodes = [];
  var sel = cy.$('node:selected');
  if (sel.length > 1 && node.selected()) {
    sel.forEach(function(n) {
      _dragSelStartPos[n.id()] = { x: n.position('x'), y: n.position('y') };
      _multiDragNodes.push(n);
    });
  }
});

cy.on('dragfree', 'node', function(e) {
  var node = e.target;
  if (_multiDragNodes.length > 1) {
    var dx = node.position('x') - _dragSelStartPos[node.id()].x;
    var dy = node.position('y') - _dragSelStartPos[node.id()].y;
    _multiDragNodes.forEach(function(n) {
      if (n !== node) {
        var sp = _dragSelStartPos[n.id()];
        var np = { x: sp.x + dx, y: sp.y + dy };
        if (gridEnabled) {
          np.x = Math.round(np.x / GRID_SIZE) * GRID_SIZE;
          np.y = Math.round(np.y / GRID_SIZE) * GRID_SIZE;
        }
        n.position(np);
      }
    });
  }
  _dragSelStartPos = {};
  _multiDragNodes = [];
});

// ============================================================
// Custom box select via raw mouse events (bypasses Cytoscape native)
// ============================================================
(function() {
  var wrap = document.getElementById('canvasWrap');
  if (!wrap) return;
  var selBox = document.getElementById('selBox');
  var down = null, moved = false;

  wrap.addEventListener('mousedown', function(e) {
    if (e.button !== 0) return;
    // Don't intercept if clicking on a node
    // Don't intercept if clicking on a node (manual collision for Cytoscape 3.x compatibility)
    var hitNode = null;
    cy.nodes().forEach(function(n) {
      var rp = n.renderedPosition();
      var r = 30;
      var dx = e.offsetX - rp.x, dy = e.offsetY - rp.y;
      if (dx*dx + dy*dy <= r*r) { hitNode = n; }
    });
    if (hitNode) return;
    down = { x: e.clientX, y: e.clientY };
    moved = false;
    selBox.style.display = 'none';
  });

  wrap.addEventListener('mousemove', function(e) {
    if (!down) return;
    var dx = e.clientX - down.x, dy = e.clientY - down.y;
    if (Math.abs(dx) > 4 || Math.abs(dy) > 4) {
      moved = true;
      var rx = Math.min(down.x, e.clientX), ry = Math.min(down.y, e.clientY);
      var rw = Math.abs(dx), rh = Math.abs(dy);
      selBox.style.cssText = 'position:fixed;left:' + rx + 'px;top:' + ry + 'px;width:' + rw + 'px;height:' + rh + 'px;border:1.5px solid #2563eb;background:rgba(37,99,235,0.12);border-radius:3px;pointer-events:none;z-index:9999;';
    }
  });

  wrap.addEventListener('mouseup', function(e) {
    if (!down) return;
    if (moved) {
      var rect = selBox.getBoundingClientRect();
      cy.nodes().unselect();
      cy.nodes().forEach(function(n) {
        var wp = n.renderedPosition();
        if (wp.x >= rect.left && wp.x <= rect.right && wp.y >= rect.top && wp.y <= rect.bottom) {
          n.select();
        }
      });
    }
    selBox.style.display = 'none';
    down = null;
    moved = false;
  });

  wrap.addEventListener('mouseleave', function() {
    selBox.style.display = 'none';
    down = null;
  });
})();

// ============================================================
// Keyboard shortcuts
// ============================================================

// ============================================================
// Keyboard shortcuts
// ============================================================
document.addEventListener('keydown', function(e) {
  if (e.target.tagName === 'INPUT') return;
  if (e.key === 'Delete' || e.key === 'Backspace') {
    const sel = cy.$(':selected');
    if (sel.length > 0) {
      var nodes = sel.nodes();
      var devCount = nodes.filter(function(n) { var d = n.data(); return d && !d.isShape && !d.isTextBox; }).length;
      var shapeCount = nodes.filter(function(n) { var d = n.data(); return d && d.isShape; }).length;
      var textCount = nodes.filter(function(n) { var d = n.data(); return d && d.isTextBox; }).length;
      sel.remove();
      hideResizeHandles();
      hideProps();
      toast('已删除');
      var desc = [];
      if (devCount > 0) desc.push(devCount + '个设备');
      if (shapeCount > 0) desc.push(shapeCount + '个形状');
      if (textCount > 0) desc.push(textCount + '个文本框');
      if (sel.edges().length > 0) desc.push(sel.edges().length + '条连线');
      if (desc.length > 0) addOpLog('human', '删除' + desc.join('、'));
    }
  }
  if (e.key === 'Escape') {
    setMode('select');
    selectedDeviceType = null;
    document.querySelectorAll('.palette-item').forEach(el => el.classList.remove('selected'));
    if (getModeBadge()) getModeBadge().classList.remove('visible');
    cy && cy.nodes(':selected').unselect();
  }
  if ((e.ctrlKey || e.metaKey) && e.key === 's') {
    e.preventDefault();
    saveTopology();
  }
  if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) {
    e.preventDefault();
    undoTopo && undoTopo();
  }
  if ((e.ctrlKey || e.metaKey) && (e.key === 'y' || (e.key === 'z' && e.shiftKey))) {
    e.preventDefault();
    redoTopo && redoTopo();
  }
  if (e.key === 'Delete' || e.key === 'Backspace') {
    var tag = e.target.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA') return;
    var sel = cy ? cy.nodes(':selected') : [];
    if (sel.length > 0) {
      e.preventDefault();
      if (!isUndoRedo) saveUndoState();
      sel.remove();
      autoSaveProject && autoSaveProject();
      updateProjectMeta && updateProjectMeta();
    }
  }
});

// ============================================================
// Project Management
// ============================================================
// Support ?proj=ID URL parameter for server-based project loading
(function() {
  var params = new URLSearchParams(window.location.search);
  window._projId = params.get('proj') || null;
  // Sync currentProjectId from URL param immediately (for old ?proj= URLs)
  if (window._projId) {
    currentProjectId = window._projId;
  }
})();
var currentProjectId = window._projId || null; // Set from URL on load
var currentProjectName = null; // Name resolved from server via /meta
var _projectModalOpen = false; // 避免重复渲染项目列表

function getProjectList() {
  try {
    return JSON.parse(localStorage.getItem('nettopo-projects') || '[]');
  } catch(e) { return []; }
}

function saveProjectList(list) {
  try {
    localStorage.setItem('nettopo-projects', JSON.stringify(list));
  } catch(e) {}
}

function getProjectTopoKey(id) {
  return 'nettopo-proj-' + id;
}

function getCurrentTopoData() {
  return {
    version: '3',
    savedAt: new Date().toISOString(),
    nodes: cy.nodes().map(function(n) {
      var d = { ...n.data(), position: n.position() };
      // Store CSS for shapes/textboxes
      if (d.isShape || d.isTextBox) {
        d._css = {
          width: n.css('width'),
          height: n.css('height'),
          'background-color': n.css('background-color'),
          'background-opacity': n.css('background-opacity'),
          'background-image': n.css('background-image'),
          'background-width': n.css('background-width'),
          'background-height': n.css('background-height'),
          color: n.css('color'),
          'font-size': n.css('font-size'),
          'border-width': n.css('border-width'),
          'border-color': n.css('border-color'),
          'border-opacity': n.css('border-opacity'),
        };
      }
      return d;
    }),
    edges: cy.edges().map(function(e) { return { ...e.data() }; }),
    counters: nodeCounter || {},
  };
}

function autoSaveProject() {
  if (!currentProjectId) return;
  var topoData = getCurrentTopoData();
  // Save to server (fire and forget)
  fetch('/api/projects/' + encodeURIComponent(currentProjectId) + '/topo', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(topoData)
  }).catch(function() {});
}

function autoLoadProject(projId) {
  if (!projId) return;
  currentProjectId = projId;
  // Update button with project name from server (async, non-blocking)
  updateProjectBtn();
  fetch('/api/projects/' + encodeURIComponent(projId) + '/meta')
    .then(function(r) { return r.json(); })
    .then(function(meta) {
      if (meta && meta.name && meta.name !== projId) {
        currentProjectName = meta.name;
        updateProjectBtn(); // Refresh button with real name
      } else {
        currentProjectName = null;
      }
    })
    .catch(function() { currentProjectName = null; });
  // Load topo from server
  fetch('/api/projects/' + encodeURIComponent(projId) + '/topo')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data) return;
      if (cy.nodes().length > 0) saveUndoState();
      cy.elements().remove();
      nodeCounter = data.counters || {};
      (data.nodes || []).forEach(function(n) {
        if (!n.icon && DEVICES[n.type]) n.icon = DEVICES[n.type].icon;
        if (!n.color && DEVICES[n.type]) n.color = DEVICES[n.type].color;
        var ele = cy.add({ group: 'nodes', data: n, position: n.position });
        if (n._css && (n.isShape || n.isTextBox)) {
          var css = n._css;
          if (css.width) ele.css('width', css.width);
          if (css.height) ele.css('height', css.height);
          if (css['background-color']) ele.css('background-color', css['background-color']);
          if (css['background-opacity'] !== undefined) ele.css('background-opacity', css['background-opacity']);
          if (css['background-image']) ele.css('background-image', css['background-image']);
          if (css['background-width']) ele.css('background-width', css['background-width']);
          if (css['background-height']) ele.css('background-height', css['background-height']);
          if (css.color) ele.css('color', css.color);
          if (css['font-size']) ele.css('font-size', css['font-size']);
          if (css['border-width']) ele.css('border-width', css['border-width']);
          if (css['border-color']) ele.css('border-color', css['border-color']);
          if (css['border-opacity'] !== undefined) ele.css('border-opacity', css['border-opacity']);
        }
      });
      (data.edges || []).forEach(function(e) {
        try { cy.add({ group: 'edges', data: e }); } catch(err) {}
      });
      cy.nodes('[?isShape]').lower();
      cy.nodes('[?isTextBox]').unlock();
      updateProjectBtn();
    })
    .catch(function() {});
  // Load sessions from server (replaces old chat history fetch)
  loadSessionsFromServer();
  // Load opLog from server
  fetch('/api/projects/' + encodeURIComponent(projId) + '/oplog')
    .then(function(r) { return r.json(); })
    .then(function(log) {
      if (log && log.length > 0) { opLog = log; renderOpLog && renderOpLog(); }
    })
    .catch(function() {});
}

function manageProjects() {
  var modal = document.getElementById('projectModal');
  if (_projectModalOpen) {
    refreshProjectListHighlight();
    modal.style.display = 'flex';
    document.getElementById('projNameInput').value = '';
    document.getElementById('projNameInput').focus();
    return;
  }
  _projectModalOpen = true;
  var container = document.getElementById('projectList');
  container.innerHTML = '<div class="proj-empty">加载中...</div>';
  fetch('/api/projects/')
    .then(function(r) { return r.json(); })
    .then(function(list) {
      list = list || [];
      saveProjectList(list.map(function(p) {
        return { id: p.id, name: p.name, created: p.created, savedAt: p.savedAt, nodeCount: p.nodeCount || 0, edgeCount: p.edgeCount || 0 };
      }));
      if (list.length === 0) {
        container.innerHTML = '<div class="proj-empty">暂无项目<br><br>输入名称并点击"新建"创建第一个项目</div>';
      } else {
        container.innerHTML = list.map(function(p) {
          var isActive = p.id === currentProjectId;
          return '<div class="proj-item' + (isActive ? ' active' : '') + '" onclick="switchProject(\'' + p.id + '\')">' +
            '<div class="proj-item-info">' +
              '<div class="proj-item-name">' + (isActive ? '✅ ' : '') + (p.name || p.id) + '</div>' +
              '<div class="proj-item-meta">' + (p.nodeCount || 0) + '个设备 · ' + (p.savedAt || p.created || '') + '</div>' +
            '</div>' +
            '<button class="proj-item-del" onclick="event.stopPropagation(); deleteProject(\'' + p.id + '\')">🗑️ 删除</button>' +
          '</div>';
        }).join('');
      }
    })
    .catch(function() {
      container.innerHTML = '<div class="proj-empty">加载失败，请重试</div>';
    });
  modal.style.display = 'flex';
  document.getElementById('projNameInput').value = '';
  document.getElementById('projNameInput').focus();
}

// 刷新项目列表的高亮状态（切换后调用，保持弹窗内高亮正确）
function refreshProjectListHighlight() {
  var container = document.getElementById('projectList');
  if (!container) return;
  var items = container.querySelectorAll('.proj-item');
  items.forEach(function(item) {
    // 从 onclick 里提取 project id
    var match = item.getAttribute('onclick').match(/switchProject\('([^']+)'\)/);
    if (match) {
      var isActive = match[1] === currentProjectId;
      if (isActive) {
        item.classList.add('active');
        var nameEl = item.querySelector('.proj-item-name');
        if (nameEl && !nameEl.textContent.startsWith('✅')) nameEl.textContent = '✅ ' + nameEl.textContent;
      } else {
        item.classList.remove('active');
        var nameEl = item.querySelector('.proj-item-name');
        if (nameEl) nameEl.textContent = nameEl.textContent.replace(/^✅ /, '');
      }
    }
  });
}

function closeProjectModal() {
  _projectModalOpen = false;
  document.getElementById('projectModal').style.display = 'none';
}

function createProject() {
  var name = document.getElementById('projNameInput').value.trim();
  if (!name) { toast('请输入项目名称'); return; }
  var id = 'proj-' + Date.now();
  var list = getProjectList();
  list.unshift({ id: id, name: name, savedAt: '刚刚', nodeCount: 0 });
  saveProjectList(list);
  // Set as current project
  currentProjectId = id;
  currentProjectName = name;
  localStorage.setItem('nettopo-current-proj', id);
  // Update server current project
  fetch('/api/project/current', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ projectId: id })
  }).catch(function() {});
  // Reset canvas
  hideResizeHandles();
  cy.elements().remove();
  nodeCounter = {};
  undoStack = [];
  redoStack = [];
  opLog = [];
  try { localStorage.setItem(projKey('opLog'), '[]'); } catch(e) {}
  try { localStorage.setItem(projKey('chatSessions'), '[]'); } catch(e) {}
  renderOpLog && renderOpLog();
  closeProjectModal();
  toast('✓ 已创建项目：' + name);
  renderProjectBtn();
  // Reload page to reflect fresh project state
  setTimeout(function() { window.location.href = '/?proj=' + encodeURIComponent(id) + '&t=' + Date.now(); }, 500);
}

function switchProject(id) {
  if (id === currentProjectId) {
    closeProjectModal();
    return;
  }
  var prevProj = currentProjectId;
  var prevTopo = cy.json();
  var prevTopoData = { nodes: prevTopo.nodes || [], edges: prevTopo.edges || [] };
  var list = getProjectList();
  var proj = list.find(function(p) { return p.id === id; });
  var projName = proj ? proj.name : id;

  // 立即关闭弹窗，切换按钮文字为加载状态
  closeProjectModal();
  toast('🔄 正在切换到「' + projName + '」...');

  hideResizeHandles();

  // 1. 并行保存旧项目到服务器 + 更新当前项目 ID
  var saves = [];
  if (prevProj && (prevTopoData.nodes.length > 0 || prevTopoData.edges.length > 0)) {
    saves.push(fetch('/api/topo?projectId=' + encodeURIComponent(prevProj), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(prevTopoData)
    }));
  }
  saves.push(fetch('/api/project/current', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ projectId: id })
  }));
  // 保存旧项目的 opLog
  if (prevProj) localStorage.setItem('nettopo-proj-' + prevProj + '-oplog', JSON.stringify(opLog));

  currentProjectId = id;
  localStorage.setItem('nettopo-current-proj', id);
  // 立即刷新弹窗内的项目高亮（不需要等服务器返回）
  refreshProjectListHighlight();
  opLog = [];
  try { opLog = JSON.parse(localStorage.getItem(projKey('opLog')) || '[]'); } catch(e) { opLog = []; }
  renderOpLog && renderOpLog();

  // 2. 等待所有保存完成，再加载新项目
  Promise.all(saves).then(function() {
    return fetch('/api/topo?projectId=' + encodeURIComponent(id)).then(function(r) { return r.json(); });
  }).then(function(topo) {
    cy.elements().remove();
    nodeCounter = {};
    undoStack = [];
    redoStack = [];
    if (topo && topo.nodes) topo.nodes.forEach(function(n) {
      if (!n.icon && DEVICES[n.type]) n.icon = DEVICES[n.type].icon;
      if (!n.color && DEVICES[n.type]) n.color = DEVICES[n.type].color;
      try { cy.add({ group: 'nodes', data: n, position: n.position || { x: 200, y: 200 } }); } catch(e) {}
    });
    if (topo && topo.edges) topo.edges.forEach(function(e) {
      try { cy.add({ group: 'edges', data: e }); } catch(err) {}
    });
    localStorage.setItem(getProjectTopoKey(id), JSON.stringify({ nodes: topo.nodes || [], edges: topo.edges || [], counters: nodeCounter }));
    toast('✅ 已切换到：' + projName);
    renderProjectBtn();
    console.log('[switchProject] reloading page for project:', id);
    window.location.href = '/?proj=' + encodeURIComponent(id) + '&t=' + Date.now();
  }).catch(function() {
    cy.elements().remove();
    toast('✅ 已切换到：' + projName);
    renderProjectBtn();
    console.error('[switchProject] failed to load topo, still reloading:', id);
    window.location.href = '/?proj=' + encodeURIComponent(id) + '&t=' + Date.now();
  });
}

function deleteProject(id) {
  if (!confirm('确定删除该项目？删除后无法恢复。')) return;
  var list = getProjectList().filter(function(p) { return p.id !== id; });
  saveProjectList(list);
  localStorage.removeItem(getProjectTopoKey(id));
  // Clean up project data
  localStorage.removeItem('nettopo-proj-' + id + '-chatSessions');
  localStorage.removeItem('nettopo-proj-' + id + '-currentChatSession');
  localStorage.removeItem('nettopo-proj-' + id + '-oplog');
  if (currentProjectId === id) {
    if (list.length > 0) {
      switchProject(list[0].id);
    } else {
      currentProjectId = null;
      currentProjectName = null;
      localStorage.removeItem('nettopo-current-proj');
      // 清除服务器的当前项目
      fetch('/api/project/current', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ projectId: 'default' })
      }).catch(function() {});
      cy.elements().remove();
      nodeCounter = {};
      toast('已清空画布');
      renderProjectBtn();
      setTimeout(function() { window.location.href = '/?proj=' + encodeURIComponent(id) + '&t=' + Date.now(); }, 500);
    }
  }
  manageProjects();
}

function newProject() {
  manageProjects();
  document.getElementById('projNameInput').focus();
}

function updateProjectBtn() {
  try {
    var btn = document.getElementById('btn-projects');
    if (btn) {
      btn.innerHTML = '<i class="fa-solid fa-folder-tree"></i> 选择项目';
    }
    var curBtn = document.getElementById('btn-current-proj');
    if (curBtn) {
      if (currentProjectId) {
        // Use server-fetched name if available, otherwise show ID
        var projName = currentProjectName || currentProjectId;
        curBtn.innerHTML = '<i class="fa-solid fa-folder-open"></i> 当前项目：' + projName;
        curBtn.style.background = '#dbeafe';
        curBtn.style.color = '#1e40af';
        curBtn.style.borderColor = '#bfdbfe';
        curBtn.disabled = true;
      } else {
        curBtn.innerHTML = '<i class="fa-solid fa-folder-open"></i> 未选择项目';
        curBtn.style.background = '#f3f4f6';
        curBtn.style.color = '#9ca3af';
        curBtn.style.borderColor = '#e5e7eb';
        curBtn.disabled = true;
      }
    }
  } catch(e) { console.error('updateProjectBtn error:', e); }
}
var renderProjectBtn = updateProjectBtn;  // alias for compatibility

function updateProjectMeta() {
  if (!currentProjectId) return;
  var list = getProjectList();
  var proj = list.find(function(p) { return p.id === currentProjectId; });
  if (proj) {
    proj.savedAt = new Date().toLocaleString ? new Date().toLocaleString('zh-CN') : '刚刚';
    proj.nodeCount = cy.nodes().length;
    saveProjectList(list);
  }
}

function saveTopology() {
  autoSaveProject();
  updateProjectMeta();
  // 同步到服务器（多客户端共享）
  if (cy.nodes().length > 0 && currentProjectId) {
    var data = cy.json();
    var payload = { nodes: data.nodes || [], edges: data.edges || [] };
    fetch('/api/topo?projectId=' + encodeURIComponent(currentProjectId), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d && d.status === 'ok') toast('✓ 已保存到服务器（项目：' + currentProjectId + '）');
    }).catch(function(e) { toast('❌ 服务器保存失败'); });
  } else {
    toast('✓ 已保存到当前项目');
  }
}

function loadTopology() {
  manageProjects();
}

// ============================================================
// Export / Import JSON
// ============================================================
function exportJSON() {
  if (cy.nodes().length === 0) { toast('拓扑为空'); return; }
  const data = {
    version: '1.1',
    exportedAt: new Date().toISOString(),
    nodes: cy.nodes().map(n => ({ ...n.data(), position: n.position() })),
    edges: cy.edges().map(e => ({ ...e.data() })),
    counters: nodeCounter,
  };
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'topology-' + new Date().toISOString().slice(0,10) + '.json';
  a.click();
  URL.revokeObjectURL(url);
  toast('✓ 已导出 JSON');
}

function importJSON() {
  document.getElementById('fileImport').click();
}

function handleFileImport(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(ev) {
    try {
      const data = JSON.parse(ev.target.result);
      cy.elements().remove();
      nodeCounter = data.counters || {};
      data.nodes.forEach(n => cy.add({ group: 'nodes', data: n, position: n.position }));
      data.edges.forEach(e => cy.add({ group: 'edges', data: e }));
      hideProps();
      toast('✓ 已导入（' + data.nodes.length + '个设备）');
    } catch(err) {
      toast('⚠ 导入失败：' + err.message);
    }
  };
  reader.readAsText(file);
  e.target.value = '';
}

// ============================================================
// 导入现网拓扑 / AI连接同步
// ============================================================
function importFromServer() {
  // 从服务器当前项目加载拓扑
  if (!currentProjectId) {
    toast('请先从服务器加载项目'); return;
  }
  fetch('/api/topo?projectId=' + encodeURIComponent(currentProjectId)).then(function(r) { return r.json(); }).then(function(topo) {
    if (!topo || (topo.nodes && topo.nodes.length === 0 && topo.edges && topo.edges.length === 0)) {
      toast('服务器暂无拓扑数据'); return;
    }
    cy.elements().remove();
    nodeCounter = {};
    if (topo.nodes) topo.nodes.forEach(function(n) {
      if (!n.icon && DEVICES[n.type]) n.icon = DEVICES[n.type].icon;
      if (!n.color && DEVICES[n.type]) n.color = DEVICES[n.type].color;
      try { cy.add({ group: 'nodes', data: n, position: n.position || { x: 200, y: 200 } }); } catch(e) {}
    });
    if (topo.edges) topo.edges.forEach(function(e) { try { cy.add({ group: 'edges', data: e }); } catch(err) {} });
    toast('✓ 已从服务器加载（' + cy.nodes().length + '个设备）');
  }).catch(function() { toast('⚠ 加载失败'); });
}

function syncToAI() {
  // 把当前拓扑保存到服务器，AI 就能看到最新状态
  if (cy.nodes().length === 0) { toast('拓扑为空，无需同步'); return; }
  var data = cy.json();
  var payload = { nodes: data.nodes || [], edges: data.edges || [] };
  fetch('/api/topo?projectId=' + encodeURIComponent(currentProjectId || 'default'), {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  }).then(function(r) { return r.json(); }).then(function(d) {
    if (d && d.status === 'ok') toast('✓ AI连接已同步（' + cy.nodes().length + '个设备）');
    else toast('⚠ 同步失败');
  }).catch(function() { toast('⚠ 同步失败'); });
}

// ============================================================
// Clear all
// ============================================================
function clearAll() {
  if (cy.nodes().length === 0) { toast('拓扑已为空'); return; }
  if (!confirm('确定清空所有设备？')) return;
  saveUndoState();
  var nodeCount = cy.nodes().length;
  cy.elements().remove();
  nodeCounter = {};
  hideProps();
  toast('已清空（可 Ctrl+Z 撤销）');
  addOpLog('human', '清空画布（' + nodeCount + '个设备）');
}

// ============================================================
// Toast
// ============================================================
let toastTimer = null;
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2200);
}

// ============================================================
// Double-click to edit
// ============================================================
cy.on('dbltap', 'node', function(e) {
  selectElement(e.target);
  setTimeout(() => {
    const inp = document.getElementById('p-label');
    if (inp) { inp.focus(); inp.select(); }
  }, 60);
});

// ============================================================
// Intro hint
// ============================================================
setTimeout(() => {
