(function initPaletteIcons() {
  const paletteColors = {
    router: '#60a5fa', switch: '#34d399', firewall: '#f87171',
    server: '#a78bfa', pc: '#fbbf24', cloud: '#67e8f9',
    router_advanced: '#a78bfa', router_core: '#818cf8',
    switch_core: '#818cf8', switch_access: '#34d399',
  };
  Object.keys(SVG).forEach(type => {
    const el = document.getElementById('icon-' + type);
    const el2 = document.getElementById('icon-' + type + '0');
    [el, el2].forEach(el => {
      if (!el) return;
      const color = paletteColors[type] || '#888';
      const html = SVG[type].replace(/CURRENT_COLOR/g, color);
      el.innerHTML = html;
      el.style.width = '32px';
      el.style.height = '32px';
      el.style.display = 'flex';
      el.style.alignItems = 'center';
      el.style.justifyContent = 'center';
    });
  });
})();

// ============================================================
// AI Analysis
// ============================================================
let aiPollTimer = null;

// ---- LLM 设置 ----

function requestAIAnalysis() {
  if (cy.nodes().length === 0) {
    toast('⚠ 请先添加至少一个设备');
    return;
  }

  const data = {
    version: '1.1',
    analyzedAt: new Date().toISOString(),
    nodes: cy.nodes().map(n => ({ ...n.data() })),
    edges: cy.edges().map(e => ({ ...e.data() })),
    summary: {
      deviceCount: cy.nodes().length,
      connectionCount: cy.edges().length,
      deviceTypes: Object.fromEntries(
        [...cy.nodes()].reduce((acc, n) => {
          const t = n.data('type');
          acc[t] = (acc[t] || 0) + 1;
          return acc;
        }, {})
      )
    }
  };

  // Show modal
  const modal = document.getElementById('aiModal');
  const resultDiv = document.getElementById('aiResult');
  const statusDiv = document.getElementById('aiStatus');
  modal.style.display = 'flex';
  resultDiv.textContent = '';
  statusDiv.textContent = '⏳ 正在发送拓扑数据...';

  // Send to backend
  fetch('/api/topology', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  }).then(r => r.json()).then(() => {
    statusDiv.textContent = '✅ 拓扑已发送，等待 AI 分析结果...';
    resultDiv.textContent = '⏳ AI 正在分析拓扑，请稍候...\n\n（后台已通知 AI Agent，请注意这里会自动显示结果）';
    startPolling();
  }).catch(err => {
    statusDiv.textContent = '❌ 发送失败';
    resultDiv.textContent = '发送失败：' + err.message + '\n\n可能原因：后端服务未启动。\n\n请确保已启动：\npython3 server.py';
  });
}

function startPolling() {
  if (aiPollTimer) clearInterval(aiPollTimer);
  aiPollTimer = setInterval(() => {
    fetch('/api/pending')
      .then(r => r.json())
      .then(data => {
        if (!data.pending && data.hasResult) {
          clearInterval(aiPollTimer);
          aiPollTimer = null;
          document.getElementById('aiStatus').textContent = '✅ 分析完成';
          loadAnalysisResult();
        }
      })
      .catch(() => {});
  }, 3000);
}

function loadAnalysisResult() {
  fetch('/api/analysis-result')
    .then(r => r.json())
    .then(data => {
      const resultDiv = document.getElementById('aiResult');
      const statusDiv = document.getElementById('aiStatus');
      if (data.result) {
        resultDiv.textContent = data.result;
        statusDiv.textContent = '✅ 完成';
      } else if (!data.pending) {
        resultDiv.textContent = '⏳ AI 正在处理中，请稍候...\n\n（AI Agent 收到请求后会在这里显示分析结果）';
      }
    })
    .catch(() => {});
}

function closeAIModal() {
  document.getElementById('aiModal').style.display = 'none';
  if (aiPollTimer) { clearInterval(aiPollTimer); aiPollTimer = null; }
}

// AI modal polling removed - only poll when explicitly needed

// ============================================================
// Chat Panel
// ============================================================
let chatOpen = false;
let chatPollTimer = null;
let chatWelcomed = false;
let chatPanelMinW = 250;
let chatPanelMaxW = 800;
let chatPanelCurW = parseInt(localStorage.getItem('chatPanelW') || '300');
let sessionListCollapsed = localStorage.getItem('sessionListCollapsed') === '1';
let resizingChatH = false, resizeStartYH = 0, resizeStartHH = 0;
let chatPanelMinH = 200;
let chatPanelMaxH = 800;
let chatPanelCurH = parseInt(localStorage.getItem('chatPanelH') || '600');
let resizingChat = false, resizeStartX = 0, resizeStartY = 0, resizeStartW = 0, resizeStartH = 0;
let chatAutoScroll = true; // auto-scroll to bottom unless user scrolled up
let chatUserAtBottom = true; // tracks if user is at bottom of chat
// Draggable floating panel
let chatDragging = false, chatDragOffX = 0, chatDragOffY = 0;
var chatPanelPos = JSON.parse(localStorage.getItem('chatPanelPos') || 'null');
// Restore saved panel position
;(function restorePanelPos() {
  if (!chatPanelPos) return;
  var cp = document.getElementById('chatPanel');
  if (!cp) return;
  cp.style.left = chatPanelPos.left + 'px';
  cp.style.top = chatPanelPos.top + 'px';
  cp.style.right = 'auto';
  cp.style.bottom = 'auto';
  cp.style.position = 'fixed';
})();


function applyPanelSize() {
  var panel = document.getElementById('chatPanel');
  panel.style.width = chatPanelCurW + 'px';
  panel.style.height = chatPanelCurH + 'px';
  panel.style.left = '-' + chatPanelCurW + 'px';
  panel.classList.remove('open');
  // Apply session list collapsed state
  if (sessionListCollapsed) {
    var list = document.getElementById('chatSessionList');
    var btn = document.getElementById('sessionListToggleBtn');
    if (list) { list.style.width = '0'; list.style.overflow = 'hidden'; }
    if (btn) btn.textContent = '»';
  }
}

// Restore saved size on load
var _panel = document.getElementById('chatPanel');
if (_panel) {
  applyPanelSize();
}

// Draggable chat panel - drag by header
function startChatDrag(e) {
  if (e.button !== 0) return;
  e.preventDefault();
  e.stopPropagation();
  chatDragging = true;
  var cp = document.getElementById('chatPanel');
  // Remove transition during drag for smooth feel
  cp.style.transition = 'none';
  chatDragOffX = e.clientX - cp.offsetLeft;
  chatDragOffY = e.clientY - cp.offsetTop;
  // Switch to fixed/floating mode
  cp.style.position = 'fixed';
  cp.style.left = cp.offsetLeft + 'px';
  cp.style.top = cp.offsetTop + 'px';
  cp.style.right = 'auto';
  cp.style.bottom = 'auto';
  document.addEventListener('mousemove', onChatDrag, { passive: true });
  document.addEventListener('mouseup', stopChatDrag);
}
function onChatDrag(e) {
  if (!chatDragging) return;
  e.preventDefault();
  var cp = document.getElementById('chatPanel');
  var newLeft = e.clientX - chatDragOffX;
  var newTop = e.clientY - chatDragOffY;
  // Clamp to viewport
  newLeft = Math.max(0, Math.min(newLeft, window.innerWidth - 100));
  newTop = Math.max(0, Math.min(newTop, window.innerHeight - 40));
  cp.style.left = newLeft + 'px';
  cp.style.top = newTop + 'px';
}
function requestTick(fn) {
  if (!window.__chatDragTick) {
    window.__chatDragTick = true;
    requestAnimationFrame(function() {
      fn();
      window.__chatDragTick = false;
    });
  }
}
function stopChatDrag() {
  if (!chatDragging) return;
  chatDragging = false;
  document.removeEventListener('mousemove', onChatDrag);
  document.removeEventListener('mouseup', stopChatDrag);
  // Restore transition for smooth feel
  var cp = document.getElementById('chatPanel');
  cp.style.transition = '';
  chatPanelPos = { left: cp.offsetLeft, top: cp.offsetTop };
  localStorage.setItem('chatPanelPos', JSON.stringify(chatPanelPos));
}
// Reset panel to sidebar mode (double-click header)
function resetChatPanelPos() {
  var cp = document.getElementById('chatPanel');
  cp.style.position = '';
  cp.style.left = '';
  cp.style.top = '';
  cp.style.right = '';
  cp.style.bottom = '';
  chatPanelPos = null;
  localStorage.removeItem('chatPanelPos');
}

function startChatResizeH(e) {
  resizingChatH = true;
  resizeStartYH = e.clientY;
  resizeStartHH = document.getElementById('chatPanel').offsetHeight;
  document.body.style.cursor = 'ns-resize';
  document.body.style.userSelect = 'none';
  e.preventDefault();
  e.stopPropagation();
}

function startChatResizeV(e) {
  resizingChat = true;
  resizeStartX = e.clientX;
  resizeStartY = e.clientY;
  resizeStartW = document.getElementById('chatPanel').offsetWidth;
  resizeStartH = document.getElementById('chatPanel').offsetHeight;
  document.body.style.cursor = 'ew-resize';
  document.body.style.userSelect = 'none';
  e.preventDefault();
  e.stopPropagation();
}

document.addEventListener('mousemove', function(e) {
  if (resizingChatH) {
    const dy = e.clientY - resizeStartYH;
    var newH = Math.min(chatPanelMaxH, Math.max(chatPanelMinH, resizeStartHH + dy));
    document.getElementById('chatPanel').style.height = newH + 'px';
    chatPanelCurH = newH;
    localStorage.setItem('chatPanelH', newH);
    return;
  }
  if (!resizingChat) return;
  const dx = e.clientX - resizeStartX;
  const dy = e.clientY - resizeStartY;
  // Horizontal drag = width
  var newW = Math.min(chatPanelMaxW, Math.max(chatPanelMinW, resizeStartW + dx));
  // Vertical drag = height
  var newH = Math.min(chatPanelMaxH, Math.max(chatPanelMinH, resizeStartH + dy));
  document.getElementById('chatPanel').style.width = newW + 'px';
  document.getElementById('chatPanel').style.height = newH + 'px';
  chatPanelCurW = newW;
  chatPanelCurH = newH;
});

document.addEventListener('mouseup', function() {
  if (resizingChatH) {
    resizingChatH = false;
    document.body.style.cursor = '';
    document.body.style.userSelect = '';
    localStorage.setItem('chatPanelH', chatPanelCurH);
  }
  if (resizingChat) {
    resizingChat = false;
    document.body.style.cursor = '';
    document.body.style.userSelect = '';
    localStorage.setItem('chatPanelW', chatPanelCurW);
    localStorage.setItem('chatPanelH', chatPanelCurH);
  }
});

function toggleSessionList() {
  sessionListCollapsed = !sessionListCollapsed;
  localStorage.setItem('sessionListCollapsed', sessionListCollapsed ? '1' : '0');
  var list = document.getElementById('chatSessionList');
  var btn = document.getElementById('sessionListToggleBtn');
  if (list) {
    list.style.flexBasis = sessionListCollapsed ? '0px' : '100px';
    list.style.overflow = sessionListCollapsed ? 'hidden' : 'auto';
    list.style.flexGrow = sessionListCollapsed ? '0' : '1';
  }
  if (btn) btn.textContent = sessionListCollapsed ? '»' : '☰';
}

function toggleChat() {
  chatOpen = !chatOpen;
  const panel = document.getElementById('chatPanel');
  const btn = document.getElementById('chatToggle');
  if (chatOpen) {
    applyPanelSize();
    panel.style.left = '0';
    panel.classList.add('open');
    btn.style.display = 'none';
    // Ensure currentSessionId is set before loading messages
    if (!currentSessionId) {
      var lastId = localStorage.getItem(projKey('currentChatSession'));
      var sessions = window.__sessions__ || [];
      currentSessionId = sessions.find(function(s) { return s.id === lastId; }) ? lastId : (sessions[0] ? sessions[0].id : null);
    }
    loadChatMessages();
    startChatPoll();
    if (!chatWelcomed) {
      chatWelcomed = true;
      setTimeout(() => {
        addChatBubble('ai', '你好！我是网络拓扑助手 🤖\n\n你可以：\n• 画完拓扑后直接发给我分析\n• 问我网络配置问题\n• 让我检查拓扑合理性\n\n在下方输入问题，我会结合你的拓扑图给出建议。', new Date().toLocaleTimeString('zh-CN',{hour:'2-digit',minute:'2-digit'}));
      }, 300);
    }
  } else {
    panel.style.left = '-' + chatPanelCurW + 'px';
    panel.classList.remove('open');
    btn.style.display = 'flex';
    if (chatPollTimer) { clearInterval(chatPollTimer); chatPollTimer = null; }
  }
}

function addChatBubble(role, text, ts, ops) {
  const empty = document.getElementById('chatEmpty');
  if (empty) empty.style.display = 'none';

  const msgs = document.getElementById('chatMessages');
  const div = document.createElement('div');
  div.className = 'chat-msg ' + role;
  const label = role === 'ai' ? '🤖 拓扑专家' : '👤 你';
  div.innerHTML = '<div class="chat-msg-label">' + label + '</div>' + escHtml(text) + '<span class="ts">' + escHtml(ts || '') + '</span>';
  msgs.appendChild(div);

  // Render operation suggestions below the AI bubble
  if (ops && ops.length > 0) {
    const opsDiv = document.createElement('div');
    opsDiv.innerHTML = renderOpsCard(ops);
    opsDiv.dataset.ops = JSON.stringify(ops);
    msgs.appendChild(opsDiv);
    // Attach listeners immediately (no setTimeout race)
    var execBtn = document.getElementById('ops-execute-btn');
    var dismissBtn = document.getElementById('ops-dismiss-btn');
    if (execBtn) { execBtn.addEventListener('click', function() { executeTopoOps(ops); }); }
    if (dismissBtn) { dismissBtn.addEventListener('click', dismissTopoOps); }
  }

  if (chatUserAtBottom) msgs.scrollTop = msgs.scrollHeight;
  var btn = document.getElementById('scrollToBottomBtn');
  if (btn) btn.style.display = chatUserAtBottom ? 'none' : 'block';

  // Save to current session (without ops HTML)
  pushMessage(role, text, ops);
}

function showTypingIndicator() {
  const empty = document.getElementById('chatEmpty');
  if (empty) empty.style.display = 'none';
  const msgs = document.getElementById('chatMessages');
  const div = document.createElement('div');
  div.className = 'chat-msg ai';
  div.id = 'chat-typing';
  div.innerHTML = '<div class="chat-msg-label">🤖 拓扑专家</div><div class="chat-typing"><span></span><span></span><span></span></div>';
  msgs.appendChild(div);
  if (chatUserAtBottom) msgs.scrollTop = msgs.scrollHeight;
}

function removeTypingIndicator() {
  const el = document.getElementById('chat-typing');
  if (el) el.remove();
}

function parseOpsFromText(text) {
  if (!text) return [];
  var ops = [];
  if (!text) return ops;
  // Normalize: replace <br> and other HTML tags with newlines, strip HTML tags
  text = text.replace(/<br\s*\/?>/gi, '\n').replace(/<[^>]+>/g, ' ').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&amp;/g, '&').replace(/&nbsp;/g, ' ');
  // Strip backticks and code blocks
  text = text.replace(/`([^`\n]+?)`/g, '$1').replace(/```[\s\S]*?```/g, '');
  // Find all [op] blocks — handle newlines between op blocks
  var matches = [];
  // Replace newlines with spaces within op blocks, split op blocks by [op] marker
  var normalized = text.replace(/\n+/g, ' ');
  var re = /\[op\]([\s\S]*?)(?=\[op\]|$)/g;
  var match;
  while ((match = re.exec(normalized)) !== null) {
    matches.push(match[1].trim());
  }
  // Also find bare [type=...] format (AI-generated without [op] prefix)
  var bareRe = /\[type=([^\]]+)\]/g;
  while ((match = bareRe.exec(normalized)) !== null) {
    matches.push(('add: ' + match[1]).trim());
  }
  for (var i = 0; i < matches.length; i++) {
    var line = matches[i]; // e.g. "add: type=router, x=150, y=150, id=R1"
    // Try colon format: "add: type=router, x=100"
    var m = line.match(/^(\w+)[:：]\s*(.+)/);
    // Fallback: space format "add type=router x=100" (no colon)
    if (!m) m = line.match(/^(\w+)\s+(.+)/);
    if (!m) continue;
    var action = m[1].trim().toLowerCase();
    var paramsStr = m[2] || '';
    var params = {};
    // Support both comma and space separated params
    // First try = format
    var pairs = paramsStr.split(/[，,]/); // split by comma (Chinese or English)
    for (var j = 0; j < pairs.length; j++) {
      var pair = pairs[j].trim();
      var eqIdx = pair.indexOf('=');
      var coIdx = pair.indexOf(':');
      if (eqIdx > 0) {
        var k = pair.slice(0, eqIdx).trim();
        var v = pair.slice(eqIdx + 1).trim().replace(/^[\s]+|[\s]+$/g, '');
        if (k && v) params[k] = v;
      } else if (coIdx > 0) {
        var k = pair.slice(0, coIdx).trim();
        var v = pair.slice(coIdx + 1).trim().replace(/^[\s]+|[\s]+$/g, '');
        if (k && v) params[k] = v;
      }
    }
    // If no = or : found, try space-separated: "type router x 100 y 200"
    if (Object.keys(params).length === 0) {
      var tokens = paramsStr.split(/\s+/);
      for (var t = 0; t < tokens.length - 1; t += 2) {
        var k = tokens[t].trim();
        var v = tokens[t + 1] ? tokens[t + 1].trim() : '';
        if (k && v && /^[a-zA-Z_]/.test(k)) params[k] = v;
      }
    }
    if (action === 'add') {
      ops.push({
        action: 'add',
        type: params.type || 'switch',
        id: params.id || null,
        x: params.x ? parseInt(params.x) : 200,
        y: params.y ? parseInt(params.y) : 200,
        label: params.label || params.id || null
      });
    } else if (action === 'delete') {
      ops.push({ action: 'delete', id: params.id || params.name || params.label || '' });
    } else if (action === 'connect' || action === 'add_edge') {
      ops.push({ action: 'add_edge', from: params.from || params.src || '', to: params.to || params.dst || params.target || '', srcPort: params.src_port || '', tgtPort: params.tgt_port || '' });
    } else if (action === 'remove_edge') {
      ops.push({ action: 'remove_edge', from: params.from || params.src || '', to: params.to || params.dst || params.target || '' });
    } else if (action === 'update_edge') {
      ops.push({ action: 'update_edge', from: params.from || '', to: params.to || '', src_port: params.src_port || '', tgt_port: params.tgt_port || '', bandwidth: params.bandwidth || '' });
    } else if (action === 'move') {
      ops.push({ action: 'move_node', id: params.id || '', x: params.x ? parseInt(params.x) : 200, y: params.y ? parseInt(params.y) : 200 });
    } else if (action === 'rename') {
      ops.push({ action: 'rename', from: params.from || '', to: params.to || '' });
    } else if (action === 'update' || action === 'update_node') {
      ops.push({ action: 'update_node', id: params.id || '', label: params.label || '', ip: params.ip || '', mac: params.mac || '', desc: params.desc || '', port: params.port || '', bandwidth: params.bandwidth || '' });
    }
  }
  return ops;
}

function escHtml(s) {
  if (s == null) return '';
  return String(s).replace(/&/g,'&amp;').replace(/'/g,'&#39;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>');
}

function getTopologySummary() {
  if (!document.getElementById('chatWithTopo').checked) return null;
  // Build a map of which ports are already used on each node
  var nodePorts = {};
  cy.edges().forEach(function(e) {
    var src = e.source().id(), tgt = e.target().id();
    var sp = e.data('srcPort'), tp = e.data('tgtPort');
    if (!nodePorts[src]) nodePorts[src] = [];
    if (!nodePorts[tgt]) nodePorts[tgt] = [];
    if (sp) nodePorts[src].push(sp);
    if (tp) nodePorts[tgt].push(tp);
  });
  // Standard port naming per device type
  var PORT_CONVENTIONS = {
    router: ['GE0/0/0','GE0/0/1','GE0/0/2','GE0/0/3','GE0/1/0','GE0/1/1','ETH0','ETH1'],
    switch: ['GE0/0/1','GE0/0/2','GE0/0/3','GE0/0/4','GE0/0/5','GE0/0/6','GE0/0/7','GE0/0/8',
             'GE0/0/9','GE0/0/10','GE0/0/11','GE0/0/12','GE0/0/13','GE0/0/14','GE0/0/15','GE0/0/16',
             'GE0/0/17','GE0/0/18','GE0/0/19','GE0/0/20','GE0/0/21','GE0/0/22','GE0/0/23','GE0/0/24',
             '10GE0/0/1','10GE0/0/2','10GE0/0/3','10GE0/0/4'],
    firewall: ['GE0/0/0','GE0/0/1','GE0/0/2','GE0/0/3','GE0/0/4','GE0/0/5','GE0/0/6','GE0/0/7'],
    server: ['ETH0','ETH1','ETH2','ETH3'],
    cloud: [],
    internet: []
  };
  return {
    version: '1.3',
    deviceCount: cy.nodes().length,
    connectionCount: cy.edges().length,
    portConventions: PORT_CONVENTIONS,
    nodes: cy.nodes().map(function(n) {
      var nType = n.data('type') || 'switch';
      var used = nodePorts[n.id()] || [];
      var allPorts = PORT_CONVENTIONS[nType] || PORT_CONVENTIONS.switch;
      var available = allPorts.filter(function(p) { return used.indexOf(p) < 0; });
      return {
        id: n.id(),
        type: nType,
        label: n.data('label'),
        ip: n.data('ip') || '',
        mac: n.data('mac') || '',
        desc: n.data('desc') || '',
        port: n.data('port') || '',
        bandwidth: n.data('bandwidth') || '',
        usedPorts: used,
        availablePorts: available,
        allPorts: allPorts,
        x: Math.round(n.position().x),
        y: Math.round(n.position().y)
      };
    }),
    edges: cy.edges().map(function(e) {
      var s = e.source(), t = e.target();
      return {
        from: s.id(),
        fromLabel: s.data('label'),
        to: t.id(),
        toLabel: t.data('label'),
        fromType: s.data('type'),
        toType: t.data('type'),
        fromIp: s.data('ip') || '',
        toIp: t.data('ip') || '',
        srcPort: e.data('srcPort') || '',
        tgtPort: e.data('tgtPort') || '',
        bandwidth: e.data('bandwidth') || ''
      };
    })
  };
}

var currentAttachment = null; // { name, content, size }

function handleChatFileUpload(input) {
  var file = input.files[0];
  if (!file) return;
  var maxSize = 2 * 1024 * 1024; // 2MB
  if (file.size > maxSize) {
    toast('文件过大，请上传小于 2MB 的文档');
    input.value = '';
    return;
  }
  var reader = new FileReader();
  reader.onload = function(e) {
    var content = e.target.result;
    // Truncate if too large (100KB limit for LLM context)
    var maxChars = 100000;
    if (content.length > maxChars) {
      content = content.substring(0, maxChars) + '\n[......文档过长，已截断]';
      toast('文档过长，已截断前10万字符', 3000);
    }
    currentAttachment = { name: file.name, content: content, size: file.size };
    var info = document.getElementById('chatAttachmentInfo');
    info.style.display = 'block';
    info.innerHTML = '📎 已附加：' + escHtml(file.name) + ' (' + Math.round(file.size/1024) + 'KB) <span onclick="clearChatAttachment()" style="cursor:pointer;color:#ef4444;margin-left:6px;">✕</span>';
    input.value = '';
    document.getElementById('chatInput').focus();
  };
  reader.onerror = function() { toast('文件读取失败'); };
  reader.readAsText(file);
}

function clearChatAttachment() {
  currentAttachment = null;
  document.getElementById('chatAttachmentInfo').style.display = 'none';
}

function sendChat() {
  const input = document.getElementById('chatInput');
  var text = input.value.trim();
  if (!text && !currentAttachment) return; // allow attachment-only messages
  // Ensure we have a session ID before sending
  if (!currentSessionId) {
    // Try to use last saved session from localStorage
    var lastId = localStorage.getItem(projKey('currentChatSession'));
    var sessions = window.__sessions__ || [];
    var found = sessions.find(function(s) { return s.id === lastId; });
    if (found) {
      currentSessionId = found.id;
    } else if (sessions.length > 0) {
      currentSessionId = sessions[0].id;
    } else {
      // No sessions exist — create one synchronously won't work (async API),
      // but at least guard against null ID
      currentSessionId = 'default';
    }
  }

  const ts = new Date().toLocaleTimeString('zh-CN', {hour:'2-digit',minute:'2-digit'});
  var displayText = text || (currentAttachment ? '[上传文档：' + currentAttachment.name + ']' : '');
  addChatBubble('user', displayText, ts);
  chatUserAtBottom = true; // user sent message, they're watching
  input.value = '';

  const btn = document.getElementById('chatSendBtn');
  btn.disabled = true;

  const topo = getTopologySummary();
  const withTopo = document.getElementById('chatWithTopo').checked;

  // Send last 20 chat messages as conversation history for context
  var sess = getSessions().find(function(s) { return s.id === currentSessionId; });
  var history = [];
  if (sess && sess.messages) {
    var msgs = sess.messages.slice(-20); // last 20 messages
    msgs.forEach(function(m) {
      if (m.role && m.text) {
        history.push({ role: m.role, content: m.text });
      }
    });
  }

  var attachment = currentAttachment;
  if (attachment) {
    clearChatAttachment(); // clear after attaching
  }
  const payload = { text, topology: topo, withTopo: withTopo, timestamp: new Date().toISOString(), history: history, attachment: attachment ? attachment.content : null, attachmentName: attachment ? attachment.name : null };

  // Show AI thinking animation
  showTypingIndicator();

  fetch('/api/chat/send', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(Object.assign(payload, { sessionId: currentSessionId, projectId: currentProjectId }))
  }).then(r => r.json()).then(data => {
    removeTypingIndicator();
    btn.disabled = false;
    var reply = data.reply || '（无响应）';
    var ops = data.operations || parseOpsFromText(reply);
    addChatBubble('ai', reply, ts, ops);
    // Save AI message to server (with ops encoded for persistence across reloads)
    if (ops && ops.length > 0) {
      // Encode ops in message content so it survives server round-trip
      var opsMarker = '__OPS__' + JSON.stringify(ops) + '__OPS__';
      var fullContent = reply + '\n' + opsMarker;
      fetch(sessionApi('/' + encodeURIComponent(currentSessionId) + '/messages'), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ role: 'ai', content: fullContent, ts: ts })
      }).catch(function() {});
    } else {
      fetch(sessionApi('/' + encodeURIComponent(currentSessionId) + '/messages'), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ role: 'ai', content: reply, ts: ts })
      }).catch(function() {});
    }
  }).catch(err => {
    removeTypingIndicator();
    btn.disabled = false;
    addChatBubble('ai', '发送失败：' + err.message, ts);
  });
}

// ============================================================
// Multi-session chat management
// ============================================================
var currentSessionId = null;

// Per-project data keys
// Server-based session key (project-aware, server-side storage)
function projKey(suffix) {
  return 'nettopo-proj-' + (currentProjectId || 'default') + '-' + suffix;
}
// Server session API base (uses currentProjectId)
function sessionApi(suffix) {
  return '/api/projects/' + encodeURIComponent(currentProjectId || 'default') + '/sessions' + suffix;
}

function newChatSession(name) {
  // Default session name if not provided
  var existing = (window.__sessions__ || []).filter(function(s) { return s.name && s.name.startsWith('会话'); });
  var seq = existing.length + 1;
  var sessName = name || ('会话' + seq);
  fetch(sessionApi(''), {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name: sessName })
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.id) {
      switchToSession(data.id);
      // New empty session: scroll to bottom so user sees the input area
      setTimeout(function() {
        var msgsEl = document.getElementById('chatMessages');
        if (msgsEl) { msgsEl.scrollTop = msgsEl.scrollHeight; chatUserAtBottom = true; }
      }, 150);
      loadSessionsFromServer(); // Refresh session list
    }
  }).catch(function() { toast('创建会话失败', 'error'); });
}

function getSessions() {
  return []; // Sessions are now server-side, use loadSessionsFromServer()
}
// Synchronous version - returns empty, real data loaded async
function saveSessions(s) { /* no-op: now server-side */ }

function switchToSession(id) {
  console.log('[switchToSession]', id);
  currentSessionId = id;
  renderSessionList();
  // Load messages from server session (don't auto-scroll — user chose this session)
  loadSessionMessages(id, false);
}

// Load session list from server
var _chatInitialized = false; // track if we've done the initial session restore
function loadSessionsFromServer() {
  fetch(sessionApi(''))
    .then(function(r) { return r.json(); })
    .then(function(sessions) {
      console.log('[loadSessionsFromServer] called, _chatInitialized=', _chatInitialized, 'currentSessionId=', currentSessionId, 'sessions=', (sessions||[]).length);
      // Store in memory for render
      window.__sessions__ = sessions || [];
      // Server creates default session on project creation; just render
      // No auto-create needed (server handles it)
      // Restore last active session ONLY on first load (page refresh / project switch)
      // Guard: if user has already switched sessions manually, DON'T override currentSessionId
      var lastId = localStorage.getItem(projKey('currentChatSession'));
      if (!_chatInitialized) {
        _chatInitialized = true;
        // Only auto-select if no session has been manually chosen yet
        var active = sessions.find(function(s) { return s.id === lastId; }) || sessions[0];
        if (!currentSessionId) {
          currentSessionId = active.id;
          renderSessionList();
          loadSessionMessages(active.id, true); // scroll to bottom on startup
        } else {
          // User already switched sessions before this response arrived — don't override
          renderSessionList();
        }
      } else {
        // Subsequent calls (e.g. after create/delete): just re-render list, keep current session
        renderSessionList();
      }
    }).catch(function() {});
}

function renderSessionList() {
  var wrap = document.getElementById('chatSessionListWrap');
  if (!wrap) return;
  var sessions = window.__sessions__ || [];
  var html = '<button class="chat-session-new" onclick="newChatSession()">+ 新建会话</button>';
  sessions.forEach(function(s) {
    var active = s.id === currentSessionId ? ' active' : '';
    html += '<div class="chat-session-item' + active + '" onclick="switchToSession(\'' + s.id + '\')">' +
      '<span class="sname">' + escHtml(s.name) + '</span>' +
      '<span class="sdel" onclick="event.stopPropagation();delSession(\'' + s.id + '\')">×</span>' +
      '<div class="chat-session-date">' + s.date + '</div></div>';
  });
  wrap.innerHTML = html;
}

function delSession(id) {
  showChatConfirm('删除该会话？此操作不可恢复。', function() {
    fetch(sessionApi('/' + encodeURIComponent(id)), { method: 'DELETE' })
      .then(function() {
        if (currentSessionId === id) {
          currentSessionId = null;
          newChatSession();
        }
        loadSessionsFromServer();
      }).catch(function() { toast('删除会话失败', 'error'); });
  });
}
function renderSessionMessages() {
  var msgs = document.getElementById('chatMessages');
  if (!msgs) return;
  msgs.innerHTML = '';
  var sessions = getSessions();
  var sess = sessions.find(function(s) { return s.id === currentSessionId; });
  if (!sess) { newChatSession(); return; }
  if (sess.messages && sess.messages.length > 0) {
    sess.messages.forEach(function(m) {
      var div = document.createElement('div');
      div.className = 'chat-msg ' + m.role;
      div.innerHTML = escHtml(m.text) + '<span class="ts"></span>';
      msgs.appendChild(div);
    });
  }
  var empty = document.getElementById('chatEmpty');
  if (empty) empty.style.display = (!sess.messages || sess.messages.length === 0) ? 'flex' : 'none';
  // Always scroll to bottom on session switch
  var msgsEl = document.getElementById('chatMessages');
  if (msgsEl) msgsEl.scrollTop = msgsEl.scrollHeight;
  chatUserAtBottom = true; // switching session = at bottom
}

function pushMessage(role, text, ops) {
  var sessions = getSessions();
  var sess = sessions.find(function(s) { return s.id === currentSessionId; });
  if (sess) {
    if (!sess.messages) sess.messages = [];
    sess.messages.push({ role: role, text: text, ops: ops || null });
    saveSessions(sessions);
  }
}

function clearCurrentSession() {
  showChatConfirm('删除当前会话？所有记录将被清除。', function() {
    delSession(currentSessionId);
  });
}

// Init sessions on load
function attachChatScrollListener() {
  var msgs = document.getElementById('chatMessages');
  if (!msgs) return;
  // Remove old listener to avoid duplicates
  msgs.removeEventListener('scroll', onChatScroll);
  msgs.addEventListener('scroll', onChatScroll);
}
function onChatScroll() {
  var msgs = document.getElementById('chatMessages');
  if (!msgs) return;
  var atBottom = msgs.scrollHeight - msgs.scrollTop - msgs.clientHeight < 60;
  chatUserAtBottom = atBottom;
  var btn = document.getElementById('scrollToBottomBtn');
  if (btn) btn.style.display = atBottom ? 'none' : 'block';
}
function scrollChatToBottom() {
  var msgs = document.getElementById('chatMessages');
  if (msgs) { msgs.scrollTop = msgs.scrollHeight; chatUserAtBottom = true; }
}
function initChatSessions() {
  // Sessions loaded asynchronously via loadSessionsFromServer
  // This just sets up the UI; session switching happens after load completes
  renderSessionList();
  attachChatScrollListener();
  chatUserAtBottom = true;
}

// ============================================================
// Chat confirm modal
// ============================================================
var _chatConfirmCallback = null;
function showChatConfirm(msg, onOk) {
  _chatConfirmCallback = onOk;
  document.getElementById('chatConfirmMsg').textContent = msg;
  document.getElementById('chatConfirmOverlay').classList.add('show');
  document.getElementById('chatConfirmModal').classList.add('show');
}
function hideChatConfirm() {
  document.getElementById('chatConfirmOverlay').classList.remove('show');
  document.getElementById('chatConfirmModal').classList.remove('show');
  _chatConfirmCallback = null;
}
document.getElementById('chatConfirmOk').onclick = function() {
  var cb = _chatConfirmCallback;
  hideChatConfirm();
  if (cb) cb();
};

function saveChatMemory() {
  const msgs = document.getElementById('chatMessages');
  if (!msgs) return;
  const bubbles = msgs.querySelectorAll('.chat-msg');
  if (bubbles.length === 0) { toast('暂无消息可保存'); return; }
  var content = '';
  bubbles.forEach(function(b) {
    var role = b.classList.contains('user') ? '用户' : 'AI';
    var text = b.innerText || '';
    content += role + '：' + text + '\n\n';
  });
  var label = prompt('为此记忆起个名字（如"网络排错-03-26"）：', '记忆-' + new Date().toLocaleDateString('zh-CN'));
  if (!label) return;
  var saved = JSON.parse(localStorage.getItem('chatMemories') || '[]');
  saved.unshift({ label: label, content: content, date: new Date().toLocaleString('zh-CN') });
  if (saved.length > 20) saved = saved.slice(0, 20);
  localStorage.setItem('chatMemories', JSON.stringify(saved));
  toast('✓ 记忆已保存：' + label);
}

function showChatMemories() {
  const msgs = document.getElementById('chatMessages');
  if (!msgs) return;
  const saved = JSON.parse(localStorage.getItem('chatMemories') || '[]');
  var html = '<div style="padding:8px 0 12px;font-weight:600;font-size:13px;color:#374151;border-bottom:1px solid #e5e7eb;margin-bottom:8px;">📋 记忆库（点击加载）</div>';
  if (saved.length === 0) {
    html += '<div style="color:#9ca3af;font-size:12px;text-align:center;padding:20px;">暂无保存的记忆</div>';
  } else {
    saved.forEach(function(m, i) {
      html += '<div class="mem-item" onclick="loadChatMemory(' + i + ')">' +
        '<span class="mem-del" onclick="event.stopPropagation();delChatMemory(' + i + ')">×</span>' +
        '<div>' + escHtml(m.label) + '</div>' +
        '<div class="mem-date">' + m.date + '</div>' +
        '<div style="font-size:11px;color:#6b7280;margin-top:3px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">' +
        escHtml(m.content.substring(0, 60)) + '</div></div>';
    });
  }
  html += '<div style="padding:8px 0;font-size:11px;color:#9ca3af;text-align:center;">点击记忆自动加载，清除消息后可重新开始</div>';
  msgs.innerHTML = '<div class="chat-memories" style="flex:1;overflow-y:auto;padding:12px;">' + html + '</div>';
  msgs.scrollTop = 0;
}

function loadChatMemory(idx) {
  var saved = JSON.parse(localStorage.getItem('chatMemories') || '[]');
  var m = saved[idx];
  if (!m) return;
  const msgs = document.getElementById('chatMessages');
  msgs.innerHTML = '';
  var lines = m.content.split('\n\n');
  lines.forEach(function(line) {
    if (!line.trim()) return;
    var isUser = line.indexOf('用户：') === 0;
    var text = line.replace(/^(用户|AI)：/, '');
    addChatBubble(isUser ? 'user' : 'ai', text, '');
  });
  addChatBubble('ai', '已加载记忆「' + m.label + '」，继续提问吧。', new Date().toLocaleTimeString('zh-CN',{hour:'2-digit',minute:'2-digit'}));
}

function delChatMemory(idx) {
  var saved = JSON.parse(localStorage.getItem('chatMemories') || '[]');
  saved.splice(idx, 1);
  localStorage.setItem('chatMemories', JSON.stringify(saved));
  showChatMemories();
}

function loadSessionMessages(sessionId, scrollToBottom) {
  // Load messages for a specific session from server
  var sid = sessionId || currentSessionId;
  if (!sid) return;
  if (scrollToBottom === undefined) scrollToBottom = true;
  var container = document.getElementById('chatMessages');
  if (!container) return;
  // Save current scroll state before potential DOM rebuild
  var prevScrollTop = container.scrollTop;
  var prevScrollHeight = container.scrollHeight;
  var prevClientHeight = container.clientHeight;
  var wasAtBottom = (prevScrollHeight - prevScrollTop - prevClientHeight) < 60;
  var prevMessages = container.querySelectorAll('.chat-msg');

  fetch(sessionApi('/' + encodeURIComponent(sid) + '/messages'))
    .then(function(r) { return r.json(); })
    .then(function(msgs) {
      if (!container) return;
      msgs = msgs || [];
      // Parse ops from content (format: text + "\n__OPS__"+JSON+"\n__OPS__")
      var parsedMsgs = msgs.map(function(m) {
        var content = m.content || '';
        var ops = null;
        var markerMatch = content.match(/\n__OPS__(.+?)__OPS__/);
        if (markerMatch) {
          try { ops = JSON.parse(markerMatch[1]); } catch(e) {}
          content = content.replace(/\n__OPS__.+?__OPS__/, '');
        }
        return { role: m.role, content: content, ts: m.ts || '', ops: ops };
      });

      // Smart reload: preserve DOM if same message count, else rebuild
      if (prevMessages.length === msgs.length) {
        // Same count — diff and update only changed messages (preserves scroll + event listeners)
        parsedMsgs.forEach(function(pm, i) {
          // Only update text if changed (don't rebuild DOM nodes unnecessarily)
          if (prevMessages[i]) {
            // Check if content actually changed
            var currentText = prevMessages[i].innerText || '';
            var newText = (pm.content || '').trim();
            // Update bubble body text if changed
            var labelDiv = prevMessages[i].querySelector('.chat-msg-label');
            var tsSpan = prevMessages[i].querySelector('.ts');
            // Simple approach: rebuild the bubble if content differs significantly
            var currentBodyText = prevMessages[i].innerText || '';
            var newBodyText = (pm.content || '') + (pm.ts || '');
            if (Math.abs(currentBodyText.length - newBodyText.length) > 5) {
              // Content changed significantly — update the bubble
              var role = pm.role || 'user';
              var label = role === 'ai' ? '🤖 拓扑专家' : '👤 你';
              prevMessages[i].innerHTML = '<div class="chat-msg-label">' + label + '</div>' + escHtml(pm.content || '') + '<span class="ts">' + escHtml(pm.ts || '') + '</span>';
            }
          }
        });
        // Update ops cards too
        var msgCount = msgs.length;
        // Rebuild all ops cards to match server state
        parsedMsgs.forEach(function(pm, i) {
          if (pm.ops && pm.ops.length > 0) {
            // Find the right place to insert/replace ops card (after corresponding chat-msg)
            var correspondingBubbles = container.querySelectorAll('.chat-msg');
            var correspondingBubble = correspondingBubbles[i];
            if (correspondingBubble) {
              var existingCard = correspondingBubble.nextElementSibling;
              if (!existingCard || !existingCard.classList.contains('chat-ops-card')) {
                // Need to insert new ops card
                var theOps = pm.ops;
                var opsDiv = document.createElement('div');
                opsDiv.innerHTML = renderOpsCard(theOps);
                opsDiv.dataset.ops = JSON.stringify(theOps);
                var execBtn = opsDiv.querySelector('.chat-ops-execute');
                var dismissBtn = opsDiv.querySelector('.chat-ops-dismiss');
                if (execBtn) execBtn.addEventListener('click', function() { executeTopoOps(theOps); });
                if (dismissBtn) dismissBtn.addEventListener('click', dismissTopoOps);
                correspondingBubble.parentNode.insertBefore(opsDiv, correspondingBubble.nextSibling);
              }
            }
          }
        });
      } else {
        // Message count changed — full rebuild, preserve scroll position carefully
        var shellBtn = container.querySelector('#scrollToBottomBtn');
        var shellEmpty = container.querySelector('#chatEmpty');
        var btnHtml = shellBtn ? '<div id="scrollToBottomBtn" onclick="scrollChatToBottom()" style="' + (shellBtn.style.cssText || '') + '">' + (shellBtn.textContent || '↓ 最新消息') + '</div>' : '';
        var emptyHtml = shellEmpty ? '<div class="chat-empty" id="chatEmpty">' + (shellEmpty.innerHTML || '') + '</div>' : '';
        
        // Build all messages HTML in memory first
        var htmlParts = [btnHtml, emptyHtml];
        parsedMsgs.forEach(function(pm) {
          var displayText = pm.content || '';
          var role = pm.role || 'user';
          var label = role === 'ai' ? '🤖 拓扑专家' : '👤 你';
          var ts = pm.ts || '';
          htmlParts.push('<div class="chat-msg ' + role + '"><div class="chat-msg-label">' + label + '</div>' + escHtml(displayText) + '<span class="ts">' + escHtml(ts) + '</span></div>');
          if (pm.ops && pm.ops.length > 0) {
            var opsCardHtml = renderOpsCard(pm.ops).replace(/ id="[^"]*"/g, ' ');
            htmlParts.push('<div class="chat-ops-card" data-ops="' + escHtml(JSON.stringify(pm.ops)) + '">' + opsCardHtml + '</div>');
          }
        });
        
        // Replace content but preserve scroll if user was reading history
        container.innerHTML = htmlParts.join('');
        
        // Attach event listeners to ops cards using parsedMsgs
        container.querySelectorAll('.chat-ops-card').forEach(function(card) {
          var opsJson = card.dataset.ops;
          if (opsJson) {
            try {
              var ops = JSON.parse(opsJson);
              var execBtn = card.querySelector('.chat-ops-execute');
              var dismissBtn = card.querySelector('.chat-ops-dismiss');
              if (execBtn) execBtn.addEventListener('click', function() { executeTopoOps(ops); });
              if (dismissBtn) dismissBtn.addEventListener('click', dismissTopoOps);
            } catch(e) {}
          }
        });
        
        // Restore scroll position
        if (scrollToBottom || wasAtBottom) {
          container.scrollTop = container.scrollHeight;
          chatUserAtBottom = true;
        } else {
          container.scrollTop = Math.min(prevScrollTop, Math.max(0, container.scrollHeight - prevClientHeight));
          chatUserAtBottom = false;
        }
      }
      // Update empty state visibility
      var emptyEl = container.querySelector('#chatEmpty');
      if (emptyEl) emptyEl.style.display = msgs.length > 0 ? 'none' : 'flex';
      var scrollBtn = container.querySelector('#scrollToBottomBtn');
      if (scrollBtn) {
        var atBottom = (container.scrollHeight - container.scrollTop - container.clientHeight) < 60;
        scrollBtn.style.display = atBottom ? 'none' : 'block';
      }
    }).catch(function() {});
}

function loadChatMessages() {
  // Poll: load messages for current session, preserve user scroll position
  if (currentSessionId) {
    loadSessionMessages(currentSessionId, false);
  }
}

// Initialize chat execute listeners at startup
(function initChatExecute() {
  document.getElementById('chatMessages').addEventListener('click', function(e) {
    var btn = e.target.closest('.chat-ops-execute');
    if (!btn) return;
    var card = btn.closest('.chat-ops-card');
    if (!card) return;
    var opsData = card.dataset.ops;
    if (!opsData) {
      var msgDiv = card.parentElement;
      opsData = msgDiv && msgDiv.dataset ? msgDiv.dataset.ops : null;
    }
    if (opsData) {
      try {
        var ops = JSON.parse(opsData);
        executeTopoOps(ops);
      } catch(err) { console.error('opsexec error:', err); }
    }
  });
})();

function renderOpsCard(ops) {
  if (!ops || ops.length === 0) return '';
  let html = '<div class="chat-ops-card" id="topo-ops-card">';
  html += '<div class="ops-title">📋 建议操作（点击执行应用到画布）：</div>';
  ops.forEach(function(op, i) {
    if (op.action === 'add_node' || op.action === 'add_device' || op.action === 'add') {
      html += '<div class="op-item"><span class="op-icon">➕</span> 添加 ' + escHtml(op.type || op.device || '?') + '：' + escHtml(op.label || op.name || op.id || '') + ' @(' + (op.x||'?') + ',' + (op.y||'?') + ')</div>';
    } else if (op.action === 'add_edge' || op.action === 'add_connection' || op.action === 'connect') {
      var portInfo = (op.src_port || op.tgt_port) ? '（' + escHtml(op.src_port || '?') + ' → ' + escHtml(op.tgt_port || '?') + '）' : '';
      html += '<div class="op-item"><span class="op-icon">🔗</span> 连接 ' + escHtml(op.from || op.source || '') + ' → ' + escHtml(op.to || op.target || '') + ' ' + portInfo + '</div>';
    } else if (op.action === 'remove_edge') {
      html += '<div class="op-item"><span class="op-icon">✂️</span> 删除连线 ' + escHtml(op.from || '') + ' → ' + escHtml(op.to || '') + '</div>';
    } else if (op.action === 'update_edge' || op.action === 'modify_edge') {
      var edgeDesc = escHtml((op.from || op.src || '') + ' → ' + (op.to || op.tgt || ''));
      var changes = [];
      if (op.src_port || op.srcPort) changes.push('端口1: ' + (op.src_port || op.srcPort));
      if (op.tgt_port || op.tgtPort) changes.push('端口2: ' + (op.tgt_port || op.tgtPort));
      if (op.bandwidth) changes.push('带宽: ' + op.bandwidth);
      if (op.label) changes.push('标签: ' + op.label);
      html += '<div class="op-item"><span class="op-icon">🔧</span> 修改连线 ' + edgeDesc + (changes.length ? ' → ' + changes.join(', ') : '') + '</div>';
    } else if (op.action === 'move_node') {
      html += '<div class="op-item"><span class="op-icon">📍</span> 移动 ' + escHtml(op.label || op.id || '') + ' → 坐标(' + (op.x || '?') + ', ' + (op.y || '?') + ')</div>';
    } else if (op.action === 'update_node') {
      html += '<div class="op-item"><span class="op-icon">✏️</span> 修改 ' + escHtml(op.label || op.id || '') + '：' + escHtml(op.ip ? 'IP=' + op.ip : (op.desc ? '描述=' + op.desc : JSON.stringify(op))) + '</div>';
    } else if (op.action === 'remove_node' || op.action === 'delete') {
      html += '<div class="op-item"><span class="op-icon">🗑️</span> 删除 ' + escHtml(op.label || op.id || '') + '</div>';
    } else if (op.action === 'rename') {
      html += '<div class="op-item"><span class="op-icon">✏️</span> 重命名 ' + escHtml(op.from || '') + ' → ' + escHtml(op.to || '') + '</div>';
    } else {
      html += '<div class="op-item"><span class="op-icon">⚙️</span> ' + escHtml(JSON.stringify(op)) + '</div>';
    }
  });
  html += '<button class="chat-ops-execute" id="ops-execute-btn">⚡ 执行全部操作</button>';
  html += '<button class="chat-ops-dismiss" id="ops-dismiss-btn">暂不执行</button>';
  html += '</div>';
  return html;
}

function executeTopoOps(ops) {
  if (!ops || ops.length === 0) { toast('无操作可执行'); return; }
  var card = document.getElementById('topo-ops-card');
  if (card) {
    var btn = card.querySelector('.chat-ops-execute');
    if (btn) { btn.disabled = true; btn.textContent = '执行中...'; }
  }
  if (card) {
    var btn = card.querySelector('.chat-ops-execute');
    if (btn) { btn.disabled = true; btn.textContent = '执行中...'; }
  }
  var failed = 0, success = 0;
  saveUndoState();
  ops.forEach(function(op, i) {
    try {
      if (op.action === 'add_node' || op.action === 'add_device' || op.action === 'add') {
        var nodeName = op.label || op.name || op.id || ('ai-' + Date.now() + '-' + Math.random().toString(36).substr(2, 5));
        // 避免重复：先按 ID 查，再按 label 查（AI 可能用 label 作为 ID）
        var type = op.type || op.device || 'switch';
        var dev = DEVICES[type] || { label: type, icon: 'router.png', color: '#3b82f6', w: 80, h: 80 };
        var existing = cy.nodes('[id="' + nodeName + '"]').length > 0
                    || cy.nodes('[label="' + nodeName + '"]').length > 0;
        if (existing) {
          success++; // 已存在算成功
        } else {
          var finalId = op.id || ('ai-' + Date.now() + '-' + i + '-' + Math.random().toString(36).substr(2, 3));
          cy.add({
            group: 'nodes',
            data: {
              id: finalId,
              type: type,
              label: nodeName,
              icon: op.icon || ('/icons/' + dev.icon),
              color: op.color || dev.color,
              w: dev.w, h: dev.h,
              ip: op.ip || '', desc: dev.label, mac: '', port: '', bandwidth: ''
            },
            position: { x: op.x || 300, y: op.y || 200 }
          });
          success++;
          addOpLog('ai', '添加设备：' + nodeName);
        }
      } else if (op.action === 'add_edge') {
        var srcId = op.from || op.source;
        var tgtId = op.to || op.target;
        var srcPort = op.srcPort || '';
        var tgtPort = op.tgtPort || '';
        if (!srcPort && op.ports && typeof op.ports === 'object') {
          srcPort = op.ports[op.from || op.source] || op.ports[srcId] || '';
          tgtPort = op.ports[op.to || op.target] || op.ports[tgtId] || '';
        }
        // Resolve node IDs - try by ID first, then by label
        var srcNode = cy.nodes('[id="' + srcId + '"]');
        var tgtNode = cy.nodes('[id="' + tgtId + '"]');
        if (!srcNode.length) srcNode = cy.nodes('[label="' + srcId + '"]');
        if (!tgtNode.length) tgtNode = cy.nodes('[label="' + tgtId + '"]');
        if (srcNode.length && tgtNode.length) {
          var realSrcId = srcNode.id();
          var realTgtId = tgtNode.id();
          var edgeNote = '';
          // Avoid duplicate edges
          var exists = cy.edges().some(function(e) {
            return e.source().id() === realSrcId && e.target().id() === realTgtId;
          });
          if (!exists) {
            var edgeColor = op.edgeColor || op.color || '#374151';
            var edgeStyle = op.edgeStyle || op.style || 'solid';
            cy.add({
              group: 'edges',
              data: {
                source: realSrcId,
                target: realTgtId,
                label: edgeNote,
                srcPort: srcPort,
                tgtPort: tgtPort,
                edgeStyle: edgeStyle,
                edgeColor: edgeColor,
                edgeBandwidth: op.bandwidth || ''
              }
            });
            success++;
            addOpLog('ai', '添加连线：' + srcId + ' → ' + tgtId + (srcPort || tgtPort ? '（' + (srcPort || '?') + ' → ' + (tgtPort || '?') + '）' : ''));
          } else {
            success++; // already exists, count as success
          }
        } else {
          failed++;
        }
      } else if (op.action === 'move_node') {
        var n = cy.nodes('[id="' + (op.id || op.label) + '"]');
        if (n.length) {
          n.position({ x: op.x || 300, y: op.y || 200 });
          success++;
          addOpLog('ai', '移动设备：' + (op.label || op.id || '?'));
        } else { failed++; }
      } else if (op.action === 'update_node' || op.action === 'modify_device') {
        var n = cy.nodes('[id="' + (op.id || op.label) + '"]');
        if (n.length) {
          if (op.ip) n.data('ip', op.ip);
          if (op.mac) n.data('mac', op.mac);
          if (op.desc) n.data('desc', op.desc);
          if (op.label) n.data('label', op.label);
          if (op.port) n.data('port', op.port);
          if (op.bandwidth) n.data('bandwidth', op.bandwidth);
          success++;
          addOpLog('ai', '修改设备：' + (op.label || op.id || '?'));
        } else { failed++; }
      } else if (op.action === 'remove_node' || op.action === 'delete') {
        var n = cy.nodes('[id="' + (op.id || op.label) + '"]');
        if (n.length) {
          var isShape = n.data('isShape'), isText = n.data('isTextBox');
          n.remove(); success++;
          hideResizeHandles();
          var what = (isShape ? '形状' : (isText ? '文本框' : '设备'));
          addOpLog('ai', '删除' + what + '：' + (op.label || op.id || '?'));
        } else { failed++; }
      } else if (op.action === 'remove_edge') {
        var es = cy.edges('[source="' + (op.src || op.from) + '"][target="' + (op.tgt || op.to) + '"]');
        if (!es.length) es = cy.edges('[source="' + (op.src || op.from) + '"]').filter(function(e) { return e.target().id() === (op.tgt || op.to); });
        if (!es.length) es = cy.edges('[target="' + (op.tgt || op.to) + '"]').filter(function(e) { return e.source().id() === (op.src || op.from); });
        if (es.length) { es.remove(); success++; addOpLog('ai', '删除连线：' + (op.src || op.from) + ' → ' + (op.tgt || op.to)); } else { failed++; }
      } else if (op.action === 'update_edge' || op.action === 'modify_edge') {
        var es = cy.edges('[source="' + (op.src || op.from) + '"][target="' + (op.tgt || op.to) + '"]');
        if (!es.length) es = cy.edges('[source="' + (op.src || op.from) + '"]').filter(function(e) { return e.target().id() === (op.tgt || op.to); });
        if (!es.length) es = cy.edges('[target="' + (op.tgt || op.to) + '"]').filter(function(e) { return e.source().id() === (op.src || op.from); });
        if (es.length) {
          var e = es[0];
          if (op.srcPort || op.src_port) e.data('srcPort', op.srcPort || op.src_port);
          if (op.tgtPort || op.tgt_port) e.data('tgtPort', op.tgtPort || op.tgt_port);
          if (op.bandwidth) e.data('bandwidth', op.bandwidth);
          if (op.label) e.data('label', op.label);
          if (op.edgeColor || op.color) { e.data('edgeColor', op.edgeColor || op.color); e.css('line-color', op.edgeColor || op.color); }
          if (op.edgeStyle || op.style) { e.data('edgeStyle', op.edgeStyle || op.style); e.css('line-style', op.edgeStyle || op.style); }
          success++;
          addOpLog('ai', '修改连线：' + (op.src || op.from) + ' → ' + (op.tgt || op.to));
        } else { failed++; }
      } else if (op.action === 'rename') {
        var n = cy.nodes('[id="' + (op.id || op.from) + '"]');
        if (!n.length) n = cy.nodes('[label="' + (op.id || op.from) + '"]');
        if (n.length) { n.data('label', op.to || op.label); success++; addOpLog('ai', '重命名：' + (op.from || op.id) + ' → ' + (op.to || op.label)); } else { failed++; }
      }
    } catch(e) {
      console.error('exec op error:', e, op);
      failed++;
    }
  });
  // Hide the ops card and clear pending ops
  if (card) card.style.display = 'none';
  window.__topoPendingOps = [];
  autoSaveProject && autoSaveProject();
  updateProjectMeta && updateProjectMeta();
  refreshCanvas();
  // Also tell server to clear the ops from this message
  fetch('/api/chat/clear-ops', { method: 'POST' }).catch(function() {});
  // Reload chat to update UI (ops will be gone)
  loadChatMessages();
  toast('✓ 已执行 ' + success + ' 个操作' + (failed > 0 ? '，' + failed + ' 个失败' : ''));
}

function dismissTopoOps() {
  var card = document.getElementById('topo-ops-card');
  if (card) card.style.display = 'none';
  window.__topoPendingOps = [];
}

function startChatPoll() {
// ============================================================
// ===== SECTION: Initialization =====
(function initDraft() {
  let draftRegistered = false;

  // ============================================================
  // Undo / Redo Stack
  // ============================================================
  var undoStack = [];
  var redoStack = [];
  var MAX_UNDO = 50;
  window.undoTopo = function() {
    if (undoStack.length === 0) { toast('没有可撤销的操作'); return; }
    var state = undoStack.pop();
    if (!state) return;
    try {
    isUndoRedo = true;
    redoStack.push({
      nodes: cy.nodes().map(function(n) { return { ...n.data(), position: n.position() }; }),
      edges: cy.edges().map(function(e) { return { ...e.data() }; })
    });
    cy.elements().remove();
    state.nodes.forEach(function(n) {
      if (!n.icon && DEVICES[n.type]) { n.icon = DEVICES[n.type].icon; n.color = DEVICES[n.type].color; }
      cy.add({ group: 'nodes', data: n, position: n.position });
    });
    state.edges.forEach(function(e) { try { cy.add({ group: 'edges', data: e }); } catch(err) {} });
    isUndoRedo = false;
    autoSaveProject && autoSaveProject();
    updateProjectMeta && updateProjectMeta();
    toast('✓ 已撤销（剩余 ' + undoStack.length + ' 步）', 1500);
    addOpLog('human', '撤销操作');
    } catch(err) { console.error('[UNDO] error:', err.message); isUndoRedo = false; }
  };

  window.redoTopo = function() {
    if (redoStack.length === 0) { toast('没有可重做的操作'); return; }
    var state = redoStack.pop();
    if (!state) return;
    isUndoRedo = true;
    undoStack.push({
      nodes: cy.nodes().map(function(n) { return { ...n.data(), position: n.position() }; }),
      edges: cy.edges().map(function(e) { return { ...e.data() }; })
    });
    cy.elements().remove();
    state.nodes.forEach(function(n) {
      if (!n.icon && DEVICES[n.type]) { n.icon = DEVICES[n.type].icon; n.color = DEVICES[n.type].color; }
      cy.add({ group: 'nodes', data: n, position: n.position });
    });
    state.edges.forEach(function(e) { try { cy.add({ group: 'edges', data: e }); } catch(err) {} });
    isUndoRedo = false;
    autoSaveProject && autoSaveProject();
    updateProjectMeta && updateProjectMeta();
    toast('✓ 已重做', 1500);
    addOpLog('human', '重做操作');
  };

  function saveUndoState() {
    if (isUndoRedo) return;
    undoStack.push({
      nodes: cy.nodes().map(function(n) { return { ...n.data(), position: n.position() }; }),
      edges: cy.edges().map(function(e) { return { ...e.data() }; })
    });
    if (undoStack.length > MAX_UNDO) undoStack.shift();
    redoStack = []; // Clear redo on new action
  }
  window.saveUndoState = saveUndoState;

  function registerDraft() {
    if (draftRegistered || typeof cy === 'undefined' || !cy || !cy.nodes) return;
    draftRegistered = true;

    // Auto-save on topology changes (debounced, not during undo/redo)
    var _autoSaveTimer = null;
    cy.on('add remove move drag', function() {
      if (isUndoRedo) return;
      clearTimeout(_autoSaveTimer);
      _autoSaveTimer = setTimeout(function() {
        autoSaveProject();
        updateProjectMeta();
      }, 1000);
    });

    // NOTE: removed cy.on('add'...) listeners - they captured state AFTER change (wrong).
    // Undo state is now saved explicitly BEFORE each cy.add()/remove() call.

    // Auto-load project from URL param on page ready
    if (window._projId) {
      // URL has ?proj=ID → load this project from server
      autoLoadProject(window._projId);
      toast('✓ 已加载项目', 2000);
    }
    // No proj param → user must select a project first (no auto-load)
  }

  // Listen for cy ready event
function saveProject() {
  if (!currentProjectId) {
    toast('请先在项目管理中选择一个项目');
    return;
  }
  var topoData = getCurrentTopoData();
  // Save to server
  fetch('/api/projects/' + encodeURIComponent(currentProjectId) + '/topo', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(topoData)
  }).then(function(r) { return r.json(); }).then(function() {
    toast('✓ 项目已保存');
  }).catch(function() { toast('保存失败，请重试'); });
  // Save chat history to server
  var chatMsgs = [];
  document.querySelectorAll('#chatMessages .chat-msg').forEach(function(el) {
    var role = el.classList.contains('ai') ? 'ai' : 'human';
    var textEl = el.querySelector('.chat-text');
    if (textEl) {
      chatMsgs.push({ role: role, content: textEl.textContent.trim() });
    }
  });
  fetch('/api/projects/' + encodeURIComponent(currentProjectId) + '/chat', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(chatMsgs)
  }).catch(function() {});
  // Save opLog to server
  fetch('/api/projects/' + encodeURIComponent(currentProjectId) + '/oplog', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
function addOpLog(type, text) {
  opLog.unshift({ type: type, text: text, time: new Date() });
  if (opLog.length > 100) opLog = opLog.slice(0, 100);
  // Save to server
  if (currentProjectId) {
    fetch('/api/projects/' + encodeURIComponent(currentProjectId) + '/oplog', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(opLog)
    }).catch(function() {});
  }
  renderOpLog();
}

function setLogFilter(f) {
  opLogFilter = f;
  document.querySelectorAll('.props-log-filter').forEach(function(b) {
    b.classList.toggle('active', b.dataset.filter === f);
  });
  renderOpLog();
  try { localStorage.setItem(projKey('opLog'), JSON.stringify(opLog)); } catch(e) {}
}

function renderOpLog() {
  var list = document.getElementById('opLogList');
  if (!list) return;
  var filtered = opLogFilter === 'all' ? opLog : opLog.filter(function(e) { return e.type === opLogFilter; });
  if (filtered.length === 0) {
    list.innerHTML = '<div class="props-log-empty">' + (opLog.length === 0 ? '暂无变更记录' : '无符合条件的记录') + '</div>';
    return;
  }
  var html = '';
  filtered.forEach(function(e) {
    var icon = e.type === 'ai' ? '🤖' : '👤';
    var cls = e.type === 'ai' ? 'ai' : 'human';
    var t = e.time.toTimeString().slice(0, 5);
    html += '<div class="props-log-item ' + cls + '">' +
      '<span class="log-icon">' + icon + '</span>' +
      '<span class="log-text">' + e.text + '</span>' +
      '<span class="log-time">' + t + '</span></div>';
  });
  list.innerHTML = html;
}

function clearOpLog() {
  opLog = [];
  try { localStorage.setItem(projKey('opLog'), JSON.stringify(opLog)); } catch(e) {}
  renderOpLog();
  toast('记录已清除', 1500);
}


// ============================================================
// Delegated palette click - unified handler for all sidebar items
document.getElementById('devicePalette').addEventListener('click', function(e) {
  var item = e.target.closest('.palette-item, .palette-group');
  if (!item) return;
  var action = item.dataset.action;
  console.log('[palette click] action:', action, 'item:', item.className);
  if (action === 'toggle-group') {
    var sub = item.nextElementSibling;
    if (sub && sub.classList.contains('palette-subitems')) {
      var isOpen = sub.style.display !== 'none';
      sub.style.display = isOpen ? 'none' : 'block';
      var chev = item.querySelector('.group-chevron');
      if (chev) chev.textContent = isOpen ? '▸' : '▾';
    }
  } else if (action === 'add-device') {
    var deviceType = item.dataset.device;
    if (deviceType) {
      quickAdd(deviceType);
    }
  }
});

// Hook: intercept AI executeTopoOps
var _origExecuteTopoOps = null;
function patchExecuteTopoOps() {
  if (typeof executeTopoOps !== 'undefined') {
    _origExecuteTopoOps = executeTopoOps;
  }
}

// Hook human operations into undo state save
var _origSaveUndoState = null;


  // ============================================================
  // Edit Menu (Shapes & TextBox)
  // ============================================================
  var pendingShapeType = null;
  var pendingShapeColor = null;
  var textBoxDialogData = null;

  function toggleEditMenu() {
    var menu = document.getElementById('editMenu');
    menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
    document.onclick = function(e) {
      if (!document.getElementById('editMenu').contains(e.target) && e.target.id !== 'btn-edit') {
        document.getElementById('editMenu').style.display = 'none';
        document.onclick = null;
      }
    };
  }

  function makeShapeSVG(type, color, w, h, label, bg, fg) {
    var bgFill = (bg === 'transparent' || !bg) ? 'fill="none"' : 'fill="' + bg + '"';
    var txtColor = fg || '#1f2937';
    var labelSvg = '';
    if (label) {
      var escaped = label.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      labelSvg = '<text x="' + (w/2) + '" y="' + (h/2) + '" text-anchor="middle" dominant-baseline="middle" font-size="12" fill="' + txtColor + '" font-family="sans-serif">' + escaped + '</text>';
    }
    var shape;
    if (type === 'ellipse') {
      shape = '<ellipse cx="' + (w/2) + '" cy="' + (h/2) + '" rx="' + (w/2-2) + '" ry="' + (h/2-2) + '" ' + bgFill + ' stroke="' + color + '" stroke-width="2"/>';
    } else {
      shape = '<rect x="2" y="2" width="' + (w-4) + '" height="' + (h-4) + '" ' + bgFill + ' stroke="' + color + '" stroke-width="2" rx="4"/>';
    }
    return 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="' + w + '" height="' + h + '">' + shape + labelSvg + '</svg>');
  }

  function startPlaceShape(type, color) {
    pendingShapeType = type;
    pendingShapeColor = color || '#ef4444';
    document.getElementById('editMenu').style.display = 'none';
    var _mb1 = getModeBadge(); if (_mb1) { _mb1.classList.add('visible'); var _t1 = _mb1.querySelector('.mode-text'); if(_t1) _t1.textContent = '放置' + (type === 'ellipse' ? '椭圆' : '方形'); var _d1 = _mb1.querySelector('.mode-dot'); if(_d1) _d1.style.background = color; }
    toast('点击画布放置形状，ESC取消');
  }

  function openTextBoxDialog() {
    document.getElementById('editMenu').style.display = 'none';
    document.getElementById('tbContent').value = '';
    document.getElementById('tbBgColor').value = '#000000';
    document.getElementById('tbBgLabel').textContent = '透明';
    document.getElementById('tbFgColor').value = '#1f2937';
    document.getElementById('tbFgLabel').textContent = '#1f2937';
    document.getElementById('textBoxDialog').style.display = 'flex';
    document.getElementById('tbContent').focus();
  }

  function confirmTextBox() {
    var content = document.getElementById('tbContent').value.trim();
    if (!content) { toast('请输入文字内容'); return; }
    var bg = document.getElementById('tbBgColor').value;
    var fg = document.getElementById('tbFgColor').value;
    // Default to transparent if white
    if (bg === '#ffffff') bg = '#00000000';
    textBoxDialogData = { content: content, bgColor: bg, fgColor: fg };
    document.getElementById('textBoxDialog').style.display = 'none';
    pendingShapeType = 'textbox';
    var _mb2 = getModeBadge(); if (_mb2) { _mb2.classList.add('visible'); var _t2 = _mb2.querySelector('.mode-text'); if(_t2) _t2.textContent = '放置文本框'; var _d2 = _mb2.querySelector('.mode-dot'); if(_d2) _d2.style.background = fg; }
    toast('点击画布放置文本框，ESC取消');
  }

  cy.on('tap', function(e) {
    if (pendingShapeType && e.target === cy) {
      var pos = e.position;
      if (pendingShapeType === 'textbox') {
        placeTextBox(pos.x, pos.y);
      } else {
        placeShape(pos.x, pos.y, pendingShapeType, pendingShapeColor);
      }
      pendingShapeType = null;
      textBoxDialogData = null;
      setMode('select');
      getModeBadge().classList.remove('visible');
    }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && pendingShapeType) {
      pendingShapeType = null;
      textBoxDialogData = null;
      setMode('select');
      getModeBadge().classList.remove('visible');
      toast('已取消', 1000);
    }
  });

  function placeShape(x, y, type, color) {
    var id = 'shape-' + Date.now();
    var w = 120, h = 80;
    var svgUri = makeShapeSVG(type, color, w, h, '', 'transparent', '#1f2937');
    cy.add({
      group: 'nodes',
      data: { id: id, type: type, label: '', shapeColor: color, w: w, h: h, isShape: true },
      css: {
        'width': w, 'height': h,
        'background-image': svgUri,
        'background-fit': 'contain',
        'background-width': w, 'background-height': h,
        'background-opacity': 0,
        'label': '',
        'text-valign': 'bottom',
        'text-margin-y': 6,
        'text-halign': 'center',
        'shape': 'rectangle',
        'text-events': 'no', 'events': 'yes',
      },
      position: { x: x, y: y }
    }).lower(); // 形状永远在设备之下
    saveUndoState && saveUndoState();
    autoSaveProject && autoSaveProject();
    addOpLog && addOpLog('human', '添加形状：' + (type === 'ellipse' ? '椭圆' : '方形'));
    toast('✓ 已添加形状');
  }

  function placeTextBox(x, y) {
    var d = textBoxDialogData;
    if (!d) return;
    var id = 'tb-' + Date.now();
    var lines = d.content.split('\n');
    var longest = lines.reduce(function(a,b){ return a.length > b.length ? a : b; }, '');
    var charW = 8, lineH = 18;
    var w = Math.max(80, Math.min(longest.length * charW + 24, 300));
    var h = Math.max(36, lines.length * lineH + 16);
    var bgHex = d.bgColor || '#00000000';
    var bgCSS = bgHex === '#00000000' || bgHex === 'transparent' ? 'rgba(0,0,0,0)' : bgHex;
    cy.add({
      group: 'nodes',
      data: { id: id, type: 'textbox', label: d.content, tbBg: bgHex, tbFg: d.fgColor, w: w, h: h, isTextBox: true },
      css: {
        'width': w, 'height': h,
        'background-color': bgCSS,
        'background-opacity': bgHex === '#00000000' ? 0 : 1,
        'label': d.content,
        'color': d.fgColor,
        'font-size': '13px',
        'text-wrap': 'wrap',
        'text-valign': 'center',
        'text-halign': 'center',
        'shape': 'rectangle',
        'border-width': 1,
        'border-color': '#d1d5db',
        'border-opacity': bgHex === '#00000000' ? 0 : 1,
        'text-events': 'yes', 'events': 'yes',
      },
      position: { x: x, y: y }
    });
    saveUndoState && saveUndoState();
    autoSaveProject && autoSaveProject();
    addOpLog && addOpLog('human', '添加文本框：' + d.content.substring(0, 20));
    toast('✓ 已添加文本框');
  }

  // ============================================================
  // Resize Handles
  // ============================================================
  var resizingNode = null;
  var resizeHandle = null;
  var resizeStartPos = null;
  var resizeStartSize = null;
  var resizeStartMouse = null;



  function showResizeHandles(node) {
    if (!node) { hideResizeHandles(); return; }
    var data = node.data();
    if (!data.isShape && !data.isTextBox) { hideResizeHandles(); return; }
    resizingNode = node;
    updateHandlePositions();
    var _ro2 = document.getElementById('resizeOverlay');
    if (_ro2) _ro2.style.pointerEvents = 'all';
    document.querySelectorAll('.resize-handle').forEach(function(h) { h.style.display = 'block'; });

  }

  function hideResizeHandles() {
    resizingNode = null;
    document.querySelectorAll('.resize-handle').forEach(function(h) { h.style.display = 'none'; });

    document.getElementById('resizeOverlay').style.pointerEvents = 'none';
  }


  function updateHandlePositions() {
    if (!resizingNode) return;
    var node = resizingNode;
    var rw = node.renderedWidth();
    var rh = node.renderedHeight();
    var pos = node.renderedPosition();
    var left = pos.x - rw / 2;
    var top = pos.y - rh / 2;
    var w = rw;
    var h = rh;
    setHandlePos('tl', left, top);
    setHandlePos('tr', left + w, top);
    setHandlePos('bl', left, top + h);
    setHandlePos('br', left + w, top + h);
    setHandlePos('tm', left + w/2, top);
    setHandlePos('bm', left + w/2, top + h);
    setHandlePos('lm', left, top + h/2);
    setHandlePos('rm', left + w, top + h/2);
  }

  function setHandlePos(h, x, y) {
    var el = document.getElementById('rh-' + h);
    if (el) { el.style.left = (x - 5) + 'px'; el.style.top = (y - 5) + 'px'; }
  }

  document.querySelectorAll('.resize-handle').forEach(function(handle) {
    handle.addEventListener('mousedown', function(e) {
      e.preventDefault();
      e.stopPropagation();
      e.cancelBubble = true;
      if (!resizingNode) return;
      resizeHandle = handle.dataset.handle;
      resizeStartPos = resizingNode.position();
      resizeStartSize = { w: resizingNode.data('w') || resizingNode.renderedWidth(), h: resizingNode.data('h') || resizingNode.renderedHeight() };
      resizeStartMouse = { x: e.clientX, y: e.clientY };
      document.addEventListener('mousemove', onResizeMove);
      document.addEventListener('mouseup', onResizeEnd);
    });
  });



  function onResizeMove(e) {
    if (!resizingNode || !resizeHandle) return;
    var dx = e.clientX - resizeStartMouse.x;
    var dy = e.clientY - resizeStartMouse.y;
    var node = resizingNode;
    var data = node.data();
    var minW = 40, minH = 30;
    var h = resizeHandle;
    var origW = resizeStartSize.w, origH = resizeStartSize.h;
    var origX = resizeStartPos.x, origY = resizeStartPos.y;
    var newW = origW, newH = origH, newX = origX, newY = origY;
    var halfW = origW / 2, halfH = origH / 2;

    if (h === 'br') {
      newW = Math.max(minW, origW + dx);
      newH = Math.max(minH, origH + dy);
    } else if (h === 'bl') {
      newW = Math.max(minW, origW - dx);
      newH = Math.max(minH, origH + dy);
    } else if (h === 'tr') {
      newW = Math.max(minW, origW + dx);
      newH = Math.max(minH, origH - dy);
    } else if (h === 'tl') {
      newW = Math.max(minW, origW - dx);
      newH = Math.max(minH, origH - dy);
    } else if (h === 'rm') {
      newW = Math.max(minW, origW + dx); newH = origH;
    } else if (h === 'lm') {
      newW = Math.max(minW, origW - dx); newH = origH;
    } else if (h === 'bm') {
      newW = origW; newH = Math.max(minH, origH + dy);
    } else if (h === 'tm') {
      newW = origW; newH = Math.max(minH, origH - dy);
    }
    // Center always fixed for all handles
    newX = origX; newY = origY;

    newW = Math.round(newW); newH = Math.round(newH);
    node.css('width', newW);
    node.css('height', newH);
    node.data('w', newW);
    node.data('h', newH);
    node.position({ x: newX, y: newY });

    if (data.isShape) {
      var svgUri = makeShapeSVG(data.type, data.shapeColor, newW, newH, data.label||'', data.shapeBg||'transparent', data.shapeFg||'#1f2937');
      node.css('background-image', svgUri);
      node.css('background-width', newW);
      node.css('background-height', newH);
    }
    if (data.isTextBox) {
      node.css('font-size', Math.max(10, Math.round(13 * newH / origH)) + 'px');
    }
    updateHandlePositions();
  }

  function onResizeEnd(e) {
    if (resizingNode) {
      saveUndoState && saveUndoState();
      autoSaveProject && autoSaveProject();
    }
    resizingNode = null; resizeHandle = null; resizeStartPos = null; resizeStartSize = null; resizeStartMouse = null;
    document.removeEventListener('mousemove', onResizeMove);
    document.removeEventListener('mouseup', onResizeEnd);
    hideResizeHandles();
  }

  cy.on('select', 'node', function(e) {
    var node = e.target;
    var data = node.data();
    if (data && (data.isShape || data.isTextBox)) {
      node.css({'border-width': 0, 'border-color': 'transparent'});
      showResizeHandles(node);
    }
  });
  cy.on('unselect', 'node', function(e) {
    var node = e.target;
    var data = node.data();
    if (data && (data.isShape || data.isTextBox)) {
      node.css({'border-width': 0});
      hideResizeHandles();
    }
  });
  var _zoomTimer = null;
cy.on('zoom resize', function() {
  clearTimeout(_zoomTimer);
  _zoomTimer = setTimeout(function() { if (resizingNode) updateHandlePositions(); }, 100);
});
  var _nodeResizeTimer = null;
window.addEventListener('resize', function() {
  clearTimeout(_nodeResizeTimer);
  _nodeResizeTimer = setTimeout(function() { if (resizingNode) updateHandlePositions(); }, 200);
});
  document.querySelectorAll('.resize-handle').forEach(function(h) { h.style.display = 'none'; });
  document.getElementById('resizeOverlay').style.pointerEvents = 'none';

  // ============================================================
  // Shape / TextBox in Properties Panel
  // ============================================================
  var _origShowProps = showProps;
  showProps = function(ele) {
    _origShowProps(ele);
    var data = ele.data();
    if (!data || (!data.isShape && !data.isTextBox)) return;
    var content = document.getElementById('propsContent');
    var extra = '';
    if (data.isShape) {
      extra += '<div class="prop-group"><div class="prop-label">边框颜色</div>' +
        '<div style="display:flex;gap:8px;align-items:center;margin-top:4px;">' +
        '<div class="shape-color-swatch" id="sc-red" style="background:#ef4444;" onclick="changeShapeColor(\'' + ele.id() + '\',\'#ef4444\')"></div>' +
        '<div class="shape-color-swatch" id="sc-yellow" style="background:#f59e0b;" onclick="changeShapeColor(\'' + ele.id() + '\',\'#f59e0b\')"></div>' +
        '<div class="shape-color-swatch" id="sc-green" style="background:#10b981;" onclick="changeShapeColor(\'' + ele.id() + '\',\'#10b981\')"></div>' +
        '</div></div>';
    }
    if (data.isTextBox) {
      var curBg = data.tbBg || '#ffffff';
      var curFg = data.tbFg || '#1f2937';
      extra += '<div class="prop-group"><div class="prop-label">背景色</div>' +
        '<div style="display:flex;gap:6px;align-items:center;margin-top:4px;">' +
        '<input type="color" value="' + curBg + '" onchange="changeTBCprop(\'' + ele.id() + '\',\'tbBg\',this.value)" style="width:32px;height:28px;border:1px solid #d1d5db;border-radius:6px;cursor:pointer;padding:0;">' +
        '<span style="font-size:11px;color:#9ca3af;">' + curBg + '</span></div></div>';
      extra += '<div class="prop-group"><div class="prop-label">字体颜色</div>' +
        '<div style="display:flex;gap:6px;align-items:center;margin-top:4px;">' +
        '<input type="color" value="' + curFg + '" onchange="changeTBCprop(\'' + ele.id() + '\',\'tbFg\',this.value)" style="width:32px;height:28px;border:1px solid #d1d5db;border-radius:6px;cursor:pointer;padding:0;">' +
        '<span style="font-size:11px;color:#9ca3af;">' + curFg + '</span></div></div>';
      extra += '<div class="prop-group"><div class="prop-label">文字内容</div>' +
        '<textarea rows="2" style="width:100%;padding:6px 8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;resize:vertical;box-sizing:border-box;margin-top:4px;font-family:inherit;" oninput="changeTBText(\'' + ele.id() + '\',this.value)">' + (data.label || '') + '</textarea></div>';
    }
    content.innerHTML += extra;
    // Highlight current color
    if (data.isShape && data.shapeColor) {
      document.querySelectorAll('.shape-color-swatch').forEach(function(s) {
        s.classList.toggle('selected', s.style.background === data.shapeColor);
      });
    }
  };

  function changeShapeColor(nodeId, color) {
    var node = cy.getElementById(nodeId);
    if (!node) return;
    var w = node.data('w') || node.renderedWidth();
    var h = node.data('h') || node.renderedHeight();
    var svgUri = makeShapeSVG(node.data('type'), color, w, h, node.data('label')||'', node.data('shapeBg')||'transparent', node.data('shapeFg')||'#1f2937');
    node.data('shapeColor', color);
    node.css('background-image', svgUri);
    saveUndoState && saveUndoState();
    autoSaveProject && autoSaveProject();
  }

  function changeTBCprop(nodeId, prop, value) {
    var node = cy.getElementById(nodeId);
    if (!node) return;
    node.data(prop, value);
    if (prop === 'tbBg') {
      var isTransparent = (value === '#00000000' || value === 'transparent');
      node.css('background-color', isTransparent ? 'rgba(0,0,0,0)' : value);
      node.css('background-opacity', isTransparent ? 0 : 1);
      node.css('border-opacity', isTransparent ? 0 : 1);
    } else if (prop === 'tbFg') {
      node.css('color', value);
    }
    saveUndoState && saveUndoState();
    autoSaveProject && autoSaveProject();
  }

  function changeTBText(nodeId, value) {
    var node = cy.getElementById(nodeId);
    if (!node) return;
    node.data('label', value);
    node.css('label', value);
    saveUndoState && saveUndoState();
    autoSaveProject && autoSaveProject();
  }

// ============================================================
var _formDevCounter = 0;
var _formEdgeCounter = 0;
var _formDeviceTypes = ['router','switch','firewall','server','pc','cloud'];
var _formDeviceLabels = {'router':'路由器','switch':'交换机','firewall':'防火墙','server':'服务器','pc':'PC','cloud':'云'};

function openFormGen() {
  document.getElementById('formGenModal').classList.add('open');
  _formDevCounter = 0;
  _formEdgeCounter = 0;
  document.getElementById('formDevTbody').innerHTML = '';
  document.getElementById('formEdgeTbody').innerHTML = '';
  document.getElementById('formRemarks').value = '';
  document.getElementById('formAiEnabled').checked = false;
  // Try restore draft
  var draft = null;
  try { draft = JSON.parse(localStorage.getItem('formGenDraft') || 'null'); } catch(e) {}
  if (draft && draft.devs && draft.devs.length > 0) {
    draft.devs.forEach(function(d) { addFormDevRow(d); });
  } else {
    addFormDevRow();
    addFormDevRow();
  }
  if (draft && draft.edges && draft.edges.length > 0) {
    draft.edges.forEach(function(e) { addFormEdgeRow(e); });
  }
  if (draft && draft.remarks) {
    document.getElementById('formRemarks').value = draft.remarks;
  }
  if (draft && draft.aiEnabled) {
    document.getElementById('formAiEnabled').checked = true;
  }
  switchFormTab('devices');
  updateFormEdgeDeviceSelects();
}

function clearFormDraft() {
  localStorage.removeItem('formGenDraft');
  _formDevCounter = 0;
  _formEdgeCounter = 0;
  document.getElementById('formDevTbody').innerHTML = '';
  document.getElementById('formEdgeTbody').innerHTML = '';
  document.getElementById('formRemarks').value = '';
  document.getElementById('formAiEnabled').checked = false;
  addFormDevRow();
  addFormDevRow();
  toast('草稿已清除', 1500);
}

function closeFormGen() {
  // Save draft before closing
  var devs = [], edges = [];
  document.querySelectorAll('#formDevTbody tr').forEach(function(row) {
    var nameInp = row.querySelector('input[id^="fd-name-"]');
    var typeSel = row.querySelector('select[id^="fd-type-"]');
    var ipInp = row.querySelector('input[id^="fd-ip-"]');
    var descInp = row.querySelector('input[id^="fd-desc-"]');
    if (nameInp && nameInp.value.trim()) {
      devs.push({
        name: nameInp.value.trim(),
        type: typeSel ? typeSel.value : 'router',
        ip: ipInp ? ipInp.value.trim() : '',
        desc: descInp ? descInp.value.trim() : ''
      });
    }
  });
  document.querySelectorAll('#formEdgeTbody tr').forEach(function(row) {
    var srcSel = row.querySelector('select[id^="fe-src-"]');
    var tgtSel = row.querySelector('select[id^="fe-tgt-"]');
    var sportInp = row.querySelector('input[id^="fe-sport-"]');
    var tportInp = row.querySelector('input[id^="fe-tport-"]');
    if (srcSel && tgtSel && srcSel.value && tgtSel.value) {
      edges.push({
        src: srcSel.value, tgt: tgtSel.value,
        srcPort: sportInp ? sportInp.value.trim() : '',
        tgtPort: tportInp ? tportInp.value.trim() : ''
      });
    }
  });
  var draft = { devs: devs, edges: edges, remarks: document.getElementById('formRemarks').value, aiEnabled: document.getElementById('formAiEnabled').checked };
  if (devs.length > 0 || edges.length > 0 || document.getElementById('formRemarks').value.trim()) {
    localStorage.setItem('formGenDraft', JSON.stringify(draft));
  }
  document.getElementById('formGenModal').classList.remove('open');
}

function switchFormTab(tab) {
  document.querySelectorAll('.form-gen-tab').forEach(function(t) { t.classList.remove('active'); });
  document.querySelectorAll('.form-gen-tab-content').forEach(function(c) { c.classList.remove('active'); });
  if (tab === 'devices') {
    document.querySelector('.form-gen-tab').classList.add('active');
    document.getElementById('tab-devices').classList.add('active');
  } else {
    document.querySelectorAll('.form-gen-tab')[1].classList.add('active');
    document.getElementById('tab-edges').classList.add('active');
    updateFormEdgeDeviceSelects();
  }
}

function getFormDevOptions(selected) {
  var html = '';
  _formDeviceTypes.forEach(function(t) {
    html += '<option value="' + t + '"' + (t === selected ? ' selected' : '') + '>' + _formDeviceLabels[t] + '</option>';
  });
  return html;
}

function addFormDevRow(dev) {
  var tbody = document.getElementById('formDevTbody');
  var id = ++_formDevCounter;
  var row = document.createElement('tr');
  row.id = 'fdev-' + id;
  row.innerHTML =
    '<td style="text-align:center;color:#9ca3af;font-size:12px">' + id + '</td>' +
    '<td><input type="text" id="fd-name-' + id + '" value="' + (dev && dev.name || '') + '" placeholder="如 Router1"></td>' +
    '<td><select id="fd-type-' + id + '">' + getFormDevOptions(dev && dev.type || 'router') + '</select></td>' +
    '<td><input type="text" id="fd-ip-' + id + '" value="' + (dev && dev.ip || '') + '" placeholder="如 192.168.1.1"></td>' +
    '<td><input type="text" id="fd-desc-' + id + '" value="' + (dev && dev.desc || '') + '" placeholder="可选"></td>' +
    '<td><button class="del-btn" onclick="delFormDevRow(' + id + ')">删除</button></td>';
  tbody.appendChild(row);
}

function delFormDevRow(id) {
  var row = document.getElementById('fdev-' + id);
  if (row) row.remove();
  updateFormEdgeDeviceSelects();
}

function getFormDevNames() {
  var names = [];
  document.querySelectorAll('#formDevTbody tr').forEach(function(row) {
    var inp = row.querySelector('input[id^="fd-name-"]');
    if (inp && inp.value.trim()) names.push(inp.value.trim());
  });
  return names;
}

function addFormEdgeRow(edge) {
  var tbody = document.getElementById('formEdgeTbody');
  var id = ++_formEdgeCounter;
  var devNames = getFormDevNames();
  var opts = devNames.length ? devNames.map(function(n) { return '<option value="'+n+'">'+n+'</option>'; }).join('') : '<option value="">-- 无设备 --</option>';
  var row = document.createElement('tr');
  row.id = 'fedge-' + id;
  row.innerHTML =
    '<td style="text-align:center;color:#9ca3af;font-size:12px">' + id + '</td>' +
    '<td><select id="fe-src-' + id + '" onchange="updateFormEdgeDeviceSelects()">' + opts + '</select></td>' +
    '<td><select id="fe-tgt-' + id + '">' + opts + '</select></td>' +
    '<td><input type="text" id="fe-sport-' + id + '" value="' + (edge && edge.srcPort || '') + '" placeholder="如 GE0/0/1"></td>' +
    '<td><input type="text" id="fe-tport-' + id + '" value="' + (edge && edge.tgtPort || '') + '" placeholder="如 GE0/0/1"></td>' +
    '<td><button class="del-btn" onclick="delFormEdgeRow(' + id + ')">删除</button></td>';
  tbody.appendChild(row);
}

function delFormEdgeRow(id) {
  var row = document.getElementById('fedge-' + id);
  if (row) row.remove();
}

function updateFormEdgeDeviceSelects() {
  var devNames = getFormDevNames();
  var opts = devNames.length ? devNames.map(function(n) { return '<option value="'+n+'">'+n+'</option>'; }).join('') : '<option value="">-- 无设备 --</option>';
  document.querySelectorAll('select[id^="fe-src-"], select[id^="fe-tgt-"]').forEach(function(sel) {
    var oldVal = sel.value;
    sel.innerHTML = opts;
    if (devNames.indexOf(oldVal) >= 0) sel.value = oldVal;
  });
}

function doFormGen() {
  // Collect device rows
  var devices = [];
  document.querySelectorAll('#formDevTbody tr').forEach(function(row) {
    var nameInp = row.querySelector('input[id^="fd-name-"]');
    if (!nameInp || !nameInp.value.trim()) return;
    var typeSel = row.querySelector('select[id^="fd-type-"]');
    var ipInp = row.querySelector('input[id^="fd-ip-"]');
    var descInp = row.querySelector('input[id^="fd-desc-"]');
    devices.push({
      name: nameInp.value.trim(),
      type: typeSel ? typeSel.value : 'router',
      ip: ipInp ? ipInp.value.trim() : '',
      desc: descInp ? descInp.value.trim() : ''
    });
  });
  if (devices.length === 0) {
    toast('请至少添加一个设备'); return;
  }
  // Collect edge rows
  var edges = [];
  document.querySelectorAll('#formEdgeTbody tr').forEach(function(row) {
    var srcSel = row.querySelector('select[id^="fe-src-"]');
    var tgtSel = row.querySelector('select[id^="fe-tgt-"]');
    if (!srcSel || !tgtSel || !srcSel.value || !tgtSel.value) return;
    var sportInp = row.querySelector('input[id^="fe-sport-"]');
    var tportInp = row.querySelector('input[id^="fe-tport-"]');
    edges.push({
      src: srcSel.value,
      tgt: tgtSel.value,
      srcPort: sportInp ? sportInp.value.trim() : '',
      tgtPort: tportInp ? tportInp.value.trim() : ''
    });
  });

  var useAi = document.getElementById('formAiEnabled').checked;
  var remarks = document.getElementById('formRemarks').value.trim();

  if (useAi) {
    // Build topology description
    var desc = '【批量生成拓扑请求】\n\n';
    desc += '## 设备列表\n';
    devices.forEach(function(d, i) {
      desc += (i+1) + '. ' + d.name + '（' + _formDeviceLabels[d.type] + '）';
      if (d.ip) desc += '，IP：' + d.ip;
      if (d.desc) desc += '，描述：' + d.desc;
      desc += '\n';
    });
    if (edges.length > 0) {
      desc += '\n## 连线列表\n';
      edges.forEach(function(e, i) {
        desc += (i+1) + '. ' + e.src + ' → ' + e.tgt;
        if (e.srcPort || e.tgtPort) desc += '（' + e.srcPort + ' → ' + e.tgtPort + ')';
        desc += '\n';
      });
    }
    if (remarks) {
      desc += '\n## 补充说明\n' + remarks + '\n';
    }
    desc += '\n请根据以上信息生成网络拓扑。将设备摆放在合适的位置，核心层设备放中间，汇聚/接入层设备放周围，保持整齐美观。';
    closeFormGen();
    // Send to AI chat
    document.getElementById('chatInput').value = desc;
    sendChat();
    // Open chat panel
    if (!document.getElementById('chatPanel').classList.contains('open')) {
      toggleChat();
    }
    toast('已发送至 AI 助手，请等待分析结果...', 3000);
  } else {
    // Direct generation: add nodes then edges
    closeFormGen();
    var GRID = GRID_SIZE || 48;
    var cols = Math.ceil(Math.sqrt(devices.length));
    var positions = {};
    devices.forEach(function(d, i) {
      var col = i % cols;
      var row = Math.floor(i / cols);
      var x = 200 + col * 180;
      var y = 150 + row * 160;
      var devInfo = DEVICES[d.type] || DEVICES.router;
      var nodeId = 'fg-' + Date.now() + '-' + i;
      positions[d.name] = nodeId;
      cy.add({
        group: 'nodes',
        data: {
          id: nodeId,
          type: d.type,
          label: d.name,
          icon: '/icons/' + devInfo.icon,
          color: devInfo.color,
          ip: d.ip,
          desc: d.desc
        },
        position: { x: x, y: y }
      });
    });
    edges.forEach(function(e) {
      var srcId = positions[e.src];
      var tgtId = positions[e.tgt];
      if (!srcId || !tgtId || srcId === tgtId) return;
      var edgeId = 'fe-' + Date.now() + '-' + Math.random().toString(36).substr(2,4);
      cy.add({
        group: 'edges',
        data: {
          id: edgeId,
          source: srcId,
          target: tgtId,
          srcPort: e.srcPort,
          tgtPort: e.tgtPort,
          edgeColor: pendingEdgeColor,
          edgeStyle: pendingEdgeStyle
        },
        css: {
          'line-color': pendingEdgeColor,
          'line-style': pendingEdgeStyle
        }
      });
    });
    saveUndoState && saveUndoState();
    autoSaveProject && autoSaveProject();
    refreshCanvas && refreshCanvas();
    toast('✓ 已生成 ' + devices.length + ' 个设备、' + edges.length + ' 条连线', 3000);
    addOpLog('human', '表单生成：' + devices.length + '个设备、' + edges.length + '条连线');
  }
}
</script>
</body>
</html>